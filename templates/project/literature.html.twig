{% extends 'base.html.twig' %}

{% block title %}Revue de Littérature - Djoliba{% endblock %}

{% block main %}
<div class="p-8 max-w-5xl mx-auto" 
     data-controller="literature" 
     data-literature-project-id-value="{{ project.id }}"
     data-literature-autostart-value="{{ app.request.query.get('autostart') == '1' ? 'true' : 'false' }}">
    {# En-tête du projet #}
    <div class="mb-8 flex justify-between items-start">
        <div>
            <nav class="flex text-sm text-slate-400 mb-2" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2">
                    <li><a href="{{ path('app_hub') }}" class="hover:text-djoliba transition-colors">Hub</a></li>
                    <li><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></li>
                    <li class="text-djoliba font-medium">Revue de littérature</li>
                </ol>
            </nav>
            <h1 class="text-3xl font-display font-bold text-djoliba">{{ project.name }}</h1>
        </div>
        <div class="flex gap-2">
            <span class="px-3 py-1 bg-djoliba/5 text-djoliba rounded-full text-xs font-bold border border-djoliba/10">Mode Intelligence Artificielle</span>
        </div>
    </div>

    {# Zone de recherche #}
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6 mb-8">
        <div class="flex gap-4">
            <div class="flex-grow relative">
                <input type="text" 
                       data-literature-target="input"
                       value="{{ project.name }}"
                       class="w-full pl-5 pr-4 py-4 bg-slate-50 border-none rounded-2xl text-djoliba placeholder-slate-400 focus:ring-2 focus:ring-djoliba/20 transition-all"
                       placeholder="Décrivez votre sujet de recherche ou posez une question complexe...">
            </div>
            <button data-action="click->literature#onSearch" 
                    class="px-8 py-4 bg-djoliba text-white rounded-2xl font-bold shadow-lg shadow-djoliba/20 hover:-translate-y-0.5 transition-all flex items-center gap-2">
                <span>Analyser</span>
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {# Zone principale : Revue de littérature #}
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 h-[500px] flex flex-col overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-50 flex justify-between items-center bg-slate-50/30">
                    <h2 class="text-sm font-bold text-djoliba flex items-center gap-2">
                        <svg class="w-4 h-4 text-emerald_ia" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                        Analyse Synthétique
                    </h2>
                    <div data-literature-target="status" class="hidden">
                        <span class="flex h-2 w-2 rounded-full bg-emerald_ia animate-pulse"></span>
                    </div>
                </div>
                
                <div class="p-8 flex-grow overflow-y-auto">
                    <div data-literature-target="output" class="prose prose-slate max-w-none text-slate-700 leading-relaxed"></div>
                </div>
            </div>
        </div>

        {# Zone latérale : Suggestions d'articles #}
        <div class="space-y-6">
            <h3 class="text-sm font-bold text-djoliba uppercase tracking-wider flex items-center gap-2">
                <svg class="w-4 h-4 text-gold_prestige" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                Sources Recommandées
            </h3>
            
            <div data-literature-target="suggestions" class="space-y-4">
                {# Placeholder initial #}
                <div class="bg-slate-50/50 rounded-2xl p-6 border border-dashed border-slate-200 text-center">
                    <p class="text-xs text-slate-400">Les articles scientifiques pertinents apparaîtront ici après l'analyse.</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
