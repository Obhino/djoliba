{% extends 'base.html.twig' %}

{% block title %}Revue de Littérature - Djoliba{% endblock %}

{% block footer %}{% endblock %}

{% block main %}
<div class="h-screen flex flex-col overflow-hidden px-4 pt-4 pb-2" 
     data-controller="literature" 
     data-literature-project-id-value="{{ project.id }}"
     data-literature-last-query-value="{{ last_query|default('') }}"
     data-literature-autostart-value="{{ app.request.query.get('autostart') == '1' ? 'true' : 'false' }}">
    {# En-tête compact du projet #}
    <div class="mb-2 flex justify-between items-center flex-shrink-0">
        <div class="flex items-center gap-3">
            <nav class="flex text-xs text-slate-400" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-1.5">
                    <li><a href="{{ path('app_hub') }}" class="hover:text-djoliba transition-colors">Hub</a></li>
                    <li><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></li>
                    <li class="text-djoliba font-medium">Revue de littérature</li>
                </ol>
            </nav>
            <span class="text-lg font-display font-bold text-djoliba">{{ project.name }}</span>
        </div>
        <span class="px-2.5 py-0.5 bg-djoliba/5 text-djoliba rounded-full text-[10px] font-bold border border-djoliba/10">Mode IA</span>
    </div>

    {# Zone de recherche compacte #}
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-2.5 mb-3 flex-shrink-0">
        <div class="flex gap-2">
            <div class="flex-grow relative">
                <input type="text" 
                       data-literature-target="input"
                       value="{{ last_query|default(project.name) }}"
                       class="w-full pl-4 pr-4 py-2 bg-slate-50 border-none rounded-lg text-djoliba text-sm placeholder-slate-400 focus:ring-2 focus:ring-djoliba/20 transition-all"
                       placeholder="Décrivez votre sujet de recherche ou posez une question complexe...">
            </div>
            <button data-action="click->literature#onSearch" 
                    class="px-5 py-2 bg-djoliba text-white rounded-lg font-bold text-sm shadow-lg shadow-djoliba/20 hover:-translate-y-0.5 transition-all flex items-center gap-1.5">
                <span>Analyser</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </button>
            <button data-action="click->literature#onDeepSearch" 
                    class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-djoliba rounded-lg font-bold text-sm border border-slate-200 transition-all flex items-center gap-1.5 shadow-sm">
                <span>Recherche Approfondie</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </button>
        </div>
    </div>

    {# Grille principale — colonnes indépendantes #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 flex-grow min-h-0 items-start">
        {# Zone principale : Revue de littérature — remplit tout l'espace vertical restant #}
        <div class="lg:col-span-2" style="height: calc(100vh - 140px);">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 flex flex-col h-full">
                <div class="px-4 py-2.5 border-b border-slate-50 flex justify-between items-center bg-slate-50/30 rounded-t-2xl flex-shrink-0">
                    <h2 class="text-xs font-bold text-djoliba flex items-center gap-2">
                        <svg class="w-3.5 h-3.5 text-emerald_ia" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                        Analyse Synthétique
                    </h2>
                    <div class="flex items-center gap-3">
                        {# Contrôle de la taille de police #}
                        <div class="flex items-center gap-0.5 bg-slate-100 rounded-lg p-0.5 border border-slate-200">
                            <button data-action="click->literature#zoomOut" 
                                    class="w-5 h-5 flex items-center justify-center text-slate-600 hover:text-djoliba hover:bg-white rounded transition-colors font-bold text-xs"
                                    title="Diminuer la taille de police">
                                -
                            </button>
                            <button data-action="click->literature#zoomIn" 
                                    class="w-5 h-5 flex items-center justify-center text-slate-600 hover:text-djoliba hover:bg-white rounded transition-colors font-bold text-xs"
                                    title="Augmenter la taille de police">
                                +
                            </button>
                        </div>

                        <div data-literature-target="status" class="hidden">
                            <span class="flex h-2 w-2 rounded-full bg-emerald_ia animate-pulse"></span>
                        </div>
                    </div>
                </div>

                <div class="p-6 flex-grow overflow-y-auto synth-scroll min-h-0">
                    <div data-literature-target="output" class="prose prose-slate max-w-none text-slate-700 leading-relaxed">
                        {% if last_synthesis %}
                            {{ last_synthesis|raw }}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# Zone latérale : Suggestions d'articles — indépendante #}
        <div class="flex flex-col">
            <h3 class="text-xs font-bold text-djoliba uppercase tracking-wider flex items-center gap-1.5 mb-2 flex-shrink-0">
                <svg class="w-4 h-4 text-gold_prestige" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                Sources Recommandées
            </h3>
            
            <div data-literature-target="suggestions" class="space-y-3 overflow-y-auto suggestions-scroll pr-1">
                {# Placeholder initial #}
                <div class="bg-slate-50/50 rounded-2xl p-6 border border-dashed border-slate-200 text-center">
                    <p class="text-xs text-slate-400">Les articles scientifiques pertinents apparaîtront ici après l'analyse.</p>
                </div>
            </div>
        </div>
    </div>
    {# Modal Recherche Approfondie #}
    <div data-literature-target="deepSearchModal" 
         class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/40 backdrop-blur-sm transition-all duration-300">
        
        {# Backdrop Click to Close #}
        <div data-action="click->literature#closeDeepSearch" class="absolute inset-0 cursor-default"></div>

        {# Modal Container #}
        <div class="relative bg-white rounded-3xl p-6 border border-slate-100 shadow-2xl flex flex-col z-10 w-full max-w-4xl max-h-[85vh] transform transition-all duration-300">
            
            {# Close Button #}
            <button type="button" data-action="click->literature#closeDeepSearch" class="absolute top-5 right-5 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>

            {# Header #}
            <div class="mb-4 pr-8">
                <h3 class="text-lg font-bold text-djoliba flex items-center gap-2">
                    <svg class="w-5 h-5 text-gold_prestige" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    Recherche Approfondie (Web & Bases de données)
                </h3>
                <p class="text-xs text-slate-400 mt-1">Résultats bruts de la recherche par mots-clés sur internet. Ajoutez-les au projet pour étendre votre bibliographie.</p>
            </div>

            {# Loader #}
            <div data-literature-target="deepSearchLoading" class="flex-grow flex flex-col items-center justify-center p-12 hidden">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-djoliba mb-3"></div>
                <p class="text-xs text-slate-500 font-semibold animate-pulse">Parcours du web en cours, veuillez patienter...</p>
            </div>

            {# Scrollable Content Area #}
            <div data-literature-target="deepSearchContent" class="flex-grow overflow-y-auto pr-1 space-y-4 grid grid-cols-1 md:grid-cols-2 gap-4 auto-rows-max p-1 suggestions-scroll">
                {# Les résultats seront injectés ici en JS #}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block styles %}
<style>
    /* Zoom proportionnel de la police de la synthèse */
    [data-literature-target="output"] {
        --synth-font-size-multiplier: 1.0;
    }
    [data-literature-target="output"] p,
    [data-literature-target="output"] li,
    [data-literature-target="output"] .ref {
        font-size: calc(0.75rem * var(--synth-font-size-multiplier, 1.0)) !important;
        line-height: 1.625 !important;
    }
    [data-literature-target="output"] h3 {
        font-size: calc(1.125rem * var(--synth-font-size-multiplier, 1.0)) !important;
        line-height: 1.4 !important;
    }
    [data-literature-target="output"] h4 {
        font-size: calc(0.875rem * var(--synth-font-size-multiplier, 1.0)) !important;
        line-height: 1.4 !important;
    }
    [data-literature-target="output"] .katex-display,
    [data-literature-target="output"] .katex {
        font-size: calc(1em * var(--synth-font-size-multiplier, 1.0)) !important;
    }

    /* Scrollbar fine et élégante pour la zone d'analyse */
    .synth-scroll {
        overflow-y: auto !important;
        scrollbar-width: thin;
        scrollbar-color: var(--color-djoliba, #1a3c5e) transparent;
    }
    .synth-scroll::-webkit-scrollbar {
        width: 5px;
    }
    .synth-scroll::-webkit-scrollbar-track {
        background: transparent;
        border-radius: 10px;
    }
    .synth-scroll::-webkit-scrollbar-thumb {
        background: rgba(26, 60, 94, 0.2);
        border-radius: 10px;
        transition: background 0.2s;
    }
    .synth-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(26, 60, 94, 0.5);
    }

    /* Style Premium pour les Références Scientifiques Enrichies */
    .prose .ref {
        display: inline-block;
        padding: 0.25rem 0.6rem;
        margin: 0.2rem 0;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        line-height: 1.25rem;
        font-style: normal !important;
        text-decoration: none !important;
        transition: all 0.2s ease;
        border: 1px solid transparent;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
    }
    .prose .ref:hover {
        transform: translateY(-0.5px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }
    .prose .ref.verified {
        background-color: #f0fdf4 !important; /* emerald-50 */
        border-color: #dcfce7 !important; /* emerald-100 */
        color: #166534 !important; /* emerald-800 */
    }
    .prose .ref.corrected {
        background-color: #fef8e6 !important; /* amber-50/100 blend */
        border-color: #fef08a !important; /* amber-200 */
        color: #854d0e !important; /* amber-800 */
    }
    .prose .ref.unverified {
        background-color: #fef2f2 !important; /* red-50 */
        border-color: #fee2e2 !important; /* red-100 */
        color: #991b1b !important; /* red-800 */
    }

    .prose .ref-authors {
        font-weight: 700;
    }
    .prose .ref-year {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-weight: 500;
        opacity: 0.85;
    }
    .prose .ref-title {
        font-style: italic;
        font-weight: 600;
    }
    .prose .ref-journal {
        font-weight: 500;
        opacity: 0.8;
    }
    .prose a.ref-link {
        display: inline-flex !important;
        align-items: center;
        padding: 0.05rem 0.35rem !important;
        background-color: #ffffff !important;
        border: 1px solid rgba(26, 60, 94, 0.2) !important;
        border-radius: 0.25rem !important;
        font-weight: 700 !important;
        color: #1a3c5e !important; /* djoliba principal */
        text-decoration: none !important;
        margin: 0 0.25rem !important;
        transition: all 0.15s ease !important;
    }
    .prose a.ref-link:hover {
        background-color: #1a3c5e !important;
        color: #ffffff !important;
        border-color: #1a3c5e !important;
        text-decoration: none !important;
    }
    .prose .ref-badge {
        display: inline-flex;
        align-items: center;
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        padding: 0.05rem 0.4rem;
        border-radius: 9999px;
        margin-left: 0.3rem;
        border: 1px solid currentColor;
    }
    .prose .ref.verified .ref-badge {
        background-color: #dcfce7 !important;
        color: #15803d !important; /* emerald-700 */
    }
    .prose .ref.corrected .ref-badge {
        background-color: #fef08a !important;
        color: #a16207 !important; /* amber-700 */
    }
    .prose .ref.unverified .ref-badge {
        background-color: #fee2e2 !important;
        color: #b91c1c !important; /* red-700 */
    }

    /* Scrollbar fine pour la zone de suggestions */
    .suggestions-scroll {
        max-height: 640px;
        scrollbar-width: thin;
        scrollbar-color: var(--color-djoliba, #1a3c5e) transparent;
    }
    .suggestions-scroll::-webkit-scrollbar {
        width: 4px;
    }
    .suggestions-scroll::-webkit-scrollbar-track {
        background: transparent;
        border-radius: 10px;
    }
    .suggestions-scroll::-webkit-scrollbar-thumb {
        background: rgba(26, 60, 94, 0.2);
        border-radius: 10px;
    }
    .suggestions-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(26, 60, 94, 0.5);
    }

    /* Bloquer le défilement global de la page sur desktop */
    @media (min-width: 1024px) {
        html, body {
            overflow: hidden !important;
            height: 100vh !important;
        }
        .suggestions-scroll {
            max-height: min(640px, calc(100vh - 170px)) !important;
        }
    }
</style>
{% endblock %}
