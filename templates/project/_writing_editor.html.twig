				<div class="flex items-center justify-between p-4 bg-slate-50 border border-slate-100 rounded-2xl">
					<div>
						<span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Score Flesch (Français)</span>
						<span data-writing-editor-target="readabilityFleschAppreciation" class="text-xs font-bold text-slate-600">Calcul...</span>
					</div>
					<div data-writing-editor-target="readabilityFleschScore" class="text-2xl font-black text-djoliba">-</div>
				</div>

				{# Détails #}
				<div class="grid grid-cols-2 gap-4">
					<div class="p-4 bg-slate-50/50 border border-slate-100 rounded-2xl space-y-1">
						<span class="block text-[9px] font-bold text-slate-400 uppercase tracking-wider">Mots par phrase</span>
						<div class="flex items-baseline gap-1">
							<span data-writing-editor-target="readabilityWordsPerSentence" class="text-base font-bold text-slate-700">0</span>
							<span class="text-[10px] text-slate-400 font-semibold">mots</span>
						</div>
					</div>
					<div class="p-4 bg-slate-50/50 border border-slate-100 rounded-2xl space-y-1">
						<span class="block text-[9px] font-bold text-slate-400 uppercase tracking-wider">Phrases passives</span>
						<div class="flex items-baseline gap-1">
							<span data-writing-editor-target="readabilityPassivePercent" class="text-base font-bold text-slate-700">0</span>
							<span class="text-[10px] text-slate-400 font-semibold">%</span>
						</div>
					</div>
				</div>

				{# Recommandations #}
				<div class="space-y-3">
					<h4 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Recommandations de style</h4>
					<div data-writing-editor-target="readabilityRecommendations" class="space-y-2 max-h-48 overflow-y-auto custom-scrollbar pr-1">
						{# Rempli dynamiquement en JS #}
					</div>
				</div>
			</div>

			<div class="px-8 py-4 border-t border-slate-50 flex justify-end bg-slate-50/20">
				<button type="button" data-action="click->writing-editor#closeReadabilityModal" class="px-5 py-2.5 bg-slate-100 text-slate-600 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">
					Fermer
				</button>
			</div>
	</div>

	{# ════════════════════════════════════════════════════════════════════ #}
	{# MODALE BIBLIOGRAPHIE BIBTEX — Sélection et insertion de citation   #}
	{# ════════════════════════════════════════════════════════════════════ #}
	<div data-writing-editor-target="citationModal"
	     class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/40 backdrop-blur-sm hidden"
	     role="dialog" aria-modal="true" aria-label="Gestionnaire de bibliographie">

		<div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden border border-slate-100/80 flex flex-col max-h-[85vh]">

			{# ── En-tête ───────────────────────────────────────────── #}
			<div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/60 flex-shrink-0">
				<div class="flex items-center gap-3">
					<div class="w-9 h-9 rounded-2xl bg-amber-50 border border-amber-100 flex items-center justify-center text-lg">📚</div>
					<div>
						<h3 class="text-sm font-black text-djoliba">Bibliographie</h3>
						<p class="text-[10px] text-slate-400">Gérez vos références et insérez des citations dans l'éditeur</p>
					</div>
				</div>
				<button type="button"
				        data-action="click->writing-editor#closeCitationModal"
				        class="p-2 hover:bg-slate-100 rounded-full text-slate-400 hover:text-slate-600 transition-colors"
				        title="Fermer (Échap)">
					<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>

			{# ── Onglets ───────────────────────────────────────────── #}
			<div class="flex border-b border-slate-100 bg-slate-50/30 text-xs font-bold text-slate-500 flex-shrink-0">
				<button type="button" 
				        data-writing-editor-target="bibTabLocal" 
				        data-action="click->writing-editor#switchBibTab" 
				        data-tab="local" 
				        class="flex-1 py-3 text-center border-b-2 border-djoliba text-djoliba">
					Fichier BibTeX local
				</button>
				<button type="button" 
				        data-writing-editor-target="bibTabZotero" 
				        data-action="click->writing-editor#switchBibTab" 
				        data-tab="zotero" 
				        class="flex-1 py-3 text-center border-b-2 border-transparent hover:text-djoliba transition-colors">
					Bibliothèque Zotero
				</button>
			</div>

			{# ── PANNEAU 1 : BIBTEX LOCAL ────────────────────────────── #}
			<div data-writing-editor-target="bibLocalPanel" class="flex flex-col flex-grow overflow-hidden">
				{# Barre de recherche #}
				<div class="px-6 pt-4 pb-2 flex-shrink-0">
					<div class="relative">
						<svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400 pointer-events-none" fill="none" viewbox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
						</svg>
						<input type="text"
						       placeholder="Rechercher par auteur, titre, clé BibTeX…"
						       class="w-full pl-9 pr-4 py-2 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-2 focus:ring-djoliba/10 transition-all bg-slate-50/50"
						       data-action="input->writing-editor#searchBibEntries"/>
					</div>
				</div>

				{# Liste des références locales #}
				<div data-writing-editor-target="citationSelect"
				     class="flex-1 overflow-y-auto px-6 py-2 space-y-1 min-h-[220px] custom-scrollbar">
					<p class="text-xs text-slate-400 text-center py-8 italic">Chargement des références…</p>
				</div>

				{# Zone import .bib #}
				<div class="px-6 py-3 border-t border-slate-100 bg-slate-50/40 flex-shrink-0">
					<div class="flex items-center gap-3">
						<label class="flex items-center gap-2 px-3 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-semibold text-slate-600 hover:border-djoliba hover:text-djoliba cursor-pointer transition-all shadow-sm hover:shadow-md flex-shrink-0">
							<svg class="w-3.5 h-3.5" fill="none" viewbox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
							</svg>
							Importer .bib
							<input type="file"
							       accept=".bib"
							       class="hidden"
							       data-action="change->writing-editor#importBibFile"/>
						</label>
						<span data-bib-import-status class="text-[10px] text-slate-400 italic flex-1 truncate"></span>
					</div>
				</div>

				{# Footer actions local #}
				<div class="px-6 py-4 border-t border-slate-100 flex justify-end gap-3 bg-white flex-shrink-0">
					<button type="button"
					        data-action="click->writing-editor#closeCitationModal"
					        class="px-5 py-2.5 bg-slate-100 text-slate-600 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">
						Annuler
					</button>
					<button type="button"
					        data-action="click->writing-editor#insertSelectedCitation"
					        class="px-5 py-2.5 bg-djoliba text-white text-xs font-bold rounded-xl hover:opacity-90 shadow-md shadow-djoliba/10 transition-all flex items-center gap-2">
						<svg class="w-3.5 h-3.5" fill="none" viewbox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
						</svg>
						Insérer la citation
					</button>
				</div>
			</div>

			{# ── PANNEAU 2 : SYSTEME ZOTERO ────────────────────────────── #}
			<div data-writing-editor-target="bibZoteroPanel" class="flex flex-col flex-grow overflow-hidden hidden">
				
				{# Sous-panneau A : Formulaire de configuration Zotero #}
				<div data-writing-editor-target="zoteroConfigForm" class="p-6 space-y-4 flex-1 overflow-y-auto hidden">
					<div class="bg-amber-50/50 border border-amber-200/50 rounded-2xl p-4 text-[11px] text-amber-800 leading-relaxed">
						<strong>Intégration de votre bibliothèque Zotero :</strong><br>
						Saisissez votre Zotero User ID (disponible dans vos réglages de profil Zotero) et une clé d'API (créée dans vos réglages Zotero -> Developer settings).
					</div>
					<div class="space-y-3">
						<div>
							<label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Zotero User ID</label>
							<input type="text" 
							       data-writing-editor-target="zoteroUserId" 
							       placeholder="Ex: 1234567" 
							       class="w-full px-4 py-2 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-2 focus:ring-djoliba/10 transition-all" />
						</div>
						<div>
							<label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Clé d'API Zotero</label>
							<input type="password" 
							       data-writing-editor-target="zoteroApiKey" 
							       placeholder="Clé générée sur zotero.org" 
							       class="w-full px-4 py-2 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-2 focus:ring-djoliba/10 transition-all" />
						</div>
						<div class="pt-2 flex justify-between items-center gap-2">
							<span data-writing-editor-target="zoteroConfigStatus" class="text-[10px] italic font-semibold"></span>
							<button type="button" 
							        data-action="click->writing-editor#saveZoteroConfig" 
							        class="px-4 py-2 bg-djoliba text-white text-xs font-bold rounded-xl hover:opacity-90 transition-all shadow-sm">
								Valider et Connecter
							</button>
						</div>
					</div>
				</div>

				{# Sous-panneau B : Navigation & Import Zotero #}
				<div data-writing-editor-target="zoteroConfigView" class="flex flex-col flex-1 overflow-hidden hidden">
					{# Infos de connexion & déconnexion #}
					<div class="px-6 py-2 bg-slate-50 border-b border-slate-100 flex items-center justify-between flex-shrink-0">
						<span data-zotero-info class="text-[10px] text-slate-500 font-semibold">Connecté</span>
						<button type="button" 
						        data-action="click->writing-editor#showZoteroConfigForm" 
						        class="text-[9px] text-red-500 hover:underline font-bold">
							Modifier les identifiants
						</button>
					</div>

					{# Filtres Zotero (Collections & Recherche) #}
					<div class="px-6 pt-3 pb-2 space-y-2 border-b border-slate-100 flex-shrink-0 bg-slate-50/20">
						<div class="grid grid-cols-2 gap-2">
							<select data-writing-editor-target="zoteroCollection" 
							        data-action="change->writing-editor#loadZoteroItems" 
							        class="px-3 py-2 text-[11px] rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba bg-white font-medium text-slate-600">
								<option value="">Toutes les collections</option>
							</select>
							<div class="relative">
								<svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3 h-3 text-slate-400 pointer-events-none" fill="none" viewbox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
								</svg>
								<input type="text" 
								       data-writing-editor-target="zoteroSearch" 
								       data-action="input->writing-editor#loadZoteroItems" 
								       placeholder="Filtrer sur Zotero..." 
								       class="w-full pl-7 pr-3 py-1.5 text-[11px] rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba" />
							</div>
						</div>
					</div>

					{# Liste des items Zotero #}
					<div data-writing-editor-target="zoteroResults" 
					     class="flex-1 overflow-y-auto px-6 py-2 space-y-1 min-h-[160px] custom-scrollbar">
						<p class="text-xs text-slate-400 text-center py-8">Chargement de votre bibliothèque Zotero...</p>
					</div>

					{# Footer sync & import #}
					<div class="px-6 py-3 border-t border-slate-100 bg-slate-50/40 flex items-center justify-between flex-shrink-0">
						<span data-writing-editor-target="zoteroSyncStatus" class="text-[10px] italic font-semibold"></span>
						<div class="flex gap-2">
							<button type="button" 
							        data-action="click->writing-editor#loadZoteroItems" 
							        class="px-3 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[10px] font-bold rounded-xl transition-all" 
							        title="Rafraîchir">
								⟳
							</button>
							<button type="button" 
							        data-zotero-import-btn 
							        data-action="click->writing-editor#importSelectedZoteroItems" 
							        disabled 
							        class="px-4 py-2 bg-djoliba text-white text-[10px] font-bold rounded-xl hover:opacity-90 shadow-sm opacity-50 cursor-not-allowed transition-all flex items-center gap-1.5">
								Importer références
							</button>
						</div>
					</div>
				</div>

			</div>
		</div>
	</div>

</div>


