{# templates/project/_writing_editor.html.twig #}
{#
  Composant d'Édition Scientifique Réutilisable (Djoliba Rich Editor)
  
  Paramètres requis :
  - project : Entité Project associée
  
  Paramètres optionnels :
  - save_url : Endpoint de sauvegarde auto (default: /api/projects/{id}/content)
  - export_url : Endpoint de téléchargement LaTeX (default: /api/export/latex)
  - placeholder : Texte d'invite de l'éditeur
  - storage_key : Clé LocalStorage de sauvegarde locale
#}

<style>
	/* TipTap / ProseMirror Full Height Editable Area */
	.tiptap.ProseMirror {
		min-height: 100% !important;
		height: 100% !important;
		outline: none !important;
		padding: 1.5rem !important;
	}
	.tiptap.ProseMirror:focus {
		outline: none !important;
	}
</style>

{% set save_url = save_url|default(path('api_project_save_content', {id: project.id})) %}
{% set export_url = export_url|default(path('api_editor_export_latex')) %}
{% set placeholder = placeholder|default('Rédigez votre article ou thèse ici. Le Markdown et le LaTeX sont supportés...') %}
{% set storage_key = storage_key|default('djoliba_draft_' ~ project.id) %}
{% set sub_project_id = sub_project_id|default(0) %}

	<div
	data-controller="writing-editor editor-ai"
	data-writing-editor-project-id-value="{{ project.id }}"
	data-writing-editor-sub-project-id-value="{{ sub_project_id }}"
	data-writing-editor-save-url-value="{{ save_url }}"
	data-writing-editor-export-url-value="{{ export_url }}"
	data-writing-editor-placeholder-value="{{ placeholder }}"
	data-writing-editor-storage-key-value="{{ storage_key }}"
	data-writing-editor-initial-mode-value="{{ project.metadata.writing_mode|default('wysiwyg') }}"
	data-writing-editor-user-name-value="{{ app.user.firstName|default('Chercheur') }}"
	class="w-full {% if is_thesis|default(false) %}flex-grow flex flex-col min-h-0 overflow-hidden space-y-2.5{% else %}space-y-6{% endif %}"> {# 1. BARRE D'OUTILS PRINCIPALE #}

	{% if is_thesis|default(false) %}
	<div class="border border-slate-100 rounded-3xl p-1 bg-white flex-grow flex flex-col min-h-0 overflow-hidden shadow-sm">
	{% endif %}

	<div
		class="bg-white rounded-2xl border border-slate-100 p-4 shadow-sm flex flex-col md:flex-row gap-4 items-center justify-between">

		{# Groupe Gauche : Onglets / Bascule de Mode #}
		<div class="flex items-center gap-2 bg-slate-50 border border-slate-100 p-1 rounded-xl shadow-inner w-full md:w-auto">
			<button type="button" data-writing-editor-target="modeWysiwygBtn" data-action="click->writing-editor#setWysiwygMode" class="flex-1 md:flex-none px-4 py-2 text-xs font-bold rounded-lg flex items-center justify-center gap-2 transition-all hover:bg-white hover:shadow-sm leading-tight text-center" title="Basculez sur l'éditeur visuel (WYSIWYG)">
				<svg class="w-4 h-4 flex-shrink-0" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
				</svg>
				<span class="text-left">Visuel<br>(WYSIWYG)</span>
			</button>
			<button type="button" data-writing-editor-target="modeLatexBtn" data-action="click->writing-editor#setLatexMode" class="flex-1 md:flex-none px-4 py-2 text-xs font-bold rounded-lg flex items-center justify-center gap-2 transition-all hover:bg-white hover:shadow-sm leading-tight text-center" title="Basculez sur l'éditeur LaTeX brut / Markdown">
				<svg class="w-4 h-4 flex-shrink-0" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
				</svg>
				<span class="text-left">LaTeX<br>brut</span>
			</button>
		</div>

		{# Groupe Milieu : Actions de Formatage (Uniquement WYSIWYG) #}
		<div class="flex items-center gap-1 bg-slate-50 border border-slate-100 p-1 rounded-xl shadow-inner overflow-x-auto w-full md:w-auto" data-writing-editor-target="wysiwygToolbar">

			<button type="button" data-action="click->writing-editor#undo" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Annuler (Ctrl+Z)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
				</svg>
			</button>
			<button type="button" data-action="click->writing-editor#redo" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Rétablir (Ctrl+Y)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 10H11a8 8 0 00-8 8v2m18-10l-6 6m6-6l-6-6"/>
				</svg>
			</button>
			{# Rechercher & Remplacer #}
			<button type="button" data-action="click->writing-editor#toggleSearchReplace" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Rechercher et remplacer (Ctrl+F)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
				</svg>
			</button>

			{# Mode Focus #}
			<button type="button" data-action="click->writing-editor#toggleFocusMode" data-writing-editor-target="focusBtn" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Mode Focus / Zen (Plein écran)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5v-4m0 4h-4m4 0l-5-5"/>
				</svg>
			</button>

			{# Plan du document #}
			<button type="button" data-action="click->writing-editor#toggleOutline" data-writing-editor-target="outlineBtn" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Plan du document (Table des matières)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/>
				</svg>
			</button>

			{# Commentaires #}
			<button type="button" data-action="click->writing-editor#toggleAnnotationsPanel" data-writing-editor-target="annotationBtn" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Afficher les commentaires">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
				</svg>
			</button>
			<span class="w-[1px] h-4 bg-slate-200 mx-1"></span>

			<button type="button" data-action="click->writing-editor#toggleBold" class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Gras (Ctrl+B)">
				G
			</button>
			<button type="button" data-action="click->writing-editor#toggleItalic" class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-serif italic text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Italique (Ctrl+I)">
				I
			</button>
			<span class="w-[1px] h-4 bg-slate-200 mx-1"></span>
			<button type="button" data-action="click->writing-editor#toggleHeading" data-level="1" class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Titre principal">
				H1
			</button>
			<button type="button" data-action="click->writing-editor#toggleHeading" data-level="2" class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Sous-titre">
				H2
			</button>
			<button type="button" data-action="click->writing-editor#toggleHeading" data-level="3" class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Titre 3">
				H3
			</button>
			<span class="w-[1px] h-4 bg-slate-200 mx-1"></span>
			<button type="button" data-action="click->writing-editor#toggleBulletList" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Liste à puces">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
			</button>
			<button type="button" data-action="click->writing-editor#toggleOrderedList" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Liste ordonnée">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
			</button>
			<button type="button" data-action="click->writing-editor#toggleCodeBlock" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Bloc de code">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
			</button>
			<span class="w-[1px] h-4 bg-slate-200 mx-1"></span>
			<button type="button" data-action="click->writing-editor#insertTableModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Insérer un tableau">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
			</button>
			<button type="button" data-action="click->writing-editor#insertFigureModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Insérer une figure légendée">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
			</button>
			<button type="button" data-action="click->writing-editor#insertFootnoteModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all flex-shrink-0" title="Insérer une note de bas de page">
				<span class="text-xs font-bold leading-none">N<sup>1</sup></span>
			</button>
			<button type="button" data-action="click->writing-editor#insertReferenceModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Insérer une référence croisée">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
			</button>

			{# Citation BibTeX #}
			<button type="button" data-action="click->writing-editor#insertCitationModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Insérer une citation bibliographique BibTeX (\cite{key})">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
				</svg>
			</button>
			<button type="button" data-action="click->writing-editor#insertMathModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all flex-shrink-0" title="Insérer une équation mathématique LaTeX (∑)">
				<span class="text-xs font-bold leading-none">∑</span>
			</button>
			<button type="button" data-writing-editor-target="toolbarDeleteTableBtn" data-action="click->writing-editor#deleteTableUnderCursor" class="w-8 h-8 rounded-lg flex items-center justify-center text-red-500 hover:text-red-700 hover:bg-red-50 border border-transparent hover:border-red-100 hover:shadow-sm transition-all hidden" title="Supprimer le tableau sous le curseur">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
			</button>
			<button type="button" data-writing-editor-target="toolbarDeleteFigureBtn" data-action="click->writing-editor#deleteFigureUnderCursor" class="w-8 h-8 rounded-lg flex items-center justify-center text-red-500 hover:text-red-700 hover:bg-red-50 border border-transparent hover:border-red-100 hover:shadow-sm transition-all hidden" title="Supprimer la figure sous le curseur">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
			</button>
		</div>

		{# Groupe Droite : Outils de Publication & Document #}
		<div
			class="flex items-center gap-2 w-full md:w-auto justify-end">
			{# Aperçu en direct (Split screen) #}
			<button type="button" data-writing-editor-target="previewBtn" data-action="click->writing-editor#togglePreview" class="w-9 h-9 text-djoliba rounded-xl flex items-center justify-center hover:bg-slate-100 transition-all" title="Prévisualiser KaTeX (Aperçu en direct split-screen)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
				</svg>
			</button>

			{# Historique IA #}
			<button type="button" data-action="click->editor-ai#openHistoryModal" class="w-9 h-9 text-djoliba rounded-xl flex items-center justify-center hover:bg-slate-100 transition-all" title="Historique IA (Revoir et réutiliser vos requêtes)">
				<svg class="w-4 h-4 text-djoliba" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
				</svg>
			</button>

			{# Versions (Snapshots) #}
			<button type="button" data-action="click->writing-editor#openSnapshotModal" class="w-9 h-9 text-djoliba rounded-xl flex items-center justify-center hover:bg-slate-100 transition-all" title="Versions du document (Sauvegarder et restaurer)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 5.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/>
				</svg>
			</button>

			{# Aperçu de Rendu LaTeX Interprété (Modal) #}
			<button type="button" data-writing-editor-target="renderBtn" data-action="click->writing-editor#showLatexPreview" class="w-9 h-9 text-emerald-600 rounded-xl flex items-center justify-center hover:bg-emerald-50 transition-all hidden" title="Aperçu du Rendu final LaTeX (Modal)">
				<svg class="w-4 h-4 animate-pulse" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
				</svg>
			</button>

			{# Importer #}
			<button type="button" data-action="click->writing-editor#triggerFileInput" data-writing-editor-target="importBtn" class="w-9 h-9 text-djoliba rounded-xl flex items-center justify-center hover:bg-slate-100 transition-all" title="Importer un fichier (DOCX ou LaTeX)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
				</svg>
			</button>
			<input type="file" accept=".docx,.tex" data-writing-editor-target="fileInput" data-action="change->writing-editor#handleFileSelect" class="hidden">

			{# Exporter en LaTeX #}
			<button type="button" data-action="click->writing-editor#exportLatex" class="w-9 h-9 text-gold_prestige rounded-xl flex items-center justify-center hover:bg-slate-100 transition-all" title="Exporter le document au format LaTeX (.tex)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
				</svg>
			</button>

			{# Exporter en PDF #}
			<button type="button" data-action="click->writing-editor#exportPdf" class="w-9 h-9 text-rose-600 rounded-xl flex items-center justify-center hover:bg-rose-50 transition-all" title="Exporter le document au format PDF (.pdf)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 15h6"/>
				</svg>
			</button>

			{# Aide / Guide d'utilisation #}
			<button type="button" data-action="click->writing-editor#openHelpModal" class="w-9 h-9 text-slate-500 hover:text-djoliba rounded-xl flex items-center justify-center hover:bg-slate-100 transition-all" title="Guide d'utilisation de l'éditeur scientifique">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
				</svg>
			</button>
		</div>
	</div>

	{# BANDEAU RECHERCHER & REMPLACER #}
	<div data-writing-editor-target="searchReplaceBar" class="hidden bg-slate-50 border-b border-x border-slate-100 rounded-b-2xl p-3 shadow-sm flex items-center justify-between gap-4 transition-all duration-150">
		<div class="flex items-center gap-3 flex-grow">
			<div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-3 py-1.5 shadow-inner">
				<span class="text-xs text-slate-400">🔍</span>
				<input type="text" data-writing-editor-target="searchInput" data-action="input->writing-editor#performSearch" placeholder="Rechercher..." class="w-40 text-xs text-djoliba font-semibold focus:outline-none bg-transparent">
			</div>
			<div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-3 py-1.5 shadow-inner">
				<span class="text-xs text-slate-400">✏️</span>
				<input type="text" data-writing-editor-target="replaceInput" placeholder="Remplacer par..." class="w-40 text-xs text-djoliba font-semibold focus:outline-none bg-transparent">
			</div>
			<div class="flex items-center gap-1.5">
				<button type="button" data-action="click->writing-editor#prevMatch" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Précédent">
					↑
				</button>
				<button type="button" data-action="click->writing-editor#nextMatch" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Suivant">
					↓
				</button>
				<span data-writing-editor-target="searchIndexIndicator" class="text-[10px] text-slate-400 font-bold px-1">0/0</span>
			</div>
			<span class="w-[1px] h-4 bg-slate-200 mx-1"></span>
			<button type="button" data-action="click->writing-editor#replaceMatch" class="px-3 py-1.5 bg-white border border-slate-200 hover:bg-slate-100 text-djoliba text-xs font-bold rounded-xl transition-all shadow-sm">
				Remplacer
			</button>
			<button type="button" data-action="click->writing-editor#replaceAllMatches" class="px-3 py-1.5 bg-djoliba hover:opacity-90 text-white text-xs font-bold rounded-xl transition-all shadow-sm">
				Remplacer tout
			</button>
		</div>
		<button type="button" data-action="click->writing-editor#toggleSearchReplace" class="p-1.5 hover:bg-slate-200 rounded-full text-slate-400 hover:text-slate-600 transition-colors">
			<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
		</button>
	</div>

	<div class="flex flex-col {% if is_thesis|default(false) %}flex-grow min-h-0{% endif %} gap-3">
		{# 2. ZONE DE RÉDACTION HYBRIDE (SPLIT SCREEN AVEC PREVIEW) #}
		<div
			class="flex flex-row gap-6 items-stretch {% if is_thesis|default(false) %}flex-grow min-h-0 overflow-hidden{% endif %}">

		{# Panneau Table des matières (Outline) #}
		<div data-writing-editor-target="outlinePanel" class="hidden w-64 bg-slate-50 border border-slate-100 rounded-3xl p-5 overflow-y-auto flex flex-col gap-4 shadow-inner flex-shrink-0 transition-all duration-300">
			<div class="flex items-center justify-between border-b border-slate-200 pb-2">
				<h4 class="text-xs font-bold text-djoliba uppercase tracking-wider">Plan du document</h4>
				<button type="button" data-action="click->writing-editor#toggleOutline" class="p-1 hover:bg-slate-200 rounded-full text-slate-400 hover:text-slate-600 transition-colors">
					<svg class="w-3.5 h-3.5" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>
			<div data-writing-editor-target="outlineContent" class="space-y-2 text-xs">
				{# Rempli dynamiquement en JS #}
			</div>
		</div>

		{# Panneau d'Édition #}
		<div
			class="flex-1 min-w-0 bg-white rounded-3xl border border-slate-100 overflow-hidden shadow-sm flex flex-col transition-all {% if is_thesis|default(false) %}flex-grow min-h-0{% else %}min-h-[68vh]{% endif %}">
			{# Champ caché contenant le brouillon WYSIWYG indépendant #}
			<input
			type="hidden" data-writing-editor-target="wysiwygInput" value="{{ project.metadata.writing_content_wysiwyg|default(project.metadata.writing_content|default('')) }}">

			{# Conteneur TipTap WYSIWYG #}
			<div data-writing-editor-target="editorContainer" class="flex-grow bg-slate-50/30 overflow-hidden {% if is_thesis|default(false) %}min-h-0{% else %}min-h-[62vh]{% endif %}"></div>

			{# Textarea pour LaTeX brut / Markdown #}
			<textarea data-writing-editor-target="input" data-action="input->writing-editor#handleContentChange" class="hidden w-full flex-grow p-6 bg-slate-900 text-slate-100 font-mono text-xs focus:outline-none focus:ring-0 border-0 leading-relaxed resize-none custom-scrollbar {% if is_thesis|default(false) %}min-h-0{% else %}min-h-[62vh]{% endif %}" placeholder="{{ placeholder }}">{{ project.metadata.writing_content_latex|default(project.metadata.writing_content|default('')) }}</textarea>
		</div>

		{# Panneau de Prévisualisation Scientifique (Masqué par défaut, géré en Split) #}
		<div
			data-writing-editor-target="previewContainer" class="hidden flex-1 min-w-0 bg-slate-50 rounded-3xl border border-slate-200 p-6 flex flex-col overflow-y-auto custom-scrollbar shadow-inner prose prose-slate max-w-none font-sans {% if is_thesis|default(false) %}flex-grow min-h-0 max-h-none{% else %}min-h-[68vh] max-h-[72vh]{% endif %}">{# Rempli dynamiquement en direct par Marked + KaTeX #}
		</div>

		{# Panneau Commentaires & Annotations #}
		<div data-writing-editor-target="annotationPanel" class="hidden w-64 bg-slate-50 border border-slate-100 rounded-3xl p-5 overflow-y-auto flex flex-col gap-4 shadow-inner flex-shrink-0 transition-all duration-300">
			<div class="flex items-center justify-between border-b border-slate-200 pb-2">
				<h4 class="text-xs font-bold text-djoliba uppercase tracking-wider">Commentaires</h4>
				<button type="button" data-action="click->writing-editor#toggleAnnotationsPanel" class="p-1 hover:bg-slate-200 rounded-full text-slate-400 hover:text-slate-600 transition-colors">
					<svg class="w-3.5 h-3.5" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>
			<div data-writing-editor-target="annotationList" class="space-y-3">
				{# Rempli dynamiquement en JS #}
			</div>
			<div data-writing-editor-target="annotationEmptyMsg" class="hidden text-center py-8 text-slate-400 italic text-xs">
				Aucun commentaire dans ce document. Sélectionnez du texte pour en ajouter un.
			</div>
		</div>
	</div>

	{% if is_thesis|default(false) %}
	</div>
	{% endif %}

	{# 3. BARRE DE STATUT & COMPTEURS #}
	<div
		class="bg-white/95 backdrop-blur-sm px-8 py-1.5 flex flex-row items-center justify-between gap-4 flex-shrink-0 z-30 sticky bottom-0 border-t border-slate-200/80 shadow-lg {% if is_thesis|default(false) %}{% else %}-mx-8 -mb-8{% endif %}">

		{# Sauvegarde automatique #}
		<div class="flex items-center gap-2">
			<span data-writing-editor-target="status" data-thesis-editor-target="status" class="text-[11px] text-slate-400 italic font-medium flex items-center gap-1.5"></span>
		</div>

		{# Font Sizer et Compteurs de mots #}
		<div class="flex items-center gap-6 justify-end w-full sm:w-auto">
			{# Resizer #}
			<div class="flex items-center gap-1 bg-slate-50 border border-slate-100 p-0.5 rounded-lg shadow-inner">
				<button type="button" data-action="click->writing-editor#decreaseFontSize" class="w-6 h-6 rounded-md flex items-center justify-center text-[9px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Diminuer la police (A-)">
					A-
				</button>
				<span class="w-[1px] h-2.5 bg-slate-200"></span>
				<button type="button" data-action="click->writing-editor#increaseFontSize" class="w-6 h-6 rounded-md flex items-center justify-center text-[9px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Agrandir la police (A+)">
					A+
				</button>
			</div>

			{# Compteurs #}
			<div class="flex items-center gap-4 text-[11px] font-semibold text-slate-500">
				<div class="flex items-center gap-1">
					<span data-writing-editor-target="wordCount" class="text-djoliba font-bold">0</span>
					<span class="text-[9px] text-slate-400 font-medium">mots</span>
				</div>
				<span class="w-1 h-1 bg-slate-300 rounded-full"></span>
				<div class="flex items-center gap-1">
					<span data-writing-editor-target="charCount" class="text-djoliba font-bold">0</span>
					<span class="text-[9px] text-slate-400 font-medium">caractères</span>
				</div>
				<span class="w-1 h-1 bg-slate-300 rounded-full"></span>
				<div class="flex items-center gap-1">
					<span data-writing-editor-target="pageCount" class="text-djoliba font-bold">1</span>
					<span class="text-[9px] text-slate-400 font-medium">pages</span>
				</div>
				<span class="w-[1px] h-3 bg-slate-200"></span>
				<button type="button" data-action="click->writing-editor#openReadabilityModal" class="flex items-center gap-1.5 hover:text-djoliba text-[11px] text-slate-500 font-bold transition-all" title="Statistiques de lisibilité et style">
					<span>Lisibilité :</span>
					<span data-writing-editor-target="readabilityBadge" class="px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-600 font-bold text-[9px] uppercase tracking-wider">Calcul...</span>
				</button>
			</div>
		</div>
	</div>
	</div>

	{# 4. OUTILS D'IA (Vérification et boutons additionnels si non Thèse) #}
	{% if not is_thesis|default(false) %}
		<div class="flex flex-col sm:flex-row items-center gap-4 pt-2 w-full">
			<button type="button" data-writing-editor-target="checkBtn" data-action="click->writing-editor#checkOriginality" class="w-full sm:w-auto px-6 py-4.5 bg-djoliba text-white text-xs font-bold rounded-2xl hover:opacity-90 shadow-md shadow-djoliba/10 transition-all flex items-center justify-center gap-2">
				<svg class="w-4 h-4 text-emerald_ia" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
				Vérifier l'originalité (Plagiat IA)
			</button>

			<button type="button" data-writing-editor-target="suggestBtn" data-action="click->writing-editor#suggestJournal" class="w-full sm:w-auto px-6 py-4.5 bg-white border border-slate-200 text-djoliba text-xs font-bold rounded-2xl hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
				<svg class="w-4 h-4 text-gold_prestige" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
				Suggérer des revues cibles
			</button>
		</div>
	{% endif %}

	{# Inclusion de l'ensemble des modales et fenêtres volantes #}
	{{ include('project/partials/_writing_editor_modals.html.twig') }}

</div>
