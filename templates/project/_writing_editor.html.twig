{# templates/project/_writing_editor.html.twig #}
{#
  Composant d'Édition Scientifique Réutilisable (Djoliba Rich Editor)
  
  Paramètres requis :
  - project : Entité Project associée
  
  Paramètres optionnels :
  - save_url : Endpoint de sauvegarde auto (default: /api/projects/{id}/content)
  - export_url : Endpoint de téléchargement LaTeX (default: /api/export/latex)
  - placeholder : Texte d'invite de l'éditeur
  - storage_key : Clé LocalStorage de sauvegarde locale
#}

{% set save_url = save_url|default(path('api_project_save_content', {id: project.id})) %}
{% set export_url = export_url|default(path('api_editor_export_latex')) %}
{% set placeholder = placeholder|default('Rédigez votre article ou thèse ici. Le Markdown et le LaTeX sont supportés...') %}
{% set storage_key = storage_key|default('djoliba_draft_' ~ project.id) %}

	<div
	data-controller="writing-editor" data-writing-editor-project-id-value="{{ project.id }}" data-writing-editor-save-url-value="{{ save_url }}" data-writing-editor-export-url-value="{{ export_url }}" data-writing-editor-placeholder-value="{{ placeholder }}" data-writing-editor-storage-key-value="{{ storage_key }}" data-writing-editor-initial-mode-value="{{ project.metadata.writing_mode|default('wysiwyg') }}" class="{% if is_thesis|default(false) %}flex-grow flex flex-col min-h-0 overflow-hidden space-y-4{% else %}space-y-6{% endif %}"> {# 1. BARRE D'OUTILS PRINCIPALE #}
	<div
		class="bg-white rounded-2xl border border-slate-100 p-4 shadow-sm flex flex-col md:flex-row gap-4 items-center justify-between">

		{# Groupe Gauche : Onglets / Bascule de Mode #}
		<div class="flex items-center gap-2 bg-slate-50 border border-slate-100 p-1 rounded-xl shadow-inner w-full md:w-auto">
			<button type="button" data-writing-editor-target="modeWysiwygBtn" data-action="click->writing-editor#setWysiwygMode" class="flex-1 md:flex-none px-4 py-2 text-xs font-bold rounded-lg flex items-center justify-center gap-2 transition-all hover:bg-white hover:shadow-sm" title="Basculez sur l'éditeur visuel (WYSIWYG)">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
				</svg>
				Visuel (WYSIWYG)
			</button>
			<button type="button" data-writing-editor-target="modeLatexBtn" data-action="click->writing-editor#setLatexMode" class="flex-1 md:flex-none px-4 py-2 text-xs font-bold rounded-lg flex items-center justify-center gap-2 transition-all hover:bg-white hover:shadow-sm" title="Basculez sur l'éditeur LaTeX brut / Markdown">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
				</svg>
				LaTeX brut
			</button>
		</div>

		{# Groupe Milieu : Actions de Formatage (Uniquement WYSIWYG) #}
		<div class="flex items-center gap-1 bg-slate-50 border border-slate-100 p-1 rounded-xl shadow-inner overflow-x-auto w-full md:w-auto" data-writing-editor-target="wysiwygToolbar">

			<button type="button" data-action="click->writing-editor#toggleBold" class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Gras (Ctrl+B)">
				G
			</button>
			<button type="button" data-action="click->writing-editor#toggleItalic" class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-serif italic text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Italique (Ctrl+I)">
				I
			</button>
			<span class="w-[1px] h-4 bg-slate-200 mx-1"></span>
			<button type="button" data-action="click->writing-editor#toggleHeading" data-level="1" class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Titre principal">
				H1
			</button>
			<button type="button" data-action="click->writing-editor#toggleHeading" data-level="2" class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Sous-titre">
				H2
			</button>
			<button type="button" data-action="click->writing-editor#toggleHeading" data-level="3" class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Titre 3">
				H3
			</button>
			<span class="w-[1px] h-4 bg-slate-200 mx-1"></span>
			<button type="button" data-action="click->writing-editor#toggleBulletList" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Liste à puces">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
			</button>
			<button type="button" data-action="click->writing-editor#toggleOrderedList" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Liste ordonnée">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
			</button>
			<button type="button" data-action="click->writing-editor#toggleCodeBlock" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Bloc de code">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
			</button>
			<span class="w-[1px] h-4 bg-slate-200 mx-1"></span>
			<button type="button" data-action="click->writing-editor#insertTableModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Insérer un tableau">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
			</button>
			<button type="button" data-action="click->writing-editor#insertFigureModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Insérer une figure légendée">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
			</button>
			<button type="button" data-action="click->writing-editor#insertFootnoteModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all flex-shrink-0" title="Insérer une note de bas de page">
				<span class="text-xs font-bold leading-none">N<sup>1</sup></span>
			</button>
			<button type="button" data-action="click->writing-editor#insertReferenceModal" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Insérer une référence croisée">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
			</button>
		</div>

		{# Groupe Droite : Outils de Publication & Document #}
		<div
			class="flex items-center gap-2 w-full md:w-auto justify-end">
			{# Aperçu en direct (Split screen) #}
			<button type="button" data-writing-editor-target="previewBtn" data-action="click->writing-editor#togglePreview" class="px-3.5 py-2 bg-slate-50 border border-slate-200 hover:bg-slate-100 text-djoliba text-xs font-bold rounded-xl flex items-center gap-1.5 transition-all shadow-sm" title="Activer la prévisualisation scientifique LaTeX (KaTeX) à côté de l'éditeur">
				<svg class="w-4 h-4 text-djoliba" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
				</svg>
				Prévisualiser
			</button>

			{# Aperçu de Rendu LaTeX Interprété (Modal) #}
			<button type="button" data-writing-editor-target="renderBtn" data-action="click->writing-editor#showLatexPreview" class="px-3.5 py-2 bg-emerald-50 border border-emerald-200 hover:bg-emerald-100/70 text-emerald-600 text-xs font-bold rounded-xl flex items-center gap-1.5 transition-all shadow-sm hidden" title="Afficher un aperçu interprété de votre LaTeX en modal">
				<svg class="w-4 h-4 text-emerald-600 animate-pulse" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
				</svg>
				Aperçu Rendu
			</button>

			{# Importer #}
			<button type="button" data-action="click->writing-editor#triggerFileInput" data-writing-editor-target="importBtn" class="px-3.5 py-2 bg-slate-50 border border-slate-200 hover:bg-slate-100 text-djoliba text-xs font-bold rounded-xl flex items-center gap-1.5 transition-all shadow-sm" title="Importer un fichier (DOCX ou LaTeX)">
				<svg class="w-4 h-4 text-djoliba" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
				</svg>
				Importer
			</button>
			<input
			type="file" accept=".docx,.tex" data-writing-editor-target="fileInput" data-action="change->writing-editor#handleFileSelect" class="hidden">

			{# Exporter en LaTeX #}
			<button type="button" data-action="click->writing-editor#exportLatex" class="px-3.5 py-2 bg-gold_prestige/10 border border-gold_prestige/20 hover:bg-gold_prestige/20 text-gold_prestige text-xs font-bold rounded-xl flex items-center gap-1.5 transition-all shadow-sm" title="Télécharger votre manuscrit au format LaTeX (.tex) compilé">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
				</svg>
				Exporter (.tex)
			</button>

			{# Aide / Guide d'utilisation #}
			<button type="button" data-action="click->writing-editor#openHelpModal" class="w-9 h-9 bg-slate-50 border border-slate-200 hover:bg-slate-100 text-slate-500 hover:text-djoliba text-xs font-bold rounded-xl flex items-center justify-center transition-all shadow-sm" title="Guide d'utilisation de l'éditeur scientifique">
				<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
				</svg>
			</button>
		</div>
	</div>

	{# 2. ZONE DE RÉDACTION HYBRIDE (SPLIT SCREEN AVEC PREVIEW) #}
	<div
		class="flex flex-row gap-6 items-stretch {% if is_thesis|default(false) %}flex-grow min-h-0 overflow-hidden{% endif %}">

		{# Panneau d'Édition #}
		<div
			class="flex-1 min-w-0 bg-white rounded-3xl border border-slate-100 overflow-hidden shadow-sm flex flex-col transition-all {% if is_thesis|default(false) %}flex-grow min-h-0{% else %}min-h-[520px]{% endif %}">
			{# Champ caché contenant le brouillon WYSIWYG indépendant #}
			<input
			type="hidden" data-writing-editor-target="wysiwygInput" value="{{ project.metadata.writing_content_wysiwyg|default(project.metadata.writing_content|default('')) }}">

			{# Conteneur TipTap WYSIWYG #}
			<div data-writing-editor-target="editorContainer" class="flex-grow bg-slate-50/30 overflow-y-auto custom-scrollbar {% if is_thesis|default(false) %}min-h-0{% else %}min-h-[480px]{% endif %}"></div>

			{# Textarea pour LaTeX brut / Markdown #}
			<textarea data-writing-editor-target="input" data-action="input->writing-editor#handleContentChange" class="hidden w-full flex-grow p-6 bg-slate-900 text-slate-100 font-mono text-xs focus:outline-none focus:ring-0 border-0 leading-relaxed resize-none custom-scrollbar {% if is_thesis|default(false) %}min-h-0{% else %}min-h-[480px]{% endif %}" placeholder="{{ placeholder }}">{{ project.metadata.writing_content_latex|default(project.metadata.writing_content|default('')) }}</textarea>
		</div>

		{# Panneau de Prévisualisation Scientifique (Masqué par défaut, géré en Split) #}
		<div
			data-writing-editor-target="previewContainer" class="hidden flex-1 min-w-0 bg-slate-50 rounded-3xl border border-slate-200 p-6 flex flex-col overflow-y-auto custom-scrollbar shadow-inner prose prose-slate max-w-none font-sans {% if is_thesis|default(false) %}flex-grow min-h-0 max-h-none{% else %}min-h-[520px] max-h-[560px]{% endif %}">{# Rempli dynamiquement en direct par Marked + KaTeX #}
		</div>
	</div>

	{# 3. BARRE DE STATUT & COMPTEURS #}
	<div
		class="bg-white px-6 py-3.5 flex flex-col sm:flex-row items-center justify-between gap-4 flex-shrink-0">

		{# Sauvegarde automatique #}
		<div class="flex items-center gap-2">
			<span data-writing-editor-target="status" class="text-[11px] text-slate-400 italic font-medium flex items-center gap-1.5"></span>
		</div>

		{# Font Sizer et Compteurs de mots #}
		<div
			class="flex items-center gap-6 justify-end w-full sm:w-auto">
			{# Resizer #}
			<div class="flex items-center gap-1 bg-slate-50 border border-slate-100 p-1 rounded-xl shadow-inner">
				<button type="button" data-action="click->writing-editor#decreaseFontSize" class="w-7 h-7 rounded-lg flex items-center justify-center text-[10px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Diminuer la police (A-)">
					A-
				</button>
				<span class="w-[1px] h-3 bg-slate-200"></span>
				<button type="button" data-action="click->writing-editor#increaseFontSize" class="w-7 h-7 rounded-lg flex items-center justify-center text-[10px] font-bold text-slate-500 hover:text-djoliba hover:bg-white border border-transparent hover:border-slate-100 hover:shadow-sm transition-all" title="Agrandir la police (A+)">
					A+
				</button>
			</div>

			{# Compteurs #}
			<div class="flex items-center gap-4 text-xs font-semibold text-slate-500">
				<div class="flex items-center gap-1">
					<span data-writing-editor-target="wordCount" class="text-djoliba font-bold">0</span>
					<span class="text-[10px] text-slate-400 font-medium">mots</span>
				</div>
				<span class="w-1 h-1 bg-slate-300 rounded-full"></span>
				<div class="flex items-center gap-1">
					<span data-writing-editor-target="charCount" class="text-djoliba font-bold">0</span>
					<span class="text-[10px] text-slate-400 font-medium">caractères</span>
				</div>
				<span class="w-1 h-1 bg-slate-300 rounded-full"></span>
				<div class="flex items-center gap-1">
					<span data-writing-editor-target="pageCount" class="text-djoliba font-bold">1</span>
					<span class="text-[10px] text-slate-400 font-medium">pages</span>
				</div>
			</div>
		</div>
	</div>

	{# 4. OUTILS D'IA (Vérification et boutons additionnels si non Thèse) #}
	{% if not is_thesis|default(false) %}
		<div class="flex flex-col sm:flex-row items-center gap-4 pt-2 w-full">
			<button type="button" data-writing-editor-target="checkBtn" data-action="click->writing-editor#checkOriginality" class="w-full sm:w-auto px-6 py-4.5 bg-djoliba text-white text-xs font-bold rounded-2xl hover:opacity-90 shadow-md shadow-djoliba/10 transition-all flex items-center justify-center gap-2">
				<svg class="w-4 h-4 text-emerald_ia" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
				Vérifier l'originalité (Plagiat IA)
			</button>

			<button type="button" data-writing-editor-target="suggestBtn" data-action="click->writing-editor#suggestJournal" class="w-full sm:w-auto px-6 py-4.5 bg-white border border-slate-200 text-djoliba text-xs font-bold rounded-2xl hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
				<svg class="w-4 h-4 text-gold_prestige" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
				Suggérer des revues cibles
			</button>
		</div>
	{% endif %}

	{# ───────────────────────────────────────────── #}
	{# MODAL 1 : RÉSULTATS DE L'ORIGINALITÉ           #}
	{# ───────────────────────────────────────────── #}
		<div data-writing-editor-target="originalityModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/40 backdrop-blur-sm transition-all duration-300 opacity-0 hidden" role="dialog" aria-modal="true"> <div class="modal-card bg-white w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden border border-slate-100/80 transform scale-95 opacity-0 transition-all duration-300 ease-out flex flex-col max-h-[85vh]">
			<div class="px-8 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
				<div class="flex items-center gap-3">
					<div class="w-8 h-8 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500">
						<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
					</div>
					<div>
						<h3 class="text-sm font-bold text-djoliba">Rapport d'Originalité IA</h3>
						<p class="text-[10px] text-slate-400">Analyse de plagiat & suggestions de reformulation</p>
					</div>
				</div>
				<button type="button" data-action="click->writing-editor#closeOriginalityModal" class="p-2 hover:bg-slate-100 rounded-full text-slate-400 hover:text-slate-600 transition-colors">
					<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>

			<div
				data-writing-editor-target="originalityContent" class="p-8 overflow-y-auto custom-scrollbar flex-grow">{# Rempli dynamiquement en JS #}
			</div>

			<div class="px-8 py-4 border-t border-slate-50 flex justify-end bg-slate-50/20">
				<button type="button" data-action="click->writing-editor#closeOriginalityModal" class="px-5 py-2.5 bg-slate-100 text-slate-600 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">
					Fermer le rapport
				</button>
			</div>
		</div>
	</div>

	{# ───────────────────────────────────────────── #}
