	{# MODALE DE LISIBILITÉ #}
	<div data-writing-editor-target="readabilityModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/40 backdrop-blur-sm transition-all duration-300 opacity-0 hidden" role="dialog" aria-modal="true">
		<div class="modal-card bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden border border-slate-100/80 transform scale-95 opacity-0 transition-all duration-300 ease-out flex flex-col">
			<div class="px-8 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
				<div class="flex items-center gap-3">
					<div class="w-8 h-8 rounded-full bg-djoliba/10 flex items-center justify-center text-djoliba text-base">
						📊
					</div>
					<div>
						<h3 class="text-sm font-bold text-djoliba">Analyse de Lisibilité</h3>
						<p class="text-[10px] text-slate-400">Statistiques de lisibilité et suggestions de style</p>
					</div>
				</div>
				<button type="button" data-action="click->writing-editor#closeReadabilityModal" class="p-2 hover:bg-slate-100 rounded-full text-slate-400 hover:text-slate-600 transition-colors">
					<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>

			<div class="p-8 space-y-6">
				{# Score Flesch #}
				<div class="flex items-center justify-between p-4 bg-slate-50 border border-slate-100 rounded-2xl">
					<div>
						<span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Score Flesch (Français)</span>
						<span data-writing-editor-target="readabilityFleschAppreciation" class="text-xs font-bold text-slate-600">Calcul...</span>
					</div>
					<div data-writing-editor-target="readabilityFleschScore" class="text-2xl font-black text-djoliba">-</div>
