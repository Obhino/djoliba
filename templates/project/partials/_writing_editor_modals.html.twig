				<button type="button" data-action="click->writing-editor#closeAnnotationModal" class="p-2 hover:bg-slate-100 rounded-full text-slate-400 hover:text-slate-600 transition-colors">
					<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>
			<div class="p-8 space-y-4">
				<div>
					<label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Sélection</label>
					<div data-writing-editor-target="annotationSelectedText" class="p-3 bg-slate-50 border border-slate-100 text-xs text-slate-600 italic rounded-xl max-h-24 overflow-y-auto line-clamp-3"></div>
				</div>
				<div>
					<label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Votre note / commentaire</label>
