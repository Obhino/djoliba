			</div>

			<div class="px-8 py-4 border-t border-slate-50 flex justify-end bg-slate-50/20">
				<button type="button" data-action="click->writing-editor#closeSnapshotModal" class="px-5 py-2.5 bg-slate-100 text-slate-600 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">
					Fermer
				</button>
			</div>
	</div>

	{# MODALE D'INSERTION DE COMMENTAIRE / ANNOTATION #}
	<div data-writing-editor-target="annotationModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/40 backdrop-blur-sm transition-all duration-300 opacity-0 hidden" role="dialog" aria-modal="true">
		<div class="modal-card bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden border border-slate-100/80 transform scale-95 opacity-0 transition-all duration-300 ease-out flex flex-col">
			<div class="px-8 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
				<div class="flex items-center gap-3">
					<div class="w-8 h-8 rounded-full bg-djoliba/10 flex items-center justify-center text-djoliba text-base">
