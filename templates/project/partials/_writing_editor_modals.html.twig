					<div class="flex gap-2">
						<input type="text" data-writing-editor-target="snapshotNameInput" placeholder="Ex: Version finale avant soumission..." class="flex-grow px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-xs text-djoliba font-semibold bg-white">
						<button type="button" data-action="click->writing-editor#createSnapshot" class="px-5 py-2.5 bg-djoliba hover:opacity-90 text-white text-xs font-bold rounded-xl transition-all shadow-md shadow-djoliba/10 whitespace-nowrap">
							Sauvegarder
						</button>
					</div>
				</div>

				{# Section 2 : Liste des versions #}
				<div class="space-y-3">
					<h4 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Versions sauvegardées</h4>
					<div data-writing-editor-target="snapshotList" class="space-y-3">
						{# Rempli dynamiquement en JS #}
					</div>
					<div data-writing-editor-target="snapshotEmptyMsg" class="hidden text-center py-8 text-slate-400 italic text-xs">
