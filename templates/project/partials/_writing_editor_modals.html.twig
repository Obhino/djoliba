					<div class="w-8 h-8 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500 animate-bounce">
						<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
						</svg>
					</div>
					<div>
						<h3 class="text-sm font-bold text-djoliba">Aperçu du Rendu Interprété (LaTeX / Markdown)</h3>
						<p class="text-[10px] text-slate-400">Rendu de mise en page haute fidélité avec compilation mathématique</p>
					</div>
				</div>
				<button type="button" data-action="click->writing-editor#closeLatexPreviewModal" class="p-2 hover:bg-slate-100 rounded-full text-slate-400 hover:text-slate-600 transition-colors">
					<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>

			<div class="p-6 bg-slate-50 overflow-y-auto custom-scrollbar flex-grow" style="max-height: 480px;">
				<div
					data-writing-editor-target="latexPreviewContent" class="w-full p-8 bg-white border border-slate-200 rounded-2xl shadow-sm min-h-[300px] overflow-y-auto custom-scrollbar prose prose-slate max-w-none font-sans leading-relaxed text-xs">{# Rempli dynamiquement en JS #}
				</div>
			</div>

			<div class="px-8 py-4 border-t border-slate-100 flex justify-end bg-slate-50/20">
				<button type="button" data-action="click->writing-editor#closeLatexPreviewModal" class="px-5 py-2.5 bg-djoliba text-white text-xs font-bold rounded-xl hover:opacity-90 transition-all shadow-md shadow-djoliba/10">
					Fermer l'aperçu
				</button>
			</div>
		</div>
	</div>

	{# ───────────────────────────────────────────── #}
	{# MODAL 6 : INSERTION DE TABLEAU                #}
	{# ───────────────────────────────────────────── #}
	<div data-writing-editor-target="tableModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/40 backdrop-blur-sm transition-all duration-300 opacity-0 hidden" role="dialog" aria-modal="true">
		<div class="modal-card bg-white w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden border border-slate-100/80 transform scale-95 opacity-0 transition-all duration-300 ease-out flex flex-col">
			<div class="px-8 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
				<div class="flex items-center gap-3">
					<div class="w-8 h-8 rounded-full bg-djoliba/10 flex items-center justify-center text-djoliba">
						<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
					</div>
					<h3 class="text-sm font-bold text-djoliba">Éditeur de Tableau Scientifique</h3>
				</div>
				<button type="button" data-action="click->writing-editor#closeTableModal" class="p-2 hover:bg-slate-100 rounded-full text-slate-400 hover:text-slate-600 transition-colors">
					<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>
			<div class="p-8 space-y-4">
				<div class="grid grid-cols-2 gap-4">
					<div>
						<label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Titre du Tableau</label>
						<input type="text" data-writing-editor-target="tableCaptionInput" placeholder="Ex: Résultats d'analyse" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-xs text-djoliba font-semibold bg-slate-50/50">
					</div>
					<div>
						<label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Label LaTeX (Optionnel)</label>
						<input type="text" data-writing-editor-target="tableLabelInput" placeholder="Ex: tab:resultats" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-xs text-djoliba font-semibold bg-slate-50/50">
					</div>
				</div>
				
				<div class="border border-slate-100 rounded-2xl p-4 bg-slate-50/30">
					<div class="flex items-center justify-between mb-3">
						<span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Édition des données de la grille</span>
						<div class="flex gap-2">
