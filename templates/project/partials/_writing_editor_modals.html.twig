				</div>
			</div>
			<div class="px-8 py-4 border-t border-slate-50 flex justify-end gap-3 bg-slate-50/20">
				<button type="button" data-action="click->writing-editor#closeAnnotationModal" class="px-5 py-2.5 bg-slate-100 text-slate-600 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">Annuler</button>
				<button type="button" data-action="click->writing-editor#confirmInsertAnnotation" class="px-5 py-2.5 bg-djoliba text-white text-xs font-bold rounded-xl hover:opacity-90 shadow-md shadow-djoliba/10 transition-all">Enregistrer</button>
			</div>
		</div>
