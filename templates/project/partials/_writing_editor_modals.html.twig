				<button type="button" data-action="click->writing-editor#confirmInsertMath" class="px-5 py-2.5 bg-djoliba text-white text-xs font-bold rounded-xl hover:opacity-90 shadow-md shadow-djoliba/10 transition-all">Insérer</button>
			</div>
		</div>
