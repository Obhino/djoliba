{% extends 'base.html.twig' %}

{% block title %}{{ research_project.title }} - Djoliba{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8" data-controller="research-project-page">
    
    <!-- Messages Flash -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="p-4 rounded-xl border {{ label == 'success' ? 'bg-emerald-50 border-emerald-200 text-emerald-800' : 'bg-rose-50 border-rose-200 text-rose-800' }} flex items-center justify-between">
                <span class="text-sm font-semibold">{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- En-tête (Header) -->
    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div class="space-y-2 max-w-2xl">
            <div class="flex items-center gap-3">
                <span class="text-3xl">🔬</span>
                <h1 class="text-3xl font-display font-bold text-djoliba">{{ research_project.title }}</h1>
                <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider {{ research_project.status == 'active' ? 'bg-emerald-500/10 text-emerald-700 border border-emerald-500/20' : 'bg-slate-100 text-slate-600' }}">
                    {{ research_project.status == 'active' ? 'Actif' : 'Archivé' }}
                </span>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed">{{ research_project.description ?: 'Aucune description fournie pour ce projet.' }}</p>
            <div class="text-xs text-slate-400 font-medium">Créé le {{ research_project.createdAt|date('d/m/Y à H:i') }}</div>
        </div>

        <div class="flex flex-wrap gap-3">
            <form action="{{ path('app_research_project_toggle_status', {id: research_project.id}) }}" method="POST">
                <button type="submit" class="px-5 py-2.5 rounded-xl border border-slate-200 hover:bg-slate-50 text-slate-600 font-bold text-xs transition-all flex items-center gap-2">
                    {% if research_project.status == 'active' %}
                        📦 Archiver le projet
                    {% else %}
                        🎯 Activer le projet
                    {% endif %}
                </button>
            </form>
            
            <a href="{{ path('app_research_project_export_zip', {id: research_project.id}) }}" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/95 text-white font-bold text-xs shadow-lg shadow-djoliba/25 transition-all flex items-center gap-2">
                📥 Exporter le projet (ZIP)
            </a>
        </div>
    </div>

    <!-- Statistiques (Grid) -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Total</span>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.total }}</span>
                <span class="text-xs text-slate-400">activités</span>
            </div>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
                <span class="text-base">📖</span>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Lectures</span>
            </div>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.reading }}</span>
            </div>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
                <span class="text-base">📚</span>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Synthèses</span>
            </div>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.literature }}</span>
            </div>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
                <span class="text-base">✍️</span>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Écritures</span>
            </div>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.writing }}</span>
            </div>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
                <span class="text-base">🎓</span>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Thèses</span>
            </div>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.thesis }}</span>
            </div>
        </div>
    </div>

    <!-- Section Sous-projets -->
    <div class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center">
            <div>
                <h2 class="text-xl font-display font-bold text-djoliba">Sous-projets</h2>
                <p class="text-xs text-slate-400 mt-1">Gérez les activités liées à ce projet de recherche.</p>
            </div>
            <button type="button" data-action="click->research-project-page#openCreateModal" class="px-4 py-2 rounded-xl bg-slate-50 border border-slate-200 hover:bg-slate-100 hover:text-djoliba text-slate-600 font-bold text-xs transition-all flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Ajouter un sous-projet
            </button>
        </div>

        <div class="divide-y divide-slate-100">
            {% for sp in sub_projects %}
                <div class="px-8 py-5 flex items-center justify-between hover:bg-slate-50/50 transition-colors">
                    <div class="flex items-center gap-4 min-w-0">
                        <div class="w-10 h-10 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center text-lg flex-shrink-0">
                            {% if sp.type == 'reading' %}📖
                            {% elseif sp.type == 'literature' %}📚
                            {% elseif sp.type == 'writing' %}✍️
                            {% elseif sp.type == 'thesis' %}🎓
                            {% endif %}
                        </div>
                        <div class="min-w-0">
                            <h3 class="font-semibold text-sm text-slate-800 truncate">{{ sp.name }}</h3>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">
                                    {% if sp.type == 'reading' %}Lecture
                                    {% elseif sp.type == 'literature' %}Synthèse
                                    {% elseif sp.type == 'writing' %}Écriture
                                    {% elseif sp.type == 'thesis' %}Thèse
                                    {% endif %}
                                </span>
                                <span class="w-1 h-1 rounded-full bg-slate-200"></span>
                                <span class="text-[10px] text-slate-400">Créé le {{ sp.createdAt|date('d/m/Y') }}</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-6">
                        <span class="subproject-status px-2.5 py-0.5 rounded-full text-[10px] font-bold {{ sp.status == 'active' ? 'bg-emerald-500/10 text-emerald-700' : 'bg-slate-100 text-slate-600' }}">
                            {{ sp.status == 'active' ? 'Actif' : 'Archivé' }}
                        </span>

                        <div class="flex items-center gap-1">
                            <!-- Action Activer/Désactiver -->
                            <form action="{{ path('app_subproject_toggle_status', {id: sp.id}) }}" method="POST" title="Changer le statut">
                                <button type="submit" class="p-2 text-slate-400 hover:text-djoliba hover:bg-slate-100 rounded-lg transition-colors">
                                    🔄
                                </button>
                            </form>
                            
                            <!-- Action Modifier (Renommer) -->
                            <button type="button" data-action="click->research-project-page#openEditModal" data-sp-id="{{ sp.id }}" data-sp-name="{{ sp.name }}" class="p-2 text-slate-400 hover:text-djoliba hover:bg-slate-100 rounded-lg transition-colors" title="Renommer">
                                ✏️
                            </button>

                            <!-- Action Supprimer -->
                            <form action="{{ path('app_subproject_delete', {id: sp.id}) }}" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce sous-projet définitivement ?');" title="Supprimer">
                                <button type="submit" class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors">
                                    🗑️
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="px-8 py-16 text-center">
                    <span class="text-4xl">📁</span>
                    <h3 class="font-bold text-slate-700 mt-4">Aucun sous-projet pour l'instant</h3>
                    <p class="text-sm text-slate-400 mt-1 max-w-sm mx-auto">Créez votre première activité (lecture, synthèse, écriture, thèse) associée à ce projet de recherche.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    <!-- Modale de Création de Sous-projet -->
    <div data-research-project-page-target="createModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
        <div data-action="click->research-project-page#closeCreateModal" class="absolute inset-0 cursor-default"></div>
        <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-md z-10 transform scale-95 opacity-0 transition-all duration-300">
            <button type="button" data-action="click->research-project-page#closeCreateModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            <div class="mb-6">
                <h3 class="text-2xl font-display font-bold text-djoliba">Ajouter un sous-projet</h3>
                <p class="text-sm text-slate-400 mt-1">Créez une nouvelle activité rattachée à ce projet de recherche.</p>
            </div>
            <form action="{{ path('app_research_project_subproject_create', {id: research_project.id}) }}" method="POST" class="space-y-6">
                <div>
                    <label for="sp-name" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nom de l'activité</label>
                    <input id="sp-name" name="name" type="text" required placeholder="Ex: Revue de littérature sur le sahel" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300">
                </div>
                <div>
                    <label for="sp-type" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Type d'activité</label>
                    <select id="sp-type" name="type" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold">
                        <option value="reading">📖 Projet de lecture</option>
                        <option value="literature">📚 Projet de synthèse</option>
                        <option value="writing">✍️ Projet d'écriture</option>
                        <option value="thesis">🎓 Thèse / Mémoire</option>
                    </select>
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->research-project-page#closeCreateModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Créer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modale d'Édition (Renommer) -->
    <div data-research-project-page-target="editModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
        <div data-action="click->research-project-page#closeEditModal" class="absolute inset-0 cursor-default"></div>
        <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-md z-10 transform scale-95 opacity-0 transition-all duration-300">
            <button type="button" data-action="click->research-project-page#closeEditModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            <div class="mb-6">
                <h3 class="text-2xl font-display font-bold text-djoliba">Renommer l'activité</h3>
                <p class="text-sm text-slate-400 mt-1">Donnez un nouveau nom à votre sous-projet.</p>
            </div>
            <form id="edit-sp-form" action="" method="POST" class="space-y-6">
                <div>
                    <label for="edit-sp-name" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nom du sous-projet</label>
                    <input id="edit-sp-name" name="name" type="text" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300">
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->research-project-page#closeEditModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
