{% extends 'base.html.twig' %}

{% block title %}{{ research_project.title }} - Djoliba{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8" data-controller="research-project-page">
    
    <!-- Messages Flash -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="p-4 rounded-xl border {{ label == 'success' ? 'bg-emerald-50 border-emerald-200 text-emerald-800' : 'bg-rose-50 border-rose-200 text-rose-800' }} flex items-center justify-between">
                <span class="text-sm font-semibold">{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- En-tête (Header) -->
    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div class="space-y-2 max-w-2xl">
            <div class="flex items-center gap-3">
                <span class="text-3xl">🔬</span>
                <h1 class="text-3xl font-display font-bold text-djoliba">{{ research_project.title }}</h1>
                <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider {{ research_project.status == 'active' ? 'bg-emerald-500/10 text-emerald-700 border border-emerald-500/20' : 'bg-slate-100 text-slate-600' }}">
                    {{ research_project.status == 'active' ? 'Actif' : 'Archivé' }}
                </span>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed">{{ research_project.description ?: 'Aucune description fournie pour ce projet.' }}</p>
            <div class="text-xs text-slate-400 font-medium">Créé le {{ research_project.createdAt|date('d/m/Y à H:i') }}</div>
        </div>

        <div class="flex flex-wrap gap-3">
            <form action="{{ path('app_research_project_toggle_status', {id: research_project.id}) }}" method="POST">
                <button type="submit" class="px-5 py-2.5 rounded-xl border border-slate-200 hover:bg-slate-50 text-slate-600 font-bold text-xs transition-all flex items-center gap-2">
                    {% if research_project.status == 'active' %}
                        📦 Archiver le projet
                    {% else %}
                        🎯 Activer le projet
                    {% endif %}
                </button>
            </form>
            
            <a href="{{ path('app_research_project_export_zip', {id: research_project.id}) }}" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/95 text-white font-bold text-xs shadow-lg shadow-djoliba/25 transition-all flex items-center gap-2">
                📥 Exporter le projet (ZIP)
            </a>
        </div>
    </div>

    <!-- Synthèse & Plan de Réalisation -->
    {% if research_project.synthesis %}
    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm space-y-4" data-controller="project-synthesis" data-project-synthesis-content-value="{{ research_project.synthesis }}">
        <div class="flex items-center justify-between cursor-pointer" data-action="click->project-synthesis#toggle">
            <div class="flex items-center gap-3">
                <span class="text-2xl">📋</span>
                <h2 class="text-xl font-display font-bold text-djoliba">Synthèse & Plan de Réalisation du Projet</h2>
            </div>
            <button class="p-2 text-slate-400 hover:text-djoliba rounded-lg hover:bg-slate-50 transition-colors font-bold text-xs" data-project-synthesis-target="toggleBtn">
                ▼ Afficher
            </button>
        </div>
        <div class="transition-all duration-300 hidden border-t border-slate-100 pt-6 prose prose-slate max-w-none text-slate-600 text-sm leading-relaxed" data-project-synthesis-target="container">
            <!-- Contenu rendu par le contrôleur Stimulus -->
        </div>
    </div>
    {% endif %}

    <!-- Statistiques (Grid) -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Total</span>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.total }}</span>
                <span class="text-xs text-slate-400">activités</span>
            </div>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
                <span class="text-base">📖</span>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Lectures</span>
            </div>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.reading }}</span>
            </div>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
                <span class="text-base">📚</span>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Synthèses</span>
            </div>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.literature }}</span>
            </div>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
                <span class="text-base">✍️</span>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Écritures</span>
            </div>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.writing }}</span>
            </div>
        </div>
        <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
                <span class="text-base">🎓</span>
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Thèses</span>
            </div>
            <div class="flex items-baseline gap-2 mt-4">
                <span class="text-3xl font-bold text-djoliba">{{ stats.thesis }}</span>
            </div>
        </div>
    </div>

    <!-- Section Sous-projets -->
    <div class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center">
            <div>
                <h2 class="text-xl font-display font-bold text-djoliba">Sous-projets</h2>
                <p class="text-xs text-slate-400 mt-1">Gérez les activités liées à ce projet de recherche.</p>
            </div>
            <button type="button" data-action="click->research-project-page#openCreateModal" class="px-4 py-2 rounded-xl bg-slate-50 border border-slate-200 hover:bg-slate-100 hover:text-djoliba text-slate-600 font-bold text-xs transition-all flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Ajouter un sous-projet
            </button>
        </div>

        <div class="divide-y divide-slate-100">
            {% for sp in sub_projects %}
                <div class="px-8 py-5 flex items-center justify-between hover:bg-slate-50/50 transition-colors">
                    <div class="flex items-center gap-4 min-w-0">
                        <div class="w-10 h-10 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center text-lg flex-shrink-0">
                            {% if sp.type == 'reading' %}📖
                            {% elseif sp.type == 'literature' %}📚
                            {% elseif sp.type == 'writing' %}✍️
                            {% elseif sp.type == 'thesis' %}🎓
                            {% endif %}
                        </div>
                        <div class="min-w-0">
                            <h3 class="font-semibold text-sm text-slate-800 truncate">{{ sp.name }}</h3>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">
                                    {% if sp.type == 'reading' %}Lecture
                                    {% elseif sp.type == 'literature' %}Synthèse
                                    {% elseif sp.type == 'writing' %}Écriture
                                    {% elseif sp.type == 'thesis' %}Thèse
                                    {% endif %}
                                </span>
                                <span class="w-1 h-1 rounded-full bg-slate-200"></span>
                                <span class="text-[10px] text-slate-400">Créé le {{ sp.createdAt|date('d/m/Y') }}</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-6">
                        <span class="subproject-status px-2.5 py-0.5 rounded-full text-[10px] font-bold {{ sp.status == 'active' ? 'bg-emerald-500/10 text-emerald-700' : 'bg-slate-100 text-slate-600' }}">
                            {{ sp.status == 'active' ? 'Actif' : 'Archivé' }}
                        </span>

                        <div class="flex items-center gap-1">
                            <!-- Action Activer/Désactiver -->
                            <form action="{{ path('app_subproject_toggle_status', {id: sp.id}) }}" method="POST" title="Changer le statut">
                                <button type="submit" class="p-2 text-slate-400 hover:text-djoliba hover:bg-slate-100 rounded-lg transition-colors">
                                    🔄
                                </button>
                            </form>
                            
                            <!-- Action Modifier (Renommer) -->
                            <button type="button" data-action="click->research-project-page#openEditModal" data-sp-id="{{ sp.id }}" data-sp-name="{{ sp.name }}" class="p-2 text-slate-400 hover:text-djoliba hover:bg-slate-100 rounded-lg transition-colors" title="Renommer">
                                ✏️
                            </button>

                            <!-- Action Supprimer -->
                            <form action="{{ path('app_subproject_delete', {id: sp.id}) }}" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce sous-projet définitivement ?');" title="Supprimer">
                                <button type="submit" class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors">
                                    🗑️
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="px-8 py-16 text-center">
                    <span class="text-4xl">📁</span>
                    <h3 class="font-bold text-slate-700 mt-4">Aucun sous-projet pour l'instant</h3>
                    <p class="text-sm text-slate-400 mt-1 max-w-sm mx-auto">Créez votre première activité (lecture, synthèse, écriture, thèse) associée à ce projet de recherche.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    <!-- Section Bibliographie du Projet -->
    <div class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden" data-controller="bibliography-manager">
        <div class="px-8 py-6 border-b border-slate-100 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h2 class="text-xl font-display font-bold text-djoliba">Bibliographie du Projet</h2>
                <p class="text-xs text-slate-400 mt-1">Gérez les références associées à ce projet de recherche.</p>
            </div>
            <div class="flex flex-wrap gap-2">
                <a href="{{ path('app_bibliography_project_export', {projectId: research_project.id}) }}" class="px-4 py-2 rounded-xl bg-slate-50 border border-slate-200 hover:bg-slate-100 hover:text-djoliba text-slate-600 font-bold text-xs transition-all flex items-center gap-1.5">
                    📥 Exporter (.bib)
                </a>
                <button type="button" data-action="click->bibliography-manager#openAssociationModal" class="px-4 py-2 rounded-xl bg-slate-50 border border-slate-200 hover:bg-slate-100 hover:text-djoliba text-slate-600 font-bold text-xs transition-all flex items-center gap-1.5">
                    🔗 Associer des références existantes
                </button>
                <button type="button" data-action="click->bibliography-manager#openAddModal" class="px-4 py-2 rounded-xl bg-djoliba hover:bg-djoliba/95 text-white font-bold text-xs transition-all flex items-center gap-1.5">
                    ➕ Ajouter une nouvelle référence
                </button>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Clé / Type</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Auteurs / Année</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Titre</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm text-slate-700 font-medium">
                    {% for ref in project_references %}
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-mono text-xs font-bold text-amber-700 bg-amber-50 px-2 py-0.5 rounded border border-amber-200/50 w-fit">
                                    {{ ref.citeKey }}
                                </div>
                                <div class="text-[10px] uppercase font-bold text-slate-400 mt-1">
                                    {{ ref.entryType }}
                                </div>
                            </td>
                            <td class="px-6 py-4 space-y-1">
                                <div class="font-semibold text-slate-800 line-clamp-1" title="{{ ref.authors }}">
                                    {{ ref.authors ?: 'Auteur inconnu' }}
                                </div>
                                <div class="text-xs text-slate-400">
                                    {{ ref.year ?: 'N.D.' }}
                                </div>
                            </td>
                            <td class="px-6 py-4 max-w-xs md:max-w-md">
                                <div class="text-slate-800 line-clamp-2" title="{{ ref.title }}">
                                    {{ ref.title ?: 'Sans titre' }}
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <form action="{{ path('app_bibliography_project_remove', {projectId: research_project.id, referenceId: ref.id}) }}" method="POST" onsubmit="return confirm('Voulez-vous vraiment détacher cette référence de ce projet ?');">
                                    <button type="submit" class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all" title="Dissocier du projet">
                                        🔗❌
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center text-slate-400">
                                <span class="text-3xl">📚</span>
                                <h3 class="font-bold text-slate-700 mt-3">Aucune référence associée</h3>
                                <p class="text-xs mt-1 max-w-sm mx-auto">Liez des références existantes ou ajoutez-en de nouvelles pour les utiliser avec ce projet.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Modale 1 : Associer des références existantes -->
        <div data-bibliography-manager-target="associationModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
            <div data-action="click->bibliography-manager#closeAssociationModal" class="absolute inset-0 cursor-default"></div>
            <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-md z-10 transform scale-95 opacity-0 transition-all duration-300">
                <button type="button" data-action="click->bibliography-manager#closeAssociationModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
                <div class="mb-6">
                    <h3 class="text-2xl font-display font-bold text-djoliba">Lier des références</h3>
                    <p class="text-sm text-slate-400 mt-1">Sélectionnez les références de votre bibliothèque à lier à ce projet.</p>
                </div>
                
                <form action="{{ path('app_bibliography_project_add', {projectId: research_project.id}) }}" method="POST" class="space-y-6">
                    <div class="max-h-60 overflow-y-auto border border-slate-150 rounded-2xl p-4 space-y-3 custom-scrollbar">
                        {% for ref in all_references %}
                            {# Vérifier si elle est déjà dans le projet #}
                            {% set is_already_associated = false %}
                            {% for pr in project_references %}
                                {% if pr.id == ref.id %}
                                    {% set is_already_associated = true %}
                                {% endif %}
                            {% endfor %}
                            
                            {% if not is_already_associated %}
                                <label class="flex items-start gap-3 cursor-pointer p-2 hover:bg-slate-50 rounded-xl transition-all">
                                    <input type="checkbox" name="reference_ids[]" value="{{ ref.id }}" class="mt-1 rounded border-slate-300 text-djoliba focus:ring-djoliba">
                                    <div>
                                        <div class="font-mono text-[10px] font-bold text-amber-700 bg-amber-50 px-1.5 py-0.5 rounded border border-amber-200/50 w-fit">
                                            {{ ref.citeKey }}
                                        </div>
                                        <div class="text-xs text-slate-800 font-semibold line-clamp-1 mt-1">{{ ref.title }}</div>
                                        <div class="text-[10px] text-slate-400">{{ ref.authors ?: 'Auteur inconnu' }} ({{ ref.year ?: 'N.D.' }})</div>
                                    </div>
                                </label>
                            {% endif %}
                        {% else %}
                            <div class="text-center text-slate-400 py-6 text-xs">
                                Votre bibliothèque personnelle est vide.
                            </div>
                        {% endfor %}
                    </div>

                    <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                        <button type="button" data-action="click->bibliography-manager#closeAssociationModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                            Annuler
                        </button>
                        <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                            Lier
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Modale 2 : Ajouter une nouvelle référence (et la lier au projet) -->
        <div data-bibliography-manager-target="addModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
            <div data-action="click->bibliography-manager#closeAddModal" class="absolute inset-0 cursor-default"></div>
            <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-lg z-10 transform scale-95 opacity-0 transition-all duration-300 max-h-[90vh] overflow-y-auto custom-scrollbar">
                <button type="button" data-action="click->bibliography-manager#closeAddModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
                <div class="mb-6">
                    <h3 class="text-2xl font-display font-bold text-djoliba">Créer et lier une référence</h3>
                    <p class="text-sm text-slate-400 mt-1">Saisissez les informations ou utilisez un DOI pour pré-remplir le formulaire.</p>
                </div>

                <!-- Résolveur DOI -->
                <div class="bg-slate-50 rounded-2xl p-4 mb-6 border border-slate-100 space-y-2">
                    <label for="doi-resolver-field-project" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Résoudre depuis un DOI (Crossref)</label>
                    <div class="flex gap-2">
                        <input type="text" id="doi-resolver-field-project" data-bibliography-manager-target="doiInput" placeholder="Ex: 10.1038/nature12345" class="flex-grow px-3 py-2 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                        <button type="button" data-action="click->bibliography-manager#resolveDoi" class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-xl hover:bg-slate-800 transition-colors">
                            Résoudre
                        </button>
                    </div>
                    <div data-bibliography-manager-target="doiStatus" class="text-[10px] text-slate-400 italic">Saisissez un DOI pour remplir automatiquement les champs ci-dessous.</div>
                </div>

                <form action="{{ path('app_bibliography_add') }}" method="POST" class="space-y-4">
                    <input type="hidden" name="project_id" value="{{ research_project.id }}">
                    
                    <div class="grid grid-cols-3 gap-3">
                        <div class="col-span-2">
                            <label for="ref-citekey-project" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Clé de citation (Cite Key)</label>
                            <input type="text" id="ref-citekey-project" name="citeKey" data-bibliography-manager-target="citeKeyInput" required placeholder="Ex: Smith2026" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba font-mono text-amber-700 font-bold">
                        </div>
                        <div>
                            <label for="ref-type-project" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Type</label>
                            <select id="ref-type-project" name="entryType" required class="w-full px-3 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba bg-white font-semibold text-slate-600">
                                <option value="article">Article</option>
                                <option value="book">Livre</option>
                                <option value="inproceedings">Conférence</option>
                                <option value="thesis">Thèse</option>
                                <option value="misc" selected>Autre (Misc)</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label for="ref-title-project" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Titre</label>
                        <textarea id="ref-title-project" name="title" rows="2" data-bibliography-manager-target="titleInput" required placeholder="Titre de la publication" class="w-full px-4 py-2 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba"></textarea>
                    </div>

                    <div>
                        <label for="ref-authors-project" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Auteurs (Séparés par "and")</label>
                        <input type="text" id="ref-authors-project" name="authors" data-bibliography-manager-target="authorsInput" placeholder="Ex: Doe, John and Smith, Jane" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                    </div>

                    <div class="grid grid-cols-3 gap-3">
                        <div class="col-span-2">
                            <label for="ref-journal-project" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Journal / Revue / Éditeur</label>
                            <input type="text" id="ref-journal-project" name="journal" data-bibliography-manager-target="journalInput" placeholder="Revue ou éditeur" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                        </div>
                        <div>
                            <label for="ref-year-project" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Année</label>
                            <input type="text" id="ref-year-project" name="year" data-bibliography-manager-target="yearInput" placeholder="Ex: 2026" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label for="ref-doi-project" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">DOI</label>
                            <input type="text" id="ref-doi-project" name="doi" placeholder="DOI de l'article" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                        </div>
                        <div>
                            <label for="ref-publisher-project" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Maison d'édition</label>
                            <input type="text" id="ref-publisher-project" data-bibliography-manager-target="publisherInput" placeholder="Éditeur optionnel" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                        </div>
                    </div>

                    <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                        <button type="button" data-action="click->bibliography-manager#closeAddModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                            Annuler
                        </button>
                        <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                            Enregistrer et lier
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modale de Création de Sous-projet -->
    <div data-research-project-page-target="createModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
        <div data-action="click->research-project-page#closeCreateModal" class="absolute inset-0 cursor-default"></div>
        <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-md z-10 transform scale-95 opacity-0 transition-all duration-300">
            <button type="button" data-action="click->research-project-page#closeCreateModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            <div class="mb-6">
                <h3 class="text-2xl font-display font-bold text-djoliba">Ajouter un sous-projet</h3>
                <p class="text-sm text-slate-400 mt-1">Créez une nouvelle activité rattachée à ce projet de recherche.</p>
            </div>
            <form action="{{ path('app_research_project_subproject_create', {id: research_project.id}) }}" method="POST" class="space-y-6">
                <div>
                    <label for="sp-name" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nom de l'activité</label>
                    <input id="sp-name" name="name" type="text" required placeholder="Ex: Revue de littérature sur le sahel" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300">
                </div>
                <div>
                    <label for="sp-type" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Type d'activité</label>
                    <select id="sp-type" name="type" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold">
                        <option value="reading">📖 Projet de lecture</option>
                        <option value="literature">📚 Projet de synthèse</option>
                        <option value="writing">✍️ Projet d'écriture</option>
                        <option value="thesis">🎓 Thèse / Mémoire</option>
                    </select>
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->research-project-page#closeCreateModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Créer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modale d'Édition (Renommer) -->
    <div data-research-project-page-target="editModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
        <div data-action="click->research-project-page#closeEditModal" class="absolute inset-0 cursor-default"></div>
        <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-md z-10 transform scale-95 opacity-0 transition-all duration-300">
            <button type="button" data-action="click->research-project-page#closeEditModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            <div class="mb-6">
                <h3 class="text-2xl font-display font-bold text-djoliba">Renommer l'activité</h3>
                <p class="text-sm text-slate-400 mt-1">Donnez un nouveau nom à votre sous-projet.</p>
            </div>
            <form id="edit-sp-form" action="" method="POST" class="space-y-6">
                <div>
                    <label for="edit-sp-name" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nom du sous-projet</label>
                    <input id="edit-sp-name" name="name" type="text" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300">
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->research-project-page#closeEditModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
