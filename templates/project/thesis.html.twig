{# templates/project/thesis.html.twig #}
{% extends 'base.html.twig' %}

{# Interface plein-écran : la sidebar est masquée pour maximiser l'espace d'édition #}
{% set hide_sidebar = true %}

{% block title %}Structure de la Thèse -
	{{ project.name }}
	- Djoliba
{% endblock %}

{# Suppress the footer for this full-screen workspace #}
{% block footer %}{% endblock %}

{% block stylesheets %}
	<style>
		/* Clean full-screen application layout: prevent body from scrolling and force vertical columns */
		html,
		body,
		main.flex-grow,
		body > div,
		body > div > div {
			height: 100vh !important;
			max-height: 100vh !important;
			overflow: hidden !important;
			margin: 0 !important;
			padding: 0 !important;
		}

		/* Force base layout wrapper divs to fill the screen without scrolling */
		body > div,
		body > div > div,
		main.flex-grow {
			display: flex !important;
			flex-direction: column !important;
			flex: 1 1 0 !important;
			min-height: 0 !important;
		}

		/* Design System & Visual Polish for Thesis Module (Sleek Compact Navigation style) */
		.thesis-header {
			background-color: var(--primary);
			padding: 0.75rem 2rem;
			color: white;
			border-radius: 0;
			margin-top: 0;
			position: relative;
			overflow: hidden;
		}
		.thesis-header::before {
			content: "";
			position: absolute;
			top: -50%;
			left: -20%;
			width: 140%;
			height: 200%;
			background: radial-gradient(circle at center, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
			pointer-events: none;
		}

		/* Chapter Tree Interactive Styling */
		.thesis-tree-list {
			list-style-type: none !important;
			margin: 0;
			padding-left: 1rem;
			position: relative;
		}

		.thesis-tree-item {
			position: relative;
			transition: all 0.2s ease;
		}

		/* Prevent wrapping of tree items to trigger horizontal scrolling if the titles are too long */
		.thesis-tree-item span.font-medium {
			white-space: nowrap !important;
		}

		/* Make tree rows capable of overflowing horizontally */
		.thesis-tree-item .group {
			width: max-content !important;
			min-width: 100% !important;
		}

		/* Gutter line for nested elements */
		.nested-sortable {
			position: relative;
			min-height: 10px;
		}
		.nested-sortable::before {
			content: "";
			position: absolute;
			top: 0;
			left: 8px;
			bottom: 0;
			width: 1px;
			background: #cbd5e1; /* slate-300 */
			opacity: 0.5;
		}

		.thesis-tree-item .cursor-move {
			cursor: grab;
			transition: transform 0.2s ease;
		}
		.thesis-tree-item .cursor-move:active {
			cursor: grabbing;
			transform: scale(1.1);
		}

		/* Active Tree Item Highlight */
		.thesis-tree-item-active {
			background-color: rgba(11, 37, 69, 0.06) !important; /* bg-djoliba/5 equivalent with premium opacity */
			border-left: 3px solid #0B2545 !important; /* Elegant vertical indicator */
			color: #0B2545 !important;
			font-weight: 700 !important;
			box-shadow: 0 1px 3px 0 rgba(11, 37, 69, 0.1), 0 1px 2px 0 rgba(11, 37, 69, 0.06) !important;
		}
	</style>
{% endblock %}

{% block main %}
	{#
		 ┌────────────────────────────────────────────────────────────────────────┐
		 │  Layout plein-écran split-panel                                        │
		 │  ┌─ Barre d'en-tête compacte ────────────────────────────────────────┐ │
		 │  └────────────────────────────────────────────────────────────────────┘ │
		 │  ┌─ Panneau gauche (28%) ─┐  ┌─ Panneau droit (72%) ────────────────┐ │
		 │  │  Plan / Arborescence   │  │  Éditeur de chapitre                 │ │
		 │  │  (scroll indépendant)  │  │  (scroll indépendant)                │ │
		 │  └────────────────────────┘  └──────────────────────────────────────┘ │
		 └────────────────────────────────────────────────────────────────────────┘
		#}
	<div
		data-controller="thesis-editor" data-thesis-editor-project-id-value="{{ project.id }}" style="height: 100vh; display: flex; flex-direction: column; overflow: hidden;">

		{# ========================================================================
				       ZONE SPLIT-PANEL (flex-1 = remplit tout l'espace restant)
				       ======================================================================== #}
		<div
			style="flex: 1 1 0%; display: flex; flex-direction: row; overflow: hidden; background: #fff;">

			{# ── PANNEAU GAUCHE : ARBORESCENCE (20%) ─────────────────────── #}
			<div
				style="width: 20%; min-width: 180px; max-width: 25%; display: flex; flex-direction: column; overflow: hidden; border-right: 1px solid #e2e8f0; background: #fff;">

				{# En-tête panneau gauche #}
				<div class="px-5 py-4 border-b border-slate-100 flex-shrink-0">
					<div class="flex items-start justify-between mb-3 gap-2">
						<div class="flex items-center gap-2.5">
							<a href="{{ path('app_thesis_hub') }}" class="w-8 h-8 rounded-xl bg-slate-50 border border-slate-200 hover:bg-slate-100 flex items-center justify-center text-djoliba transition-all shadow-sm flex-shrink-0" title="Retour au hub thèse">
								<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
								</svg>
							</a>
							<div>
								<h3 class="text-xs font-black text-djoliba">Plan de thèse</h3>
								<p class="text-[9px] text-slate-400">Glissez-déposez pour réorganiser</p>
							</div>
						</div>
					</div>

					{# Boutons d'ajout #}
					<div class="flex gap-2">
						<button type="button" data-action="click->thesis-editor#addChapter" class="flex-1 px-3 py-2 bg-djoliba text-white text-[11px] font-bold rounded-xl hover:opacity-95 transition-all flex items-center justify-center gap-1.5 shadow-sm shadow-djoliba/10" title="Ajouter un chapitre principal">
							<span class="text-sm leading-none">+</span>
							Chapitre
						</button>
						<button type="button" data-action="click->thesis-editor#addSubChapter" class="flex-1 px-3 py-2 bg-slate-50 border border-slate-200 hover:bg-slate-100 text-djoliba text-[11px] font-bold rounded-xl transition-all flex items-center justify-center gap-1.5" title="Ajouter un sous-chapitre">
							<span class="text-sm leading-none">+</span>
							Sous-partie
						</button>
					</div>
				</div>

				{# Arborescence scrollable #}
				<div class="flex-grow overflow-y-auto overflow-x-auto custom-scrollbar p-4">
					<div
						data-thesis-editor-target="tree" class="text-xs text-slate-600">
						{# Rempli dynamiquement par JS #}
						<div class="text-center py-16 text-slate-400 italic">
							<svg class="w-8 h-8 mx-auto mb-3 animate-spin text-slate-300" fill="none" viewbox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89H18"/>
							</svg>
							Chargement de la structure...
						</div>
					</div>
				</div>

				{# Bouton d'export PDF du document complet #}
				<div class="px-4 py-3 border-t border-slate-100 flex-shrink-0">
					<button
						type="button"
						id="btn-export-full-pdf"
						data-action="click->thesis-editor#exportFullPdf"
						class="w-full px-3 py-2.5 bg-rose-50 hover:bg-rose-100 border border-rose-200 text-rose-700 text-[11px] font-bold rounded-xl transition-all flex items-center justify-center gap-2"
						title="Exporter le document complet en PDF (tous les chapitres)">
						<svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
						</svg>
						Exporter le document
					</button>
					<p data-thesis-editor-target="status" class="text-[9px] text-slate-400 italic text-center mt-1.5"></p>
				</div>
			</div>

			{# ── PANNEAU DROIT : ÉDITEUR (80%) ────────────────────────────── #}
			<div
				style="flex: 1 1 0%; display: flex; flex-direction: column; overflow: hidden; background: #fff;">

				{# ÉDITEUR (masqué par défaut, JS l'affiche au clic d'un chapitre) #}
				<div
					data-thesis-editor-target="editor"
					class="hidden flex-grow flex flex-col overflow-hidden bg-white h-full">

					{# Zone de contenu principale (sans scroll global, hauteur totale) #}
					<div class="flex-grow flex flex-col min-h-0 overflow-hidden gap-4 bg-slate-50/10">
						{# Titre du chapitre (caché pour maximiser l'espace, la gestion et la surbrillance se font dans l'arborescence) #}
						<input type="hidden" data-thesis-editor-target="titleInput">

						{# Zone d'écriture étirable à 100% de la hauteur #}
						<div class="flex-grow flex flex-col min-h-0 overflow-hidden gap-2">
							<div class="flex-grow flex flex-col min-h-0 overflow-hidden mt-3">
								{% include 'project/_writing_editor.html.twig' with {
									'project': project,
									'save_url': '',
									'placeholder': 'Rédigez le texte scientifique, les chapitres de thèse ou le plan détaillé. Le Markdown et le LaTeX sont pleinement supportés...',
									'storage_key': 'thesis_chapter_draft_' ~ project.id,
									'is_thesis': true
								} %}
							</div>
						</div>

						{# RÉSULTATS COHÉRENCE IA #}
						<div data-thesis-editor-target="results" class="flex-shrink-0 empty:hidden"></div>
					</div>



				</div>

				{# ÉTAT VIDE : affiché quand aucun chapitre n'est sélectionné #}
				<div
					id="thesis-editor-blank-state"
					data-thesis-editor-target="blankState"
					class="flex-grow flex flex-col items-center justify-center p-12 text-center gap-4 bg-slate-50/50 h-full">
					<div class="w-16 h-16 bg-slate-50 border border-slate-100 rounded-2xl flex items-center justify-center text-slate-400 shadow-inner">
						<svg class="w-8 h-8" fill="none" viewbox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
						</svg>
					</div>
					<div>
						<h3 class="text-sm font-bold text-djoliba">Sélectionnez un Chapitre</h3>
						<p class="text-[11px] text-slate-400 mt-1 max-w-sm mx-auto leading-relaxed">
							Choisissez une section dans le plan à gauche pour commencer à rédiger.
							Vous pouvez aussi cliquer sur
							<strong>« + Chapitre »</strong>
							pour démarrer un nouveau plan.
						</p>
					</div>
				</div>
			</div>
			{# /panneau droit #}

		</div>
		{# /split-panel #}

	</div>
	{# /thesis-editor controller #}
{% endblock %}
