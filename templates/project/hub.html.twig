{% extends 'base.html.twig' %}

{% block title %}Djoliba Search - Hub Central{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50 pt-24 pb-12" data-controller="search">
    <input type="file" data-search-target="fileInput" data-action="change->search#onUpload" class="hidden" accept=".pdf">

    <div class="max-w-5xl mx-auto px-4">
        
        <!-- Header / Salutation -->
        <div class="mb-12 fade-in">
            <h1 class="text-3xl font-display font-black text-djoliba mb-2">Bonjour, {{ app.user ? (app.user.firstName ?: app.user.userIdentifier) : 'Chercheur' }}</h1>
            <p class="text-slate-500">Que souhaitez-vous explorer aujourd'hui ?</p>
        </div>

        {# Indicateur de projet de recherche actif #}
        {% if app.user %}
            {% set active_rp = get_active_research_project() %}
            {% if active_rp %}
                <div class="mb-8 p-4 bg-gradient-to-r from-emerald-500/10 to-teal-500/10 border border-emerald-500/20 rounded-2xl flex items-center justify-between shadow-sm fade-in">
                    <div class="flex items-center gap-3">
                        <span class="text-2xl animate-pulse">🎯</span>
                        <div>
                            <span class="text-xs font-bold text-emerald-700 uppercase tracking-wider block">Projet de recherche actif</span>
                            <span class="font-bold text-djoliba text-sm">{{ active_rp.name }}</span>
                            {% if active_rp.description %}
                                <span class="text-xs text-slate-500 block truncate max-w-lg mt-0.5">{{ active_rp.description }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <button data-controller="research-project-hub" data-action="click->research-project-hub#selectProject" data-rp-id="{{ active_rp.id }}" data-active="true" class="px-4 py-2 bg-white hover:bg-slate-50 border border-slate-200 text-slate-600 font-bold text-xs rounded-xl transition-all shadow-sm">
                            Désélectionner
                        </button>
                    </div>
                </div>
            {% endif %}
        {% endif %}

        <!-- Barre de recherche Centrale -->
        <div class="mb-16 fade-in" style="animation-delay: 0.1s">
            <div class="relative group">
                <div class="absolute -inset-1 bg-gradient-to-r from-djoliba to-emerald_ia rounded-2xl blur opacity-20 group-hover:opacity-30 transition duration-1000 group-hover:duration-200"></div>
                <div class="relative flex items-center bg-white rounded-2xl shadow-xl border border-slate-100 p-2">
                    <div class="pl-4 text-slate-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                    <input type="text" 
                           data-search-target="input"
                           data-action="keydown->search#onSearch"
                           placeholder="Rechercher un article, un sujet ou un document..." 
                           class="w-full px-4 py-4 text-lg border-none focus:ring-0 text-djoliba placeholder-slate-400 font-medium">
                    <button data-action="click->search#onSearch"
                            class="bg-djoliba text-white px-8 py-4 rounded-xl font-bold hover:bg-slate-800 transition-all shadow-lg flex items-center gap-2">
                        Rechercher
                    </button>
                </div>
            </div>
            <div class="mt-4 flex gap-4 text-xs font-medium text-slate-400 justify-center">
                <span>Populaire : </span>
                <a href="#" class="hover:text-djoliba underline">Intelligence Artificielle au Sahel</a>
                <a href="#" class="hover:text-djoliba underline">Agriculture durable</a>
                <a href="#" class="hover:text-djoliba underline">Énergies renouvelables</a>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16 fade-in" style="animation-delay: 0.2s">
            <div data-action="click->search#triggerUpload" class="bg-white rounded-3xl border border-slate-200 shadow-sm hover:border-emerald_ia hover:shadow-md transition-all group flex flex-col items-center justify-center p-10 cursor-pointer">
                <div class="w-16 h-16 bg-emerald-50 text-emerald_ia rounded-2xl flex items-center justify-center mb-4 transition-transform">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-djoliba mb-1">Analyser un PDF</h3>
                <p class="text-sm text-slate-500 text-center">Glissez un document pour une synthèse instantanée</p>
            </div>
            
            <a href="{{ path('app_project_hub') }}" class="bg-white rounded-3xl border border-slate-200 shadow-sm hover:border-gold_prestige hover:shadow-md transition-all group flex flex-col items-center justify-center p-10 cursor-pointer">
                <div class="w-16 h-16 bg-amber-50 text-gold_prestige rounded-2xl flex items-center justify-center mb-4 transition-transform">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-djoliba mb-1">Revue de Littérature</h3>
                <p class="text-sm text-slate-500 text-center">Générez un état de l'art assisté par IA</p>
            </a>
        </div>

        {# Section Projets de Recherche parent #}
        {% if app.user %}
            {% set research_projects = get_user_research_projects() %}
            {% set active_rp = get_active_research_project() %}
            
            <div class="mb-16 fade-in" style="animation-delay: 0.25s" data-controller="research-project-hub">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-display font-bold text-djoliba">Mes Projets de Recherche</h2>
                    <button data-action="click->research-project-hub#openModal" class="px-4 py-2 bg-djoliba hover:bg-slate-800 text-white font-bold text-xs rounded-xl transition-all shadow-md flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                        Nouveau projet de recherche
                    </button>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {% for rp in research_projects %}
                        {% set is_rp_active = active_rp and active_rp.id == rp.id %}
                        <div class="bg-white rounded-3xl p-6 border transition-all relative flex flex-col justify-between {{ is_rp_active ? 'border-emerald-500 ring-4 ring-emerald-500/10 shadow-md' : 'border-slate-200 shadow-sm hover:border-slate-300 hover:shadow-md' }}">
                            <div>
                                <div class="flex items-start justify-between gap-4 mb-2">
                                    <div class="flex items-center gap-2 min-w-0">
                                        <span class="text-2xl">📁</span>
                                        <h3 class="font-display font-bold text-djoliba text-base truncate">{{ rp.name }}</h3>
                                    </div>
                                    <div class="flex items-center gap-2 flex-shrink-0">
                                        <button data-action="click->research-project-hub#selectProject" data-rp-id="{{ rp.id }}" data-active="{{ is_rp_active ? 'true' : 'false' }}" class="px-2.5 py-1.5 text-[10px] font-bold rounded-lg border transition-all {{ is_rp_active ? 'bg-emerald-500 text-white border-emerald-500 hover:bg-emerald-600' : 'bg-slate-50 text-slate-600 border-slate-200 hover:bg-slate-100' }}">
                                            {{ is_rp_active ? 'Actif' : 'Sélectionner' }}
                                        </button>
                                        <button data-action="click->research-project-hub#deleteProject" data-rp-id="{{ rp.id }}" class="p-1.5 text-slate-300 hover:text-red-500 transition-colors" title="Supprimer le projet de recherche">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                        </button>
                                    </div>
                                </div>
                                <p class="text-xs text-slate-500 line-clamp-2 min-h-[2rem] mb-4">
                                    {{ rp.description ?: 'Aucune description fournie.' }}
                                </p>
                            </div>
                            
                            <div class="border-t border-slate-100 pt-4 flex items-center justify-between text-xs text-slate-400">
                                <span>{{ rp.projects|filter(p => p.status != 'deleted')|length }} sous-projet(s)</span>
                                <span>Créé le {{ rp.createdAt|date('d/m/Y') }}</span>
                            </div>
                        </div>
                    {% else %}
                        <div class="col-span-full py-12 text-center bg-white rounded-3xl border-2 border-dashed border-slate-200">
                            <p class="text-slate-400 mb-3">Aucun projet de recherche créé pour le moment</p>
                            <button data-action="click->research-project-hub#openModal" class="px-4 py-2 bg-djoliba hover:bg-slate-800 text-white font-bold text-xs rounded-xl transition-all shadow-md">
                                Créer mon premier projet de recherche
                            </button>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <!-- Section Projets Récents -->
        <div class="fade-in" style="animation-delay: 0.3s">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-display font-bold text-djoliba">Sous-projets récents</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {% for sp in sub_projects|slice(0, 4) %}
                    <a href="{{ path('app_subproject_show', {id: sp.id}) }}" class="group">
                        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm hover:border-djoliba hover:shadow-md transition-all flex items-center gap-4">
                            <div class="w-12 h-12 bg-slate-50 border border-slate-100 rounded-xl flex items-center justify-center text-xl transition-all">
                                {% if sp.type == 'reading' %}📖
                                {% elseif sp.type == 'literature' %}📚
                                {% elseif sp.type == 'writing' %}✍️
                                {% elseif sp.type == 'thesis' %}🎓
                                {% endif %}
                            </div>
                            <div class="flex-grow min-w-0">
                                <h4 class="font-bold text-djoliba truncate">{{ sp.name }}</h4>
                                <div class="flex items-center gap-1.5 mt-0.5">
                                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">
                                        {% if sp.type == 'reading' %}Lecture
                                        {% elseif sp.type == 'literature' %}Synthèse
                                        {% elseif sp.type == 'writing' %}Écriture
                                        {% elseif sp.type == 'thesis' %}Thèse
                                        {% endif %}
                                    </span>
                                    <span class="w-1 h-1 rounded-full bg-slate-200"></span>
                                    <p class="text-xs text-slate-400">Modifié le {{ sp.createdAt|date('d/m/Y') }}</p>
                                </div>
                            </div>
                            <svg class="w-5 h-5 text-slate-200 group-hover:text-djoliba transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </div>
                    </a>
                {% else %}
                    <div class="col-span-full py-12 text-center bg-white rounded-2xl border-2 border-dashed border-slate-200">
                        <p class="text-slate-400">Aucun projet récent</p>
                    </div>
                {% endfor %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
