{% extends 'base.html.twig' %}

{% block title %}Lecture & Analyse de Document - Djoliba{% endblock %}

{% block main %}
<div class="p-8 max-w-7xl mx-auto" 
     data-controller="reading-chat"
     data-reading-chat-project-id-value="{{ project.id }}"
     data-reading-chat-document-id-value="{{ document_id|default(0) }}"
     data-reading-chat-url-value="/api/reading/chat">
     
    {# En-tête du projet #}
    <div class="mb-8 flex justify-between items-start">
        <div>
            <nav class="flex text-sm text-slate-400 mb-2" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2">
                    <li><a href="{{ path('app_hub') }}" class="hover:text-djoliba transition-colors">Hub</a></li>
                    <li><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></li>
                    <li class="text-djoliba font-medium">Lecture & Analyse</li>
                </ol>
            </nav>
            <h1 class="text-3xl font-display font-bold text-djoliba">{{ project.name }}</h1>
        </div>
        <div class="flex gap-2">
            <span class="px-3 py-1 bg-emerald_ia/5 text-emerald_ia rounded-full text-xs font-bold border border-emerald_ia/10">Analyse de PDF active</span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        {# Zone gauche (Col 7) : Upload & Synthèse #}
        <div class="lg:col-span-7 space-y-8">
            {# Zone Drag & Drop #}
            <div data-action="dragenter->reading-chat#onDragOver dragover->reading-chat#onDragOver dragleave->reading-chat#onDragLeave drop->reading-chat#onDrop click->reading-chat#triggerSelect"
                 class="bg-white rounded-3xl p-8 border-2 border-dashed border-slate-200 hover:border-djoliba/50 transition-all flex flex-col items-center justify-center text-center cursor-pointer min-h-[220px] group relative overflow-hidden shadow-sm">
                
                <div class="absolute top-0 left-0 w-full h-1.5 bg-slate-100 hidden" data-reading-chat-target="progressContainer">
                    <div class="h-full bg-djoliba w-0 transition-all duration-300" data-reading-chat-target="progressBar"></div>
                </div>

                <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center text-djoliba transition-colors mb-4">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
                </div>
                
                <div class="space-y-1">
                    <p class="text-sm font-bold text-djoliba">Glissez-déposez votre document PDF ici</p>
                    <p class="text-xs text-slate-400">Ou cliquez pour parcourir vos fichiers (Max. 25 Mo)</p>
                </div>
            </div>

            <input type="file" 
                   data-reading-chat-target="fileInput" 
                   data-action="change->reading-chat#onFileSelect" 
                   class="hidden" 
                   accept=".pdf">

            {# Affichage de la Synthèse #}
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden min-h-[350px] flex flex-col">
                <div class="px-6 py-4 border-b border-slate-50 flex justify-between items-center bg-slate-50/30">
                    <h2 class="text-sm font-bold text-djoliba flex items-center gap-2">
                        <svg class="w-4 h-4 text-emerald_ia" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                        Points Clés du Document
                    </h2>
                    <span class="text-[10px] bg-slate-100 text-slate-500 px-2 py-0.5 rounded-full font-medium" data-reading-chat-target="docName">
                        {{ document ? document.filename : 'Aucun document chargé' }}
                    </span>
                </div>

                <div class="p-8 flex-grow flex flex-col justify-start overflow-y-auto max-h-[380px] custom-scrollbar" data-reading-chat-target="synthesisContainer">
                    {# Message initial #}
                    <div class="text-center max-w-sm mx-auto my-auto space-y-3 {% if document_id is defined and document_id > 0 %}hidden{% endif %}" data-reading-chat-target="emptyState">
                        <div class="w-12 h-12 bg-slate-50 text-slate-300 rounded-full flex items-center justify-center mx-auto">
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" /></svg>
                        </div>
                        <p class="text-sm font-semibold text-slate-600">En attente de votre document</p>
                        <p class="text-xs text-slate-400">Importez un PDF pour générer automatiquement une synthèse structurée de son contenu.</p>
                    </div>

                    {# Skeleton Loader pendant la synthèse #}
                    <div class="space-y-4 my-auto hidden" data-reading-chat-target="loader">
                        <div class="animate-pulse flex space-x-4">
                            <div class="flex-1 space-y-4 py-1">
                               <div class="h-4 bg-slate-200 rounded w-1/4"></div>
                               <div class="space-y-2">
                                   <div class="h-3 bg-slate-100 rounded"></div>
                                   <div class="h-3 bg-slate-100 rounded w-5/6"></div>
                               </div>
                            </div>
                        </div>
                        <div class="animate-pulse flex space-x-4">
                            <div class="flex-1 space-y-4 py-1">
                               <div class="h-4 bg-slate-200 rounded w-1/3"></div>
                               <div class="space-y-2">
                                   <div class="h-3 bg-slate-100 rounded"></div>
                                   <div class="h-3 bg-slate-100 rounded w-4/5"></div>
                               </div>
                            </div>
                        </div>
                    </div>

                    {# Liste des points de synthèse #}
                    <div class="space-y-6 hidden text-xs text-slate-700 leading-relaxed w-full" data-reading-chat-target="pointsList">
                        {# Rempli dynamiquement via JS #}
                    </div>
                </div>
            </div>
        </div>

        {# Zone droite (Col 5) : Chat Interactif #}
        <div class="lg:col-span-5 flex flex-col h-[650px]">
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 flex flex-col h-full overflow-hidden">
                 
                {# En-tête du Chat #}
                <div class="px-6 py-4 border-b border-slate-50 flex items-center justify-between bg-slate-50/30">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-emerald_ia/10 flex items-center justify-center text-emerald_ia">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-djoliba">Interroger le document</h3>
                            <p class="text-[10px] text-slate-400">Posez vos questions sur le texte analysé</p>
                        </div>
                    </div>
                    
                    {# Statut ou bouton d'annulation #}
                    <button data-action="click->reading-chat#cancelStream" 
                            class="text-xs text-red-500 font-bold hover:underline hidden" 
                            type="button">
                        Annuler
                    </button>
                </div>

                {# Historique des Messages #}
                <div data-reading-chat-target="messages" 
                     class="flex-grow p-6 overflow-y-auto space-y-4 bg-slate-50/10 min-h-0">
                     
                    {# Message de bienvenue de l'IA #}
                    <div class="flex gap-3 max-w-[85%]">
                        <div class="flex-shrink-0 w-7 h-7 rounded-full bg-slate-100 flex items-center justify-center text-djoliba font-bold text-xs">AI</div>
                        <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm">
                            <p class="text-xs text-slate-700 leading-relaxed">
                                Bonjour ! Une fois votre document chargé et synthétisé, posez-moi des questions spécifiques.
                            </p>
                        </div>
                    </div>

                    {# Zone temporaire de streaming pour la réponse IA active #}
                    <div data-reading-chat-target="response" class="hidden"></div>
                </div>

                {# Barre de saisie #}
                <div class="p-4 border-t border-slate-50 bg-white">
                    <form data-action="submit->reading-chat#sendMessage" class="flex gap-2">
                        <input type="text" 
                               data-reading-chat-target="input" 
                               class="flex-grow px-4 py-3 bg-slate-50 border-none rounded-xl text-xs text-djoliba placeholder-slate-400 focus:ring-2 focus:ring-djoliba/20 focus:bg-white transition-all shadow-inner"
                               placeholder="Posez une question...">
                        
                        <button type="submit" 
                                data-reading-chat-target="submit"
                                class="p-3 bg-djoliba text-white rounded-xl hover:opacity-90 shadow-md shadow-djoliba/10 transition-all flex items-center justify-center">
                            <svg class="w-4 h-4 transform rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                        </button>
                    </form>
                    <div data-reading-chat-target="status" class="mt-2 text-[10px] text-slate-400 text-center"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Styles pour les bulles de chat similaires au design premium de Djoliba #}
<style>
    .message {
        max-width: 85%;
        margin-bottom: 1rem;
        font-size: 0.75rem;
        line-height: 1.5;
        padding: 0.75rem 1rem;
        position: relative;
    }
    .message--user {
        margin-left: auto;
        background-color: var(--color-djoliba);
        color: white;
        border-radius: 1.25rem 1.25rem 0.25rem 1.25rem;
    }
    .message--ai {
        background-color: white;
        color: var(--text-main);
        border: 1px solid var(--slate-100);
        border-radius: 1.25rem 1.25rem 1.25rem 0.25rem;
        box-shadow: var(--shadow-premium);
    }
    .message__time {
        display: block;
        font-size: 8px;
        color: rgba(148, 163, 184, 0.7);
        margin-top: 0.25rem;
        text-align: right;
    }
    .message--user .message__time {
        color: rgba(255, 255, 255, 0.6);
    }
</style>
{% endblock %}
