<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Djoliba - Plateforme Autonome de Recherche{% endblock %}</title>

    {# Polices Google #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Merriweather:wght@300;400;700&display=swap" rel="stylesheet">

    {# KaTeX pour le rendu des équations LaTeX #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex/contrib/auto-render.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var checkKaTeX = setInterval(function() {
                if (window.renderMathInElement) {
                    clearInterval(checkKaTeX);
                    window.renderMathInElement(document.body, {
                        delimiters: [
                            {left: "$$", right: "$$", display: true},
                            {left: "$", right: "$", display: false},
                            {left: "\\(", right: "\\)", display: false},
                            {left: "\\[", right: "\\]", display: true}
                        ],
                        throwOnError: false
                    });
                }
            }, 50);
        });
    </script>

    {# AssetMapper : CSS (Tailwind) & JS (Stimulus) #}
    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}

    {% block styles %}{% endblock %}
</head>
<body class="bg-slate-50 text-slate-900 antialiased min-h-screen flex flex-col selection:bg-djoliba selection:text-white">

    {% block header %}
        {# Conteneur pour les Toasts Stimulus #}
        <div id="toast-container" data-controller="toast" class="fixed top-6 right-6 z-[9999] flex flex-col gap-3 pointer-events-none"></div>

        {# Gestion des messages Flash Symfony via Toasts #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div data-controller="toast" data-toast-message-value="{{ message }}" data-toast-type-value="{{ label }}"></div>
            {% endfor %}
        {% endfor %}
    {% endblock %}

    {% set show_sidebar = (not hide_sidebar|default(false)) and (app.user or app.session.get('is_test_mode')) %}

    <div class="{{ show_sidebar ? 'flex min-h-screen' : '' }}" {{ show_sidebar ? 'data-controller="sidebar"' : '' }}>
        {% if show_sidebar %}
            {% block sidebar %}
                {{ include('_sidebar.html.twig') }}
            {% endblock %}
        {% endif %}

        <div class="{{ show_sidebar ? 'flex-grow flex flex-col min-w-0' : '' }}">
            {% if show_sidebar %}
                {# Header Mobile #}
                <header class="lg:hidden bg-white border-b border-slate-200 h-16 flex items-center px-4 sticky top-0 z-[70]">
                    <button data-action="click->sidebar#toggle" class="p-2 text-slate-500 hover:text-djoliba">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
                    </button>
                    <div class="ml-4 flex items-center gap-2">
                        <div class="w-7 h-7 bg-djoliba rounded-md flex items-center justify-center text-white font-bold text-sm">D</div>
                        <span class="font-display font-bold text-lg text-djoliba">Djoliba</span>
                    </div>
                </header>
            {% endif %}

            <main class="flex-grow">
                {% block main %}{% endblock %}
                {% block content %}{% endblock %}
            </main>
        </div>
    </div>

    {% block footer %}
        <footer class="bg-white border-t border-slate-200 mt-auto">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
                <div class="flex justify-center items-center gap-2 mb-4">
                    <span class="font-display font-bold text-xl text-djoliba">Djoliba</span>
                </div>
                <p class="text-slate-400 text-sm">
                    &copy; {{ 'now'|date('Y') }} Djoliba. Tous droits réservés.
                </p>
            </div>
        </footer>
    {% endblock %}

    {% block javascript %}{% endblock %}
</body>
</html>
