<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Djoliba - Plateforme Autonome de Recherche{% endblock %}</title>
    <link rel="icon" type="image/svg+xml" href="{{ asset('images/logo.svg') }}">

    {# Polices Google #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Merriweather:wght@300;400;700&display=swap" rel="stylesheet">

    {# KaTeX pour le rendu des équations LaTeX #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var checkKaTeX = setInterval(function() {
                if (window.renderMathInElement) {
                    clearInterval(checkKaTeX);
                    window.renderMathInElement(document.body, {
                        delimiters: [
                            {left: "$$", right: "$$", display: true},
                            {left: "$", right: "$", display: false},
                            {left: "\\(", right: "\\)", display: false},
                            {left: "\\[", right: "\\]", display: true}
                        ],
                        throwOnError: false
                    });
                }
            }, 50);
        });
    </script>

    {# AssetMapper : CSS (Tailwind) & JS (Stimulus) #}
    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}

    {% block styles %}{% endblock %}
</head>
<body class="bg-slate-50 text-slate-900 antialiased min-h-screen flex flex-col selection:bg-djoliba selection:text-white">

    {% block header %}
        {# Conteneur pour les Toasts Stimulus #}
        <div id="toast-container" data-controller="toast" class="fixed top-6 right-6 z-[9999] flex flex-col gap-3 pointer-events-none"></div>

        {# Gestion des messages Flash Symfony via Toasts #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div data-controller="toast" data-toast-message-value="{{ message }}" data-toast-type-value="{{ label }}"></div>
            {% endfor %}
        {% endfor %}
    {% endblock %}

    {% set show_sidebar = (not hide_sidebar|default(false)) and (app.user or app.session.get('is_test_mode')) %}

    <div class="{{ show_sidebar ? 'flex min-h-screen' : '' }}" {{ show_sidebar ? 'data-controller="sidebar"' : '' }}>
        {% if show_sidebar %}
            {% block sidebar %}
                {{ include('_sidebar.html.twig') }}
            {% endblock %}
        {% endif %}

        <div class="{{ show_sidebar ? 'flex-grow flex flex-col min-w-0' : '' }}">
            {% if show_sidebar %}
                {# Header Mobile #}
                <header class="lg:hidden bg-white border-b border-slate-200 h-16 flex items-center px-4 sticky top-0 z-[70]">
                    <button data-action="click->sidebar#toggle" class="p-2 text-slate-500 hover:text-djoliba">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
                    </button>
                    <div class="ml-4 flex items-center gap-2">
                        <div class="w-7 h-7 bg-djoliba rounded-md flex items-center justify-center text-white font-bold text-sm">D</div>
                        <span class="font-display font-bold text-lg text-djoliba">Djoliba</span>
                    </div>
                </header>
            {% endif %}

            <main class="flex-grow">
                {% block main %}{% endblock %}
                {% block content %}{% endblock %}
            </main>
        </div>
    </div>

    {% block footer %}
        <footer class="bg-white border-t border-slate-200 mt-auto">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
                <div class="flex justify-center items-center gap-2 mb-4">
                    <span class="font-display font-bold text-xl text-djoliba">Djoliba</span>
                </div>
                <p class="text-slate-400 text-sm">
                    &copy; {{ 'now'|date('Y') }} Djoliba. Tous droits réservés.
                </p>
            </div>
        </footer>
    {% endblock %}

    {# Global Premium Project Creation Modal #}
    <div id="project-create-modal" 
         data-controller="project-modal" 
         class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 transition-all duration-300 opacity-0 bg-slate-950/20 backdrop-blur-md">
        
        {# Backdrop Click to Close #}
        <div data-action="click->project-modal#close" class="absolute inset-0 cursor-default"></div>

        {# Modal Box #}
        <div data-project-modal-target="card" 
             style="max-width: 440px; width: 100%;"
             class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl transform scale-95 opacity-0 transition-all duration-300 ease-out z-10">
            
            {# Close Button #}
            <button type="button" data-action="click->project-modal#close" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>

            {# Modal Header #}
            <div class="mb-6">
                <h3 data-project-modal-target="title" class="text-2xl font-display font-bold text-djoliba">Créer un nouveau projet</h3>
                <p class="text-sm text-slate-400 mt-1">Saisissez les informations nécessaires pour démarrer.</p>
            </div>

            {# Form #}
            <form data-action="submit->project-modal#submit" class="space-y-6">
                <div>
                    <label for="project-name-input" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nom du projet</label>
                    <input id="project-name-input" 
                           type="text" 
                           data-project-modal-target="input" 
                           required 
                           placeholder="Ex: Énergies renouvelables au Sahel" 
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300">
                </div>

                <div data-project-modal-target="typeSection" class="space-y-3">
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Type d'analyse</label>
                    <input type="hidden" data-project-modal-target="typeInput" value="literature_review">
                    
                    <div class="grid grid-cols-2 gap-3">
                        {# Option 1: Literature Review #}
                        <div data-action="click->project-modal#selectType" data-type="literature_review" data-project-modal-target="typeCard" class="project-type-card active flex flex-col p-4 rounded-2xl border border-slate-200 cursor-pointer text-center select-none h-28 justify-center">
                            <span class="text-2xl mb-1">📚</span>
                            <span class="text-[11px] font-bold text-djoliba block leading-tight">Synthèse / Revue</span>
                        </div>
                        {# Option 2: Reading #}
                        <div data-action="click->project-modal#selectType" data-type="reading" data-project-modal-target="typeCard" class="project-type-card flex flex-col p-4 rounded-2xl border border-slate-200 cursor-pointer text-center select-none h-28 justify-center">
                            <span class="text-2xl mb-1">📖</span>
                            <span class="text-[11px] font-bold text-djoliba block leading-tight">Lecture / PDF</span>
                        </div>
                        {# Option 3: Writing #}
                        <div data-action="click->project-modal#selectType" data-type="writing" data-project-modal-target="typeCard" class="project-type-card flex flex-col p-4 rounded-2xl border border-slate-200 cursor-pointer text-center select-none h-28 justify-center">
                            <span class="text-2xl mb-1">✍️</span>
                            <span class="text-[11px] font-bold text-djoliba block leading-tight">Rédaction / Pub</span>
                        </div>
                        {# Option 4: Thesis #}
                        <div data-action="click->project-modal#selectType" data-type="thesis" data-project-modal-target="typeCard" class="project-type-card flex flex-col p-4 rounded-2xl border border-slate-200 cursor-pointer text-center select-none h-28 justify-center">
                            <span class="text-2xl mb-1">🎓</span>
                            <span class="text-[11px] font-bold text-djoliba block leading-tight">Thèse / Mémoire</span>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->project-modal#close" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" data-project-modal-target="submitBtn" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Créer le projet
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# Global Premium Research Project Creation Modal #}
    {% if app.user %}
    <div id="research-project-create-modal" 
         data-controller="research-project-modal" 
         class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 transition-all duration-300 opacity-0 bg-slate-950/20 backdrop-blur-md">
        
        {# Backdrop Click to Close #}
        <div data-action="click->research-project-modal#close" class="absolute inset-0 cursor-default"></div>

        {# Modal Box #}
        <div data-research-project-modal-target="card" 
             style="max-width: 440px; width: 100%;"
             class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl transform scale-95 opacity-0 transition-all duration-300 ease-out z-10">
            
            {# Close Button #}
            <button type="button" data-action="click->research-project-modal#close" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>

            {# Modal Header #}
            <div class="mb-6">
                <h3 class="text-2xl font-display font-bold text-djoliba">Nouveau projet de recherche</h3>
                <p class="text-sm text-slate-400 mt-1">Créez un conteneur pour vos revues, rédactions et lectures.</p>
            </div>

            {# Form #}
            <form data-action="submit->research-project-modal#submit" class="space-y-6">
                <div>
                    <label for="rp-name-input" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nom du projet de recherche</label>
                    <input id="rp-name-input" 
                           type="text" 
                           required 
                           data-research-project-modal-target="nameInput" 
                           placeholder="Ex: Thèse de doctorat en IA" 
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300">
                </div>
                <div>
                    <label for="rp-desc-input" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Description</label>
                    <textarea id="rp-desc-input" 
                              rows="3" 
                              data-research-project-modal-target="descInput" 
                              placeholder="Ex: Analyse de la littérature et modélisation des architectures multi-agents..." 
                              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300"></textarea>
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->research-project-modal#close" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" data-research-project-modal-target="submitBtn" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Créer
                    </button>
                </div>
            </form>
        </div>
    </div>
    {% endif %}

    {% block javascript %}{% endblock %}
</body>
</html>
