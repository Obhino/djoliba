{% set is_test = app.session.get('is_test_mode') and not app.user %}
{% set current_route = app.request.attributes.get('_route') %}
{% set current_path = app.request.pathinfo %}

{# Détermination des classes active/inactive pour éviter tout flash visuel au chargement/Turbo swap #}
{% set active_classes = 'bg-djoliba/10 text-djoliba border-djoliba' %}
{% set inactive_classes = 'text-slate-500 border-transparent hover:bg-slate-50 hover:text-djoliba hover:border-slate-100' %}

{% set is_literature_active = current_path == '/literature' %}
{% set is_reading_active = (current_path == '/reading' or '/reading' in current_path) %}
{% set is_synthesis_active = (current_path == '/synthesis' or '/synthesis' in current_path or ('/literature' in current_path and current_path != '/literature')) %}
{% set is_writing_active = (current_path == '/writing' or '/writing' in current_path) %}
{% set is_thesis_active = (current_path == '/thesis' or '/thesis' in current_path) %}

{# Overlay pour mobile #}
<div data-sidebar-target="overlay" data-action="click->sidebar#close" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-[80] lg:hidden hidden"></div>

<aside data-sidebar-target="menu" class="fixed inset-y-0 left-0 w-72 bg-white border-r border-slate-200 z-[90] transform -translate-x-full lg:translate-x-0 lg:static lg:h-screen transition-transform duration-300 ease-in-out flex flex-col">
    <!-- Logo -->
    <div class="h-20 flex items-center px-8 border-b border-slate-50">
        <a href="{{ path('app_hub') }}" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 bg-djoliba rounded-lg flex items-center justify-center text-white font-bold text-lg shadow-lg">D</div>
            <span class="font-display font-bold text-xl text-djoliba">Djoliba</span>
        </a>
        {# Bouton fermer sur mobile #}
        <button data-action="click->sidebar#close" class="ml-auto lg:hidden p-2 text-slate-400 hover:text-djoliba">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
    </div>

    <!-- Menu Principal -->
    <nav class="flex-grow p-6 space-y-1.5 overflow-y-auto">
        <div class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-4 pl-4">Recherche & Analyse</div>
        
        <a href="{{ path('app_literature_search') }}" data-sidebar-target="link" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold border-2 transition-all {{ is_literature_active ? active_classes : inactive_classes }}">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            Nouvelle recherche / PDF
        </a>

        {# Les entrées suivantes sont grisées en mode test #}
        {% set disabled_class = is_test ? 'opacity-40 grayscale pointer-events-none cursor-not-allowed' : '' %}

        {# Section Projets de Recherche parent #}
        {% if app.user %}
            {% set research_projects = get_user_research_projects() %}
            {% set active_rp = get_active_research_project() %}
            
            <div class="flex items-center justify-between mt-8 mb-4 pl-4 pr-2">
                <div class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em]">Projets de Recherche</div>
                <button data-action="click->sidebar#openResearchProjectModal" class="p-1 hover:bg-slate-100 rounded-lg text-slate-400 hover:text-djoliba transition-all" title="Nouveau projet de recherche">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                </button>
            </div>
            <div class="space-y-2 mb-6">
                {% for rp in research_projects %}
                    {% set is_rp_active = active_rp and active_rp.id == rp.id %}
                    <details class="bg-slate-50/50 rounded-xl border border-slate-100 overflow-hidden" {% if is_rp_active %}open{% endif %}>
                        <summary class="flex items-center justify-between px-4 py-3 cursor-pointer select-none hover:bg-slate-50/80 transition-all list-none">
                            <div class="flex items-center gap-2 min-w-0">
                                <span class="text-base flex-shrink-0">📁</span>
                                <span class="font-semibold text-xs text-djoliba truncate {{ is_rp_active ? 'font-bold' : '' }}">{{ rp.name }}</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                {% if is_rp_active %}
                                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" title="Projet de recherche actif"></span>
                                {% endif %}
                                <svg class="w-3 h-3 text-slate-400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </summary>
                        <div class="px-3 pb-3 pt-1 border-t border-slate-100/50 bg-white space-y-1">
                            {# Action de sélection / désélection active #}
                            <button data-action="click->sidebar#selectResearchProject" data-rp-id="{{ rp.id }}" class="w-full flex items-center justify-center gap-1.5 py-1.5 px-3 rounded-lg text-[10px] font-bold transition-all border {{ is_rp_active ? 'bg-emerald-500/10 text-emerald-700 border-emerald-500/20' : 'bg-slate-50 text-slate-600 border-slate-200 hover:bg-slate-100' }}">
                                {{ is_rp_active ? '✅ Projet actif' : '🎯 Rendre actif' }}
                            </button>

                            {% for project in rp.projects %}
                                {% if project.status != 'deleted' %}
                                    {% set proj_icon = '📄' %}
                                    {% if project.type == 'literature_review' %}{% set proj_icon = '📚' %}
                                    {% elseif project.type == 'reading' %}{% set proj_icon = '📖' %}
                                    {% elseif project.type == 'writing' %}{% set proj_icon = '✍️' %}
                                    {% elseif project.type == 'thesis' %}{% set proj_icon = '🎓' %}
                                    {% endif %}
                                    
                                    {% set project_path = '/project/' ~ project.id %}
                                    {% if project.type == 'literature_review' %}{% set project_path = '/project/' ~ project.id ~ '/literature' %}
                                    {% elseif project.type == 'reading' %}{% set project_path = '/project/' ~ project.id ~ '/reading' %}
                                    {% elseif project.type == 'writing' %}{% set project_path = '/project/' ~ project.id ~ '/writing' %}
                                    {% elseif project.type == 'thesis' %}{% set project_path = '/project/' ~ project.id ~ '/thesis' %}
                                    {% endif %}

                                    <a href="{{ project_path }}" class="flex items-center gap-2 px-3 py-2 rounded-lg text-xs font-medium text-slate-600 hover:bg-slate-50 hover:text-djoliba transition-all {{ current_path == project_path ? 'bg-djoliba/5 text-djoliba font-semibold' : '' }}">
                                        <span class="text-sm flex-shrink-0">{{ proj_icon }}</span>
                                        <span class="truncate">{{ project.name }}</span>
                                    </a>
                                {% endif %}
                            {% else %}
                                <div class="text-[10px] text-slate-400 text-center py-2">Aucun sous-projet</div>
                            {% endfor %}
                        </div>
                    </details>
                {% else %}
                    <div class="px-2">
                        <button data-action="click->sidebar#openResearchProjectModal" class="w-full text-left py-2 border-2 border-dashed border-slate-200 hover:border-djoliba hover:bg-slate-50 text-[11px] font-semibold text-slate-400 hover:text-djoliba rounded-xl transition-all flex items-center justify-center gap-1">
                            <span>+ Nouveau projet</span>
                        </button>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mt-8 mb-4 pl-4">Mes Hubs</div>

        <a href="{{ path('app_reading_hub') }}" data-sidebar-target="link" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold border-2 transition-all {{ disabled_class }} {{ is_reading_active ? active_classes : inactive_classes }}">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            Projets de lecture
        </a>

        <a href="{{ path('app_project_hub') }}" data-sidebar-target="link" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold border-2 transition-all {{ disabled_class }} {{ is_synthesis_active ? active_classes : inactive_classes }}">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
            Projets de synthèse
        </a>

        <a href="{{ path('app_writing_hub') }}" data-sidebar-target="link" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold border-2 transition-all {{ disabled_class }} {{ is_writing_active ? active_classes : inactive_classes }}">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            Projets d'écriture
        </a>

        <a href="{{ path('app_thesis_hub') }}" data-sidebar-target="link" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold border-2 transition-all {{ disabled_class }} {{ is_thesis_active ? active_classes : inactive_classes }}">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /></svg>
            Thèse / Mémoire
        </a>
    </nav>

    <!-- Bottom Account -->
    <div class="p-6 border-t border-slate-50">
        {% if app.user %}
            <div class="bg-slate-50 rounded-2xl p-4 flex items-center gap-3 w-full">
                <a href="{{ path('app_user_profile') }}" class="flex items-center gap-3 flex-grow min-w-0 group" title="Gérer mon profil chercheur">
                    <div class="w-10 h-10 rounded-full bg-djoliba flex items-center justify-center text-white font-bold text-xs group-hover:scale-105 transition-transform flex-shrink-0">
                        {{ (app.user.firstName ?: app.user.userIdentifier)|slice(0, 2)|upper }}
                    </div>
                    <div class="flex-grow min-w-0">
                        <div class="text-sm font-bold text-djoliba truncate group-hover:underline">{{ app.user.firstName ?: app.user.userIdentifier }}</div>
                        <div class="text-[10px] text-slate-400">Chercheur</div>
                    </div>
                </a>
                <a href="{{ path('app_logout') }}" class="text-slate-300 hover:text-red-500 transition-colors flex-shrink-0" title="Se déconnecter">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                </a>
            </div>
        {% else %}
            <a href="{{ path('app_login') }}" class="flex items-center justify-center gap-2 w-full py-3 bg-djoliba text-white rounded-xl text-sm font-bold shadow-lg hover:shadow-djoliba/20 transition-all">
                Se connecter
            </a>
        {% endif %}
    </div>
</aside>
