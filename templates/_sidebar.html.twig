{% set current_route = app.request.attributes.get('_route') %}
{% set current_path = app.request.pathinfo %}

{# Classes actives/inactives pour la navigation #}
{% set active_classes = 'bg-djoliba/10 text-djoliba border-djoliba' %}
{% set inactive_classes = 'text-slate-500 border-transparent hover:bg-slate-50 hover:text-djoliba hover:border-slate-100' %}

{# Variables globales du template via TwigExtension #}
{% set research_projects = get_user_research_projects() %}
{% set active_rp = get_active_research_project() %}
{% set counts = get_subproject_counts() %}

{# Détermination des chemins pour les hubs de sous-projets #}
{% set reading_path = active_rp ? '/research-project/' ~ active_rp.id ~ '/sub-projects/reading' : '/sub-projects/type/reading' %}
{% set literature_path = active_rp ? '/research-project/' ~ active_rp.id ~ '/sub-projects/literature' : '/sub-projects/type/literature' %}
{% set writing_path = active_rp ? '/research-project/' ~ active_rp.id ~ '/sub-projects/writing' : '/sub-projects/type/writing' %}
{% set thesis_path = active_rp ? '/research-project/' ~ active_rp.id ~ '/sub-projects/thesis' : '/sub-projects/type/thesis' %}

{# Overlay pour mobile #}
<div data-sidebar-target="overlay" data-action="click->sidebar#close" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-[80] lg:hidden hidden"></div>

<aside data-controller="sidebar" data-sidebar-target="menu" class="fixed inset-y-0 left-0 w-72 bg-white border-r border-slate-200 z-[90] transform -translate-x-full lg:translate-x-0 lg:static lg:h-screen transition-transform duration-300 ease-in-out flex flex-col">
    <!-- Logo -->
    <div class="h-20 flex items-center px-8 border-b border-slate-50">
        <a href="{{ path('app_hub') }}" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 bg-djoliba rounded-lg flex items-center justify-center text-white font-bold text-lg shadow-lg">D</div>
            <span class="font-display font-bold text-xl text-djoliba">Djoliba</span>
        </a>
        {# Bouton fermer sur mobile #}
        <button data-action="click->sidebar#close" class="ml-auto lg:hidden p-2 text-slate-400 hover:text-djoliba">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
    </div>

    <!-- Contenu Principal -->
    <nav class="flex-grow p-6 space-y-6 overflow-y-auto">
        
        <!-- Bouton Nouveau (Crée uniquement un projet de recherche) -->
        <div>
            <button type="button" data-action="click->sidebar#openResearchProjectModal" class="w-full flex items-center justify-center gap-2 py-3 bg-djoliba text-white rounded-xl text-sm font-bold shadow-lg shadow-djoliba/25 hover:bg-djoliba/95 transition-all">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Nouveau projet de recherche
            </button>
        </div>

        <!-- Section Projets de Recherche -->
        {% if app.user %}
            <div class="space-y-2">
                <div class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] pl-4">Projet Actif</div>
                
                <div class="relative">
                    <button type="button" data-action="click->sidebar#toggleProjectDropdown" class="w-full flex items-center justify-between px-4 py-3 rounded-xl border border-slate-200 bg-slate-50/50 hover:bg-slate-50 hover:border-slate-300 transition-all text-xs font-semibold text-slate-700">
                        <span class="truncate flex items-center gap-2">
                            {% if active_rp %}
                                <span class="w-2 h-2 rounded-full bg-emerald-500 flex-shrink-0 animate-pulse"></span>
                                {{ active_rp.name }}
                            {% else %}
                                <span class="w-2 h-2 rounded-full bg-slate-300 flex-shrink-0"></span>
                                Aucun projet actif
                            {% endif %}
                        </span>
                        <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    </button>
                    
                    <div data-sidebar-target="projectDropdown" class="hidden absolute left-0 right-0 mt-2 bg-white border border-slate-100 rounded-2xl shadow-xl z-50 py-2 max-h-60 overflow-y-auto">
                        {% if active_rp %}
                            <button type="button" data-action="click->sidebar#selectResearchProject" data-rp-id="{{ active_rp.id }}" data-is-active="true" class="w-full text-left px-4 py-2 text-xs font-bold text-red-500 hover:bg-slate-50 transition-colors flex items-center gap-2">
                                ❌ Désactiver le projet actif
                            </button>
                            <div class="border-t border-slate-50 my-1.5"></div>
                        {% endif %}
                        
                        {% for rp in research_projects %}
                            {% set is_rp_active = active_rp and active_rp.id == rp.id %}
                            <div class="flex items-center justify-between px-4 py-1.5 hover:bg-slate-50 group transition-colors {{ is_rp_active ? 'bg-djoliba/5 border-l-4 border-djoliba' : '' }}">
                                <a href="/research-project/{{ rp.id }}" class="flex-grow text-left text-xs font-semibold text-slate-700 hover:text-djoliba truncate pr-2">
                                    📁 {{ rp.name }}
                                </a>
                                <button type="button" data-action="click->sidebar#selectResearchProject" data-rp-id="{{ rp.id }}" data-is-active="{{ is_rp_active ? 'true' : 'false' }}" class="p-1 rounded hover:bg-slate-100 transition-colors {{ is_rp_active ? 'text-emerald-500' : 'text-slate-300 hover:text-emerald-500' }}" title="{{ is_rp_active ? 'Désactiver' : 'Activer' }}">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l5-5z" clip-rule="evenodd" /></svg>
                                </button>
                            </div>
                        {% else %}
                            <div class="text-[10px] text-slate-400 text-center py-2">Aucun projet de recherche</div>
                        {% endfor %}
                    </div>
                </div>
                
                {% if active_rp %}
                    <a href="/research-project/{{ active_rp.id }}" class="w-full flex items-center justify-center gap-1.5 py-2 px-4 rounded-xl text-[11px] font-bold text-slate-500 hover:text-djoliba bg-slate-50 hover:bg-slate-100 transition-all">
                        ⚙️ Gérer le projet actif
                    </a>
                {% endif %}
            </div>
        {% endif %}

        <!-- Section Sous-projets -->
        <div class="space-y-2">
            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] pl-4">Sous-projets</div>

            <a href="{{ reading_path }}" data-sidebar-target="link" class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-semibold border-2 transition-all {{ current_path == reading_path ? active_classes : inactive_classes }}">
                <div class="flex items-center gap-3">
                    <span class="text-base">📖</span>
                    <span>Lecture</span>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-slate-50 border border-slate-100 text-slate-600 text-[10px] font-extrabold">{{ counts.reading }}</span>
            </a>

            <a href="{{ literature_path }}" data-sidebar-target="link" class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-semibold border-2 transition-all {{ current_path == literature_path ? active_classes : inactive_classes }}">
                <div class="flex items-center gap-3">
                    <span class="text-base">📚</span>
                    <span>Synthèse</span>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-slate-50 border border-slate-100 text-slate-600 text-[10px] font-extrabold">{{ counts.literature }}</span>
            </a>

            <a href="{{ writing_path }}" data-sidebar-target="link" class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-semibold border-2 transition-all {{ current_path == writing_path ? active_classes : inactive_classes }}">
                <div class="flex items-center gap-3">
                    <span class="text-base">✍️</span>
                    <span>Écriture</span>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-slate-50 border border-slate-100 text-slate-600 text-[10px] font-extrabold">{{ counts.writing }}</span>
            </a>

            <a href="{{ thesis_path }}" data-sidebar-target="link" class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-semibold border-2 transition-all {{ current_path == thesis_path ? active_classes : inactive_classes }}">
                <div class="flex items-center gap-3">
                    <span class="text-base">🎓</span>
                    <span>Thèse</span>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-slate-50 border border-slate-100 text-slate-600 text-[10px] font-extrabold">{{ counts.thesis }}</span>
            </a>
        </div>
    </nav>

    <!-- Pied de Page / Compte Chercheur -->
    <div class="p-6 border-t border-slate-50">
        {% if app.user %}
            <div class="bg-slate-50 rounded-2xl p-4 flex items-center gap-3 w-full">
                <a href="{{ path('app_user_profile') }}" class="flex items-center gap-3 flex-grow min-w-0 group" title="Gérer mon profil chercheur">
                    <div class="w-10 h-10 rounded-full bg-djoliba flex items-center justify-center text-white font-bold text-xs group-hover:scale-105 transition-transform flex-shrink-0">
                        {{ (app.user.firstName ?: app.user.userIdentifier)|slice(0, 2)|upper }}
                    </div>
                    <div class="flex-grow min-w-0">
                        <div class="text-sm font-bold text-djoliba truncate group-hover:underline">{{ app.user.firstName ?: app.user.userIdentifier }}</div>
                        <div class="text-[10px] text-slate-400">Chercheur</div>
                    </div>
                </a>
                <a href="{{ path('app_logout') }}" class="text-slate-300 hover:text-red-500 transition-colors flex-shrink-0" title="Se déconnecter">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                </a>
            </div>
        {% else %}
            <a href="{{ path('app_login') }}" class="flex items-center justify-center gap-2 w-full py-3 bg-djoliba text-white rounded-xl text-sm font-bold shadow-lg hover:shadow-djoliba/20 transition-all">
                Se connecter
            </a>
        {% endif %}
    </div>
</aside>
