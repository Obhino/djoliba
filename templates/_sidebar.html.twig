{% set is_test = app.session.get('is_test_mode') and not app.user %}

<aside class="w-72 bg-white border-r border-slate-200 h-screen sticky top-0 hidden lg:flex flex-col" data-controller="sidebar">
    <!-- Logo -->
    <div class="h-20 flex items-center px-8 border-b border-slate-50">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-djoliba rounded-lg flex items-center justify-center text-white font-bold text-lg shadow-lg">D</div>
            <span class="font-display font-bold text-xl text-djoliba">Djoliba</span>
        </div>
    </div>

    <!-- Mode Test Indicator -->
    {% if is_test %}
    <div class="px-6 pt-4">
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></div>
            <div class="text-[10px] font-bold text-amber-700 uppercase tracking-wider">Mode Démonstration</div>
        </div>
    </div>
    {% endif %}

    <!-- Menu -->
    <nav class="flex-grow p-6 space-y-2">
        <div class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-4 pl-4">Menu Principal</div>
        
        <a href="{{ path('app_hub') }}" class="sidebar-link" data-sidebar-target="link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            Hub Central
        </a>

        {# Les entrées suivantes sont grisées en mode test #}
        {% set disabled_class = is_test ? 'opacity-40 grayscale pointer-events-none cursor-not-allowed' : '' %}

        <a href="{{ path('app_dashboard') }}" class="sidebar-link {{ disabled_class }}" data-sidebar-target="link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            Mes Projets
        </a>

        <a href="#" class="sidebar-link {{ disabled_class }}" data-sidebar-target="link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            Recherche
        </a>

        <a href="#" class="sidebar-link {{ disabled_class }}" data-sidebar-target="link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            Bibliothèque
        </a>

        <a href="#" class="sidebar-link {{ disabled_class }}" data-sidebar-target="link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            Rédaction
        </a>
    </nav>

    <!-- Appearance Settings (Quick Toggle) -->
    <div class="px-6 py-4 border-t border-slate-50" data-controller="appearance">
        <div class="flex items-center justify-between bg-slate-50 rounded-xl p-2">
            <!-- Thème -->
            <button data-action="click->appearance#toggleTheme" class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-white transition-all text-slate-500 hover:text-djoliba">
                <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707-.707"></path></svg>
                <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
            </button>
            
            <div class="h-4 w-px bg-slate-200"></div>

            <!-- Langue -->
            <div class="flex gap-1">
                <button data-action="click->appearance#switchLanguage" data-lang="fr" class="px-2 py-1 text-[10px] font-bold rounded-md transition-all hover:bg-white text-slate-400 hover:text-djoliba">FR</button>
                <button data-action="click->appearance#switchLanguage" data-lang="en" class="px-2 py-1 text-[10px] font-bold rounded-md transition-all hover:bg-white text-slate-400 hover:text-djoliba">EN</button>
            </div>
        </div>
    </div>

    <!-- Bottom Account -->
    <div class="p-6 border-t border-slate-50">
        {% if app.user %}
            <div class="bg-slate-50 rounded-2xl p-4 flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-djoliba flex items-center justify-center text-white font-bold text-xs">
                    {{ (app.user.firstName ?: app.user.userIdentifier)|slice(0, 2)|upper }}
                </div>
                <div class="flex-grow min-w-0">
                    <div class="text-sm font-bold text-djoliba truncate">{{ app.user.firstName ?: app.user.userIdentifier }}</div>
                    <div class="text-[10px] text-slate-400">Chercheur</div>
                </div>
                <a href="{{ path('app_logout') }}" class="text-slate-300 hover:text-red-500 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                </a>
            </div>
        {% else %}
            <div class="bg-slate-50 rounded-2xl p-4 flex flex-col gap-3">
                <div class="text-[10px] font-bold text-slate-400 uppercase">Utilisateur Anonyme</div>
                <a href="/login" class="text-xs font-bold text-djoliba hover:underline flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                    Se connecter
                </a>
            </div>
        {% endif %}
    </div>
</aside>
