{% extends 'base.html.twig' %}
{% set hide_sidebar = true %}

{% block title %}Inscription - Djoliba{% endblock %}

{% block content %}
<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-slate-50">
    <div class="max-w-md w-full space-y-8">
        <div class="text-center space-y-3">
            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2.5 hover:opacity-90 transition-opacity">
                <img src="{{ asset('images/logo-icon.png') }}" alt="Djoliba Search" class="h-12 w-auto object-contain drop-shadow-sm" />
                <span class="font-display font-black text-2xl tracking-tight text-[#0F2942]">DJOLIBA <span class="text-[#10B981] font-semibold">Search</span></span>
            </a>
            <h2 class="text-xl font-display font-bold text-slate-700">
                Rejoignez la plateforme
            </h2>
            <p class="text-sm text-slate-500">
                Déjà un compte ? <a href="{{ path('app_login') }}" class="font-medium text-[#10B981] hover:underline transition-colors">Connectez-vous</a>
            </p>
        </div>

        <form class="mt-8 space-y-6" method="post">
            <div class="rounded-2xl bg-white shadow-sm border border-slate-100 p-8 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="firstName" class="block text-sm font-medium text-slate-700 mb-1">Prénom</label>
                        <input id="firstName" name="firstName" type="text" required
                            class="appearance-none block w-full px-3 py-3 border border-slate-200 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-emerald_ia focus:border-emerald_ia sm:text-sm transition-all">
                    </div>
                    <div>
                        <label for="lastName" class="block text-sm font-medium text-slate-700 mb-1">Nom</label>
                        <input id="lastName" name="lastName" type="text" required
                            class="appearance-none block w-full px-3 py-3 border border-slate-200 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-emerald_ia focus:border-emerald_ia sm:text-sm transition-all">
                    </div>
                </div>

                <div>
                    <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Adresse email</label>
                    <input id="email" name="email" type="email" autocomplete="email" required
                        class="appearance-none block w-full px-3 py-3 border border-slate-200 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-emerald_ia focus:border-emerald_ia sm:text-sm transition-all"
                        placeholder="chercheur@universite.com">
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Mot de passe</label>
                    <input id="password" name="password" type="password" required
                        class="appearance-none block w-full px-3 py-3 border border-slate-200 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-emerald_ia focus:border-emerald_ia sm:text-sm transition-all"
                        placeholder="••••••••">
                </div>

                <div>
                    <label for="password_confirm" class="block text-sm font-medium text-slate-700 mb-1">Confirmer le mot de passe</label>
                    <input id="password_confirm" name="password_confirm" type="password" required
                        class="appearance-none block w-full px-3 py-3 border border-slate-200 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-emerald_ia focus:border-emerald_ia sm:text-sm transition-all"
                        placeholder="••••••••">
                </div>

                <div class="flex items-center pt-2">
                    <input id="terms" name="terms" type="checkbox" required
                        class="h-4 w-4 text-emerald_ia focus:ring-emerald_ia border-slate-300 rounded">
                    <label for="terms" class="ml-2 block text-sm text-slate-600">
                        J'accepte les <a href="#" class="text-djoliba hover:underline">conditions d'utilisation</a>
                    </label>
                </div>

                <div class="pt-4">
                    <button type="submit"
                        class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-djoliba hover:bg-opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-djoliba shadow-lg transition-all transform hover:-translate-y-0.5">
                        Créer mon compte
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}
