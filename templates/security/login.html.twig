{% extends 'base.html.twig' %}
{% set hide_sidebar = true %}

{% block title %}Connexion - Djoliba{% endblock %}

{% block content %}
<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-slate-50">
    <div class="max-w-md w-full space-y-8">
        <div>
            <div class="mx-auto h-12 w-12 bg-djoliba rounded-xl flex items-center justify-center text-white font-bold text-2xl shadow-lg">D</div>
            <h2 class="mt-6 text-center text-3xl font-display font-extrabold text-djoliba">
                Bon retour parmi nous
            </h2>
            <p class="mt-2 text-center text-sm text-slate-500">
                Ou <a href="{{ path('app_register') }}" class="font-medium text-emerald_ia hover:text-emerald-600 transition-colors">créez un compte gratuitement</a>
            </p>
        </div>

        {% if error %}
            <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-md">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-red-700">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </p>
                    </div>
                </div>
            </div>
        {% endif %}

        <form class="mt-8 space-y-6" method="post">
            <div class="rounded-2xl bg-white shadow-sm border border-slate-100 p-8 space-y-4">
                <div>
                    <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Adresse email</label>
                    <input id="email" name="_username" type="email" autocomplete="email" required value="{{ last_username }}"
                        class="appearance-none block w-full px-3 py-3 border border-slate-200 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-emerald_ia focus:border-emerald_ia sm:text-sm transition-all"
                        placeholder="nom@exemple.com">
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Mot de passe</label>
                    <input id="password" name="_password" type="password" autocomplete="current-password" required
                        class="appearance-none block w-full px-3 py-3 border border-slate-200 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-emerald_ia focus:border-emerald_ia sm:text-sm transition-all"
                        placeholder="••••••••">
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="flex items-center justify-between pt-2">
                    <div class="flex items-center">
                        <input id="remember_me" name="_remember_me" type="checkbox"
                            class="h-4 w-4 text-djoliba focus:ring-djoliba border-slate-300 rounded">
                        <label for="remember_me" class="ml-2 block text-sm text-slate-600">Se souvenir de moi</label>
                    </div>

                    <div class="text-sm">
                        <a href="#" class="font-medium text-slate-500 hover:text-djoliba">Mot de passe oublié ?</a>
                    </div>
                </div>

                <div class="pt-4">
                    <button type="submit"
                        class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-djoliba hover:bg-opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-djoliba shadow-lg transition-all transform hover:-translate-y-0.5">
                        Se connecter
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}
