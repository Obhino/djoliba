{% extends 'base.html.twig' %}
{% set hide_sidebar = true %}

{% block title %}Djoliba - Plateforme Autonome de Recherche{% endblock %}

{% block content %}
<div class="relative overflow-hidden bg-white">
    {# Barre de navigation #}
    <nav class="absolute top-0 left-0 right-0 z-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-24">
                <a href="{{ path('app_home') }}" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
                    <img src="{{ asset('images/logo.svg') }}" alt="Djoliba Search" class="h-10 w-auto object-contain" />
                    <div class="flex flex-col">
                        <span class="font-display font-extrabold text-xl leading-none text-[#0F2942]">DJOLIBA <span class="text-[#10B981] font-semibold">Search</span></span>
                        <span class="text-[11px] text-slate-400 font-medium tracking-tight mt-0.5">La 1ère plateforme autonome de recherche</span>
                    </div>
                </a>
                <div class="hidden sm:flex items-center gap-6">
                    <a href="{{ path('app_login') }}" class="text-sm font-semibold text-slate-600 hover:text-djoliba transition-colors">Se connecter</a>
                    <a href="{{ path('app_register') }}" class="px-5 py-2.5 bg-djoliba text-white text-sm font-bold rounded-full hover:bg-djoliba/90 transition-all shadow-md">S'inscrire</a>
                </div>
            </div>
        </div>
    </nav>

    {# Arrière-plan décoratif #}
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%230B2545\' fill-opacity=\'0.03\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')] opacity-50"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-24 text-center lg:pt-44 lg:pb-32">
        <!-- Logo Hero (Vectoriel logo.svg + Texte HTML/CSS) -->
        <div class="mb-8 flex flex-col items-center justify-center gap-3">
            <img src="{{ asset('images/logo.svg') }}" alt="Djoliba Search Logo" class="h-20 sm:h-24 w-auto object-contain drop-shadow-md hover:scale-105 transition-transform duration-300" />
            <div class="flex flex-col items-center">
                <span class="font-display font-black text-3xl sm:text-4xl tracking-tight text-[#0F2942]">DJOLIBA <span class="text-[#10B981] font-semibold">Search</span></span>
                <span class="text-xs sm:text-sm text-slate-500 font-medium tracking-wide mt-1">La 1ère plateforme autonome de recherche scientifique en Afrique</span>
            </div>
        </div>

        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 text-djoliba text-sm font-medium mb-8 border border-slate-200 shadow-sm">
            <span class="flex h-2 w-2 rounded-full bg-emerald_ia animate-pulse"></span>
            Lancement de la phase bêta
        </div>
        
        <h1 class="mx-auto max-w-4xl font-display text-5xl font-bold tracking-tight text-djoliba sm:text-7xl mb-8">
            Recherche académique, <span class="text-emerald_ia">augmentée par l'IA.</span>
        </h1>
        
        <p class="mx-auto max-w-2xl text-lg text-slate-600 mb-10 leading-relaxed">
            Djoliba Search vous accompagne de la revue de littérature à la rédaction finale. Analysez vos documents, structurez vos idées et rédigez plus rapidement grâce à notre IA spécialisée.
        </p>
        
        <div class="flex justify-center items-center gap-4 flex-col sm:flex-row flex-wrap">
            <a href="{{ path('app_test_mode_enable') }}" class="group relative inline-flex items-center justify-center gap-2 rounded-full bg-djoliba px-8 py-4 text-sm font-semibold text-white transition-all hover:opacity-90 hover:shadow-xl hover:shadow-djoliba/30 focus:outline-none w-full sm:w-auto">
                Tester Djoliba
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
            </a>
        </div>
    </div>
</div>
{% endblock %}
