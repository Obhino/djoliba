{% extends 'base.html.twig' %}

{% block title %}Ma Bibliothèque de Références - Djoliba{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8" data-controller="bibliography-manager">
    
    <!-- Messages Flash -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="p-4 rounded-xl border {{ label == 'success' ? 'bg-emerald-50 border-emerald-200 text-emerald-800' : 'bg-rose-50 border-rose-200 text-rose-800' }} flex items-center justify-between">
                <span class="text-sm font-semibold">{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- En-tête (Header) -->
    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div class="space-y-2 max-w-2xl">
            <div class="flex items-center gap-3">
                <span class="text-3xl">🔖</span>
                <h1 class="text-3xl font-display font-bold text-djoliba">Ma Bibliothèque</h1>
                <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-djoliba/10 text-djoliba border border-djoliba/20">
                    {{ references|length }} Référence(s)
                </span>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed">Gérez vos références bibliographiques personnelles et utilisez-les sur l'ensemble de vos projets.</p>
        </div>

        <div class="flex flex-wrap gap-3">
            <a href="{{ path('app_bibliography_export') }}" class="px-5 py-2.5 rounded-xl border border-slate-200 hover:bg-slate-50 text-slate-600 font-bold text-xs transition-all flex items-center gap-2">
                📤 Exporter en BibTeX (.bib)
            </a>
            <button type="button" data-action="click->bibliography-manager#openImportModal" class="px-5 py-2.5 rounded-xl border border-slate-200 hover:bg-slate-50 text-slate-600 font-bold text-xs transition-all flex items-center gap-2">
                📥 Importer un fichier BibTeX (.bib)
            </button>
            <button type="button" data-action="click->bibliography-manager#openAddModal" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/95 text-white font-bold text-xs shadow-lg shadow-djoliba/25 transition-all flex items-center gap-2">
                ➕ Ajouter une référence
            </button>
        </div>
    </div>

    <!-- Barre de filtres et recherche -->
    <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm flex flex-col md:flex-row justify-between items-stretch md:items-center gap-4">
        <form action="{{ path('app_bibliography_dashboard') }}" method="GET" class="flex-grow flex flex-col md:flex-row gap-3">
            <div class="relative flex-grow">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input type="text" name="q" value="{{ current_query }}" placeholder="Rechercher par titre, auteur, journal ou clé de citation..." class="w-full pl-11 pr-4 py-3 rounded-2xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm font-semibold text-djoliba">
            </div>
            
            <div class="flex gap-3">
                <select name="type" class="px-4 py-3 rounded-2xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm font-semibold text-slate-600 bg-white">
                    <option value="">Tous les types</option>
                    {% for type in entry_types %}
                        <option value="{{ type }}" {{ current_type == type ? 'selected' : '' }}>{{ type|capitalize }}</option>
                    {% endfor %}
                </select>

                <button type="submit" class="px-6 py-3 rounded-2xl bg-slate-900 text-white font-bold text-xs hover:bg-slate-800 transition-colors">
                    Rechercher
                </button>
                {% if current_query or current_type %}
                    <a href="{{ path('app_bibliography_dashboard') }}" class="px-6 py-3 rounded-2xl border border-slate-200 hover:bg-slate-50 text-slate-500 font-bold text-xs transition-colors flex items-center justify-center">
                        Réinitialiser
                    </a>
                {% endif %}
            </div>
        </form>
    </div>

    <!-- Tableau de références -->
    <div class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Clé / Type</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Auteurs / Année</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Titre</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Journal / Revue</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">DOI</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm text-slate-700 font-medium">
                    {% for ref in references %}
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4 space-y-1">
                                <div class="font-mono text-xs font-bold text-amber-700 bg-amber-50 px-2 py-0.5 rounded border border-amber-200/50 w-fit">
                                    {{ ref.citeKey }}
                                </div>
                                <div class="text-[10px] uppercase font-bold text-slate-400">
                                    {{ ref.entryType }}
                                </div>
                            </td>
                            <td class="px-6 py-4 space-y-1">
                                <div class="font-semibold text-slate-800 line-clamp-1" title="{{ ref.authors }}">
                                    {{ ref.authors ?: 'Auteur inconnu' }}
                                </div>
                                <div class="text-xs text-slate-400">
                                    {{ ref.year ?: 'N.D.' }}
                                </div>
                            </td>
                            <td class="px-6 py-4 max-w-xs md:max-w-md">
                                <div class="text-slate-800 line-clamp-2" title="{{ ref.title }}">
                                    {{ ref.title ?: 'Sans titre' }}
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-slate-500 line-clamp-1" title="{{ ref.journal }}">
                                    {{ ref.journal ?: 'N.D.' }}
                                </div>
                            </td>
                            <td class="px-6 py-4 font-mono text-xs text-slate-400">
                                {{ ref.doi ?: 'N.D.' }}
                            </td>
                            <td class="px-6 py-4 text-right">
                                <form action="{{ path('app_bibliography_delete', {id: ref.id}) }}" method="POST" onsubmit="return confirm('Voulez-vous vraiment supprimer cette référence de votre bibliothèque ?');">
                                    <button type="submit" class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all" title="Supprimer définitivement">
                                        🗑️
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-16 text-center text-slate-400">
                                <span class="text-4xl">🔖</span>
                                <h3 class="font-bold text-slate-700 mt-4">Aucune référence trouvée</h3>
                                <p class="text-xs mt-1 max-w-sm mx-auto">Ajoutez manuellement ou importez un fichier BibTeX pour commencer à construire votre bibliothèque.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modale 1 : Ajouter Manuellement / DOI -->
    <div data-bibliography-manager-target="addModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
        <div data-action="click->bibliography-manager#closeAddModal" class="absolute inset-0 cursor-default"></div>
        <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-lg z-10 transform scale-95 opacity-0 transition-all duration-300 max-h-[90vh] overflow-y-auto custom-scrollbar">
            <button type="button" data-action="click->bibliography-manager#closeAddModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            <div class="mb-6">
                <h3 class="text-2xl font-display font-bold text-djoliba">Ajouter une référence</h3>
                <p class="text-sm text-slate-400 mt-1">Saisissez les informations ou utilisez un DOI pour pré-remplir le formulaire.</p>
            </div>

            <!-- Résolveur DOI -->
            <div class="bg-slate-50 rounded-2xl p-4 mb-6 border border-slate-100 space-y-2">
                <label for="doi-resolver-field" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Résoudre depuis un DOI (Crossref)</label>
                <div class="flex gap-2">
                    <input type="text" id="doi-resolver-field" data-bibliography-manager-target="doiInput" placeholder="Ex: 10.1038/nature12345" class="flex-grow px-3 py-2 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                    <button type="button" data-action="click->bibliography-manager#resolveDoi" class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-xl hover:bg-slate-800 transition-colors">
                        Résoudre
                    </button>
                </div>
                <div data-bibliography-manager-target="doiStatus" class="text-[10px] text-slate-400 italic">Saisissez un DOI pour remplir automatiquement les champs ci-dessous.</div>
            </div>

            <form action="{{ path('app_bibliography_add') }}" method="POST" class="space-y-4">
                <div class="grid grid-cols-3 gap-3">
                    <div class="col-span-2">
                        <label for="ref-citekey" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Clé de citation (Cite Key)</label>
                        <input type="text" id="ref-citekey" name="citeKey" data-bibliography-manager-target="citeKeyInput" required placeholder="Ex: Smith2026" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba font-mono text-amber-700 font-bold">
                    </div>
                    <div>
                        <label for="ref-type" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Type</label>
                        <select id="ref-type" name="entryType" required class="w-full px-3 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba bg-white font-semibold text-slate-600">
                            <option value="article">Article</option>
                            <option value="book">Livre</option>
                            <option value="inproceedings">Conférence</option>
                            <option value="thesis">Thèse</option>
                            <option value="misc" selected>Autre (Misc)</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label for="ref-title" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Titre</label>
                    <textarea id="ref-title" name="title" rows="2" data-bibliography-manager-target="titleInput" required placeholder="Titre de la publication" class="w-full px-4 py-2 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba"></textarea>
                </div>

                <div>
                    <label for="ref-authors" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Auteurs (Séparés par "and")</label>
                    <input type="text" id="ref-authors" name="authors" data-bibliography-manager-target="authorsInput" placeholder="Ex: Doe, John and Smith, Jane" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                </div>

                <div class="grid grid-cols-3 gap-3">
                    <div class="col-span-2">
                        <label for="ref-journal" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Journal / Revue / Éditeur</label>
                        <input type="text" id="ref-journal" name="journal" data-bibliography-manager-target="journalInput" placeholder="Revue ou éditeur" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                    </div>
                    <div>
                        <label for="ref-year" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Année</label>
                        <input type="text" id="ref-year" name="year" data-bibliography-manager-target="yearInput" placeholder="Ex: 2026" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label for="ref-doi" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">DOI</label>
                        <input type="text" id="ref-doi" name="doi" placeholder="DOI de l'article" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                    </div>
                    <div>
                        <label for="ref-publisher" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Maison d'édition</label>
                        <input type="text" id="ref-publisher" data-bibliography-manager-target="publisherInput" placeholder="Éditeur optionnel" class="w-full px-4 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba">
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->bibliography-manager#closeAddModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Ajouter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modale 2 : Importer fichier BibTeX -->
    <div data-bibliography-manager-target="importModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
        <div data-action="click->bibliography-manager#closeImportModal" class="absolute inset-0 cursor-default"></div>
        <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-md z-10 transform scale-95 opacity-0 transition-all duration-300">
            <button type="button" data-action="click->bibliography-manager#closeImportModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            <div class="mb-6">
                <h3 class="text-2xl font-display font-bold text-djoliba">Importer du BibTeX</h3>
                <p class="text-sm text-slate-400 mt-1">Uploadez un fichier .bib ou collez directement du texte brut BibTeX.</p>
            </div>
            
            <form action="{{ path('app_bibliography_import') }}" method="POST" enctype="multipart/form-data" class="space-y-6">
                <div data-controller="bibliography-file-input">
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Fichier BibTeX (.bib)</label>
                    <div class="flex items-center gap-3">
                        <button type="button" data-action="click->bibliography-file-input#triggerSelect" class="px-4 py-2.5 bg-slate-50 border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-100 text-xs font-bold flex items-center gap-1.5 transition-all shadow-sm">
                            📁 Choisir un fichier
                        </button>
                        <span data-bibliography-file-input-target="filename" class="text-xs text-slate-400 font-semibold italic truncate">Aucun fichier sélectionné</span>
                    </div>
                    <input type="file" id="bib-file-field" name="bib_file" accept=".bib" data-bibliography-file-input-target="input" data-action="change->bibliography-file-input#onFileSelect" class="hidden">
                </div>

                <div class="relative flex py-2 items-center">
                    <div class="flex-grow border-t border-slate-200"></div>
                    <span class="flex-shrink mx-4 text-slate-400 text-xs font-bold uppercase tracking-wider">OU</span>
                    <div class="flex-grow border-t border-slate-200"></div>
                </div>

                <div>
                    <label for="bib-content-field" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Coller le contenu brut BibTeX</label>
                    <textarea id="bib-content-field" name="bib_content" rows="6" placeholder="@article{key, ...}" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba font-mono text-xs leading-relaxed"></textarea>
                </div>

                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->bibliography-manager#closeImportModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Importer
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>
{% endblock %}
