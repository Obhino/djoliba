{% extends 'base.html.twig' %}

{% block title %}Djoliba - La 1ère plateforme autonome de recherche{% endblock %}

{% block content %}
<div class="relative overflow-hidden bg-white">
    {# Arrière-plan décoratif #}
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%230B2545\' fill-opacity=\'0.03\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')] opacity-50"></div>
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-djoliba/5 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-float"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-emerald_ia/5 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-float" style="animation-delay: 2s;"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-24 text-center lg:pt-48 lg:pb-32">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 text-djoliba text-sm font-medium mb-8 border border-slate-200 shadow-sm">
            <span class="flex h-2 w-2 rounded-full bg-emerald_ia animate-pulse"></span>
            Lancement de la phase bêta gratuite
        </div>
        
        <h1 class="mx-auto max-w-4xl font-display text-5xl font-bold tracking-tight text-djoliba sm:text-7xl mb-8">
            Recherche académique, <span class="text-emerald_ia">augmentée par l'IA.</span>
        </h1>
        
        <p class="mx-auto max-w-2xl text-lg text-slate-600 mb-10 leading-relaxed">
            Djoliba Search vous accompagne de la revue de littérature à la rédaction finale. Analysez vos documents, structurez vos idées et rédigez plus rapidement grâce à notre IA spécialisée pour l'Afrique.
        </p>
        
        <div class="flex justify-center gap-4 flex-col sm:flex-row">
            <a href="/register" class="group relative inline-flex items-center justify-center gap-2 rounded-full bg-djoliba px-8 py-4 text-sm font-semibold text-white transition-all hover:opacity-90 hover:shadow-xl hover:shadow-djoliba/30 focus:outline-none">
                Commencer gratuitement
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
            </a>
            <a href="{{ path('app_test_mode_toggle') }}" class="inline-flex items-center justify-center gap-2 rounded-full bg-white border border-slate-200 px-8 py-4 text-sm font-semibold text-slate-700 transition-all hover:bg-slate-50 hover:text-djoliba hover:border-djoliba/20 focus:outline-none shadow-sm">
                Tester sans compte (Démo)
            </a>
        </div>
    </div>
</div>

{# Section Fonctionnalités #}
<div id="features" class="py-24 bg-slate-50 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-emerald_ia font-semibold tracking-wide uppercase text-sm mb-3">La Suite Complète</h2>
            <h3 class="font-display text-3xl font-bold text-djoliba sm:text-4xl">Tout ce dont un chercheur a besoin</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {# Feature 1 #}
            <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
                <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center text-djoliba mb-6">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                </div>
                <h4 class="text-xl font-bold text-djoliba mb-3 font-display">Revue de Littérature</h4>
                <p class="text-slate-500 leading-relaxed">Trouvez les articles pertinents, analysez les tendances et identifiez les lacunes de recherche en quelques minutes.</p>
            </div>

            {# Feature 2 #}
            <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
                <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald_ia mb-6">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                </div>
                <h4 class="text-xl font-bold text-djoliba mb-3 font-display">Chat avec PDF</h4>
                <p class="text-slate-500 leading-relaxed">Uploadez vos articles et posez-leur des questions directement. L'IA extrait, synthétise et cite les sources.</p>
            </div>

            {# Feature 3 #}
            <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
                <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center text-gold_prestige mb-6">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </div>
                <h4 class="text-xl font-bold text-djoliba mb-3 font-display">Aide à la Rédaction</h4>
                <p class="text-slate-500 leading-relaxed">Structurez vos chapitres, vérifiez la cohérence et obtenez des suggestions d'amélioration stylistique.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
