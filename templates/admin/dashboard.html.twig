{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Tableau de Bord - Statistiques Globales{% endblock %}

{% block main %}
    <div class="row">
        <!-- Cartes de statistiques -->
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card shadow-sm border-0 bg-primary text-white" style="background: linear-gradient(135deg, #4f46e5, #6366f1) !important;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="card-subtitle text-white-50">Utilisateurs Actifs</h6>
                        <h2 class="card-title mb-0 font-weight-bold" style="font-size: 2.5rem; margin-top: 5px;">{{ stats.activeUsers }}</h2>
                    </div>
                    <div style="font-size: 3rem; opacity: 0.3;">
                        <i class="fa fa-users"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card shadow-sm border-0 bg-success text-white" style="background: linear-gradient(135deg, #10b981, #34d399) !important;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="card-subtitle text-white-50">Total Projets</h6>
                        <h2 class="card-title mb-0 font-weight-bold" style="font-size: 2.5rem; margin-top: 5px;">{{ stats.totalProjects }}</h2>
                    </div>
                    <div style="font-size: 3rem; opacity: 0.3;">
                        <i class="fa fa-folder-open"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card shadow-sm border-0 bg-info text-white" style="background: linear-gradient(135deg, #06b6d4, #22d3ee) !important;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="card-subtitle text-white-50">Requêtes IA</h6>
                        <h2 class="card-title mb-0 font-weight-bold" style="font-size: 2.5rem; margin-top: 5px;">{{ stats.totalIaQueries }}</h2>
                    </div>
                    <div style="font-size: 3rem; opacity: 0.3;">
                        <i class="fa fa-robot"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card shadow-sm border-0 bg-warning text-white" style="background: linear-gradient(135deg, #f59e0b, #fbbf24) !important;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="card-subtitle text-white-50">Taux File d'Emails</h6>
                        <h2 class="card-title mb-0 font-weight-bold" style="font-size: 2.5rem; margin-top: 5px;">{{ stats.emailSuccessRate }}%</h2>
                    </div>
                    <div style="font-size: 3rem; opacity: 0.3;">
                        <i class="fa fa-envelope"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Instructions / Diagnostics panel -->
    <div class="card shadow-sm border-0 mt-4" style="border-radius: 12px;">
        <div class="card-header bg-white border-0 py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
            <h5 class="card-title mb-0 font-weight-bold" style="color: #1e293b;">Diagnostics Système & Administration</h5>
        </div>
        <div class="card-body">
            <p>Bienvenue dans l'interface d'administration de <strong>Djoliba Search</strong>.</p>
            <p class="text-muted">Utilisez le menu latéral pour naviguer entre les différentes sections de l'administration. Toutes vos actions en tant qu'administrateur sont consignées et loguées pour des raisons de sécurité.</p>
            <div class="alert alert-info border-0 shadow-sm d-flex align-items-center" style="border-radius: 8px; background-color: #f0f9ff; color: #0369a1;">
                <i class="fa fa-shield-alt mr-3 fa-2x" style="margin-right: 15px;"></i>
                <div>
                    <strong>Sécurité 2FA Activée</strong> : L'accès à ce tableau de bord est protégé par double authentification TOTP.
                </div>
            </div>
        </div>
    </div>
{% endblock %}
