{% extends 'base.html.twig' %}

{% block title %}Nouvelle Recherche - Djoliba{% endblock %}

{% block content %}
<div class="p-8">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-display font-bold text-djoliba mb-2">Nouvelle Recherche / PDF</h1>
        <p class="text-slate-500 mb-8">Commencez une nouvelle exploration de littérature ou analysez un document PDF.</p>
        
        <div data-controller="literature-upload" class="relative">
            <input type="file" 
                   data-literature-upload-target="fileInput" 
                   data-action="change->literature-upload#onFileSelect" 
                   class="hidden" 
                   accept=".pdf">

            <div data-literature-upload-target="dropzone"
                 data-action="dragenter->literature-upload#onDragOver dragover->literature-upload#onDragOver dragleave->literature-upload#onDragLeave drop->literature-upload#onDrop click->literature-upload#triggerSelect"
                 class="bg-white rounded-3xl p-12 border-2 border-dashed border-slate-200 text-center hover:border-djoliba transition-all group cursor-pointer relative overflow-hidden shadow-sm">
                
                {# Barre de progression gradient premium #}
                <div class="absolute top-0 left-0 w-full h-1.5 bg-slate-50 hidden" data-literature-upload-target="progressContainer">
                    <div class="h-full bg-gradient-to-r from-djoliba to-emerald_ia w-0 transition-all duration-300" data-literature-upload-target="progressBar"></div>
                </div>

                <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-6 transition-colors">
                    <svg class="w-8 h-8 text-djoliba transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
                </div>
                
                <h2 class="text-xl font-bold text-djoliba mb-2">Glissez votre PDF ici</h2>
                <p class="text-slate-400 mb-8">Ou cliquez pour parcourir vos fichiers</p>
                <button class="px-8 py-3 bg-djoliba text-white rounded-xl font-bold shadow-lg shadow-djoliba/20 hover:-translate-y-0.5 transition-all">Parcourir les fichiers</button>

                {# Texte indicateur de statut #}
                <p class="text-xs text-slate-500 mt-6 font-semibold hidden animate-pulse" data-literature-upload-target="statusText"></p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
