{% extends 'base.html.twig' %}

{% block title %}Nouvelle Recherche - Djoliba{% endblock %}

{% block content %}
<div class="p-8">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-display font-bold text-djoliba mb-2">Nouvelle Recherche / PDF</h1>
        <p class="text-slate-500 mb-8">Commencez une nouvelle exploration de littérature ou analysez un document PDF.</p>
        
        <div class="bg-white rounded-3xl p-12 border-2 border-dashed border-slate-200 text-center hover:border-djoliba transition-colors group">
            <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-6 transition-colors">
                <svg class="w-8 h-8 text-djoliba transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
            </div>
            <h2 class="text-xl font-bold text-djoliba mb-2">Glissez votre PDF ici</h2>
            <p class="text-slate-400 mb-8">Ou cliquez pour parcourir vos fichiers</p>
            <button class="px-8 py-3 bg-djoliba text-white rounded-xl font-bold shadow-lg shadow-djoliba/20 hover:-translate-y-0.5 transition-all">Parcourir les fichiers</button>
        </div>
    </div>
</div>
{% endblock %}
