<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ project.name }}</title>
    <style>
        @page {
            margin: 2.5cm;
            @bottom-right {
                content: counter(page);
            }
        }
        body {
            font-family: 'DejaVu Sans', sans-serif;
            font-size: 11pt;
            line-height: 1.6;
            color: #1a1a1a;
        }
        .header {
            text-align: right;
            font-size: 8pt;
            color: #666;
            border-bottom: 1px solid #ccc;
            padding-bottom: 5px;
            margin-bottom: 20px;
        }
        .title-block {
            margin-bottom: 40px;
        }
        .title {
            font-size: 24pt;
            font-weight: bold;
            color: #0B2545;
            margin-bottom: 10px;
        }
        .metadata {
            font-size: 9pt;
            color: #555;
            margin-bottom: 20px;
        }
        .content {
            text-align: justify;
        }
        /* Style standard pour les éléments Tiptap dans le PDF */
        h1, h2, h3, h4 {
            color: #0B2545;
            font-weight: bold;
            page-break-after: avoid;
        }
        h1 { font-size: 18pt; margin-top: 1.5cm; border-bottom: 1px solid #eee; padding-bottom: 5px; }
        h2 { font-size: 14pt; margin-top: 1.2cm; }
        h3 { font-size: 12pt; margin-top: 1cm; }
        p { margin-bottom: 15px; }
        pre, code {
            font-family: monospace;
            background-color: #f5f5f5;
            padding: 2px 4px;
            font-size: 9pt;
        }
        pre {
            padding: 10px;
            border-left: 3px solid #ccc;
            display: block;
            margin: 15px 0;
            white-space: pre-wrap;
        }
        blockquote {
            margin: 15px 0;
            padding-left: 15px;
            border-left: 4px solid #ccc;
            color: #555;
            font-style: italic;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            font-size: 9pt;
        }
        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }
        th {
            background-color: #f9f9f9;
            font-weight: bold;
        }
        img {
            max-width: 100%;
            height: auto;
            margin: 15px 0;
            display: block;
        }
        .footer {
            position: fixed;
            bottom: -1.5cm;
            left: 0;
            right: 0;
            height: 1cm;
            text-align: center;
            font-size: 8pt;
            color: #999;
            border-top: 1px solid #eee;
            padding-top: 5px;
        }
        /* Style des annotations */
        .djoliba-annotation {
            background-color: #fef3c7;
            border-bottom: 1px solid #d97706;
        }
        /* Style de la bibliographie */
        .bibliography-section {
            margin-top: 2cm;
            border-top: 1px solid #ccc;
            padding-top: 15px;
            page-break-before: always;
        }
        .bibliography-section h2 {
            font-size: 16pt;
            margin-bottom: 20px;
        }
        .bibliography-section ul {
            list-style-type: none;
            padding-left: 0;
        }
        .bibliography-section li {
            margin-bottom: 12px;
            padding-left: 30px;
            text-indent: -30px;
            text-align: justify;
            font-size: 10pt;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <div class="header">
        Djoliba Search - Éditeur Scientifique Autonome
    </div>

    <div class="title-block">
        <div class="title">{{ project.name }}</div>
        <div class="metadata">
            Auteur : {{ project.user.firstName|default(project.user.email) }} | Date d'export : {{ "now"|date("d/m/Y H:i") }}
        </div>
    </div>

    <div class="content">
        {{ contentHtml|raw }}
    </div>

    <div class="footer">
        Document exporté au format PDF par Djoliba Search
    </div>
</body>
</html>
