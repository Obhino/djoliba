<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{{ project.name }}</title>
    <style>
        /* Importation de polices de haute qualité */
        @import url('https://fonts.googleapis.com/css2?family=Charis+SIL:ital,wght@0,400;0,700;1,400&family=Playfair+Display:wght@700&display=swap');

        /* Structure de Page Académique standard (WeasyPrint) */
        @page {
            size: A4;
            margin: 2.5cm;
            
            @bottom-right {
                content: counter(page);
                font-family: 'Charis SIL', 'Times New Roman', serif;
                font-size: 10pt;
                color: #475569;
            }
            
            @top-center {
                content: string(running_chapter);
                font-family: 'Charis SIL', 'Times New Roman', serif;
                font-size: 8pt;
                font-style: italic;
                color: #64748b;
                border-bottom: 0.5px solid #e2e8f0;
                padding-bottom: 5px;
                width: 100%;
                text-align: center;
            }
        }

        /* Masquage de l'en-tête et pied de page sur la couverture */
        @page :first {
            margin-top: 5cm;
            @top-center {
                content: none;
                border-bottom: none;
            }
            @bottom-right {
                content: none;
            }
        }

        body {
            font-family: 'Charis SIL', 'Times New Roman', 'DejaVu Serif', serif;
            font-size: 11pt;
            line-height: 1.6;
            color: #0f172a;
            text-align: justify;
        }

        /* Couverture / Title Block */
        .title-block {
            margin-bottom: 3cm;
            text-align: center;
            page-break-after: always;
        }

        .title {
            font-family: 'Playfair Display', 'Times New Roman', serif;
            font-size: 26pt;
            font-weight: bold;
            color: #0f172a;
            margin-bottom: 20px;
            line-height: 1.2;
        }

        .metadata {
            font-size: 11pt;
            color: #475569;
            margin-top: 1cm;
            font-style: italic;
        }

        /* Titres dans le document */
        h1, h2, h3, h4 {
            font-family: 'Playfair Display', 'Times New Roman', serif;
            color: #0f172a;
            page-break-after: avoid;
            font-weight: bold;
        }

        h1 {
            font-size: 18pt;
            margin-top: 1.5cm;
            margin-bottom: 0.8cm;
            page-break-before: always;
            string-set: running_chapter content(); /* running headers WeasyPrint */
            border-bottom: 1px solid #cbd5e1;
            padding-bottom: 6px;
        }

        h2 {
            font-size: 14pt;
            margin-top: 1.2cm;
            margin-bottom: 0.6cm;
        }

        h3 {
            font-size: 12pt;
            margin-top: 1cm;
            margin-bottom: 0.4cm;
        }

        /* Paragraphes */
        p {
            margin-top: 0;
            margin-bottom: 12pt;
            text-indent: 1cm; /* Retrait académique standard */
        }
        
        p.no-indent, blockquote p, li p, .figure-container p {
            text-indent: 0;
        }

        /* Table de matières interactive */
        .toc-container {
            page-break-before: always;
            page-break-after: always;
            margin-bottom: 2cm;
        }
        
        .toc-title {
            font-family: 'Playfair Display', serif;
            font-size: 20pt;
            font-weight: bold;
            text-align: center;
            margin-bottom: 1.5cm;
        }

        .toc-list {
            list-style-type: none;
            padding-left: 0;
        }

        .toc-item {
            margin-bottom: 10px;
            font-size: 11pt;
        }

        .toc-item.level-1 {
            font-weight: bold;
            margin-top: 15px;
        }

        .toc-item.level-2 {
            padding-left: 20px;
        }

        .toc-item a {
            text-decoration: none;
            color: #0f172a;
            display: block;
        }

        /* Pointillés d'alignement TOC pour WeasyPrint */
        .toc-item a::after {
            content: leader(dotted) " " target-counter(attr(href), page);
            float: right;
            font-weight: normal;
        }

        .toc-item.level-1 a::after {
            font-weight: bold;
        }

        /* Citations en bloc */
        blockquote {
            margin: 1.5em 2cm;
            padding-left: 15px;
            border-left: 3px solid #64748b;
            font-style: italic;
            color: #475569;
            page-break-inside: avoid;
        }

        /* Blocs de code */
        pre, code {
            font-family: 'DejaVu Sans Mono', monospace;
            background-color: #f8fafc;
            font-size: 9.5pt;
        }

        pre {
            padding: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            margin: 15px 0;
            white-space: pre-wrap;
            page-break-inside: avoid;
        }

        /* Tableaux */
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 25px 0;
            font-size: 10pt;
            page-break-inside: avoid;
        }

        th, td {
            border-top: 1px solid #cbd5e1;
            border-bottom: 1px solid #cbd5e1;
            padding: 8px 12px;
            text-align: left;
        }

        th {
            font-weight: bold;
            background-color: #f8fafc;
            border-bottom: 2px solid #0f172a;
        }

        /* Images et Figures */
        .figure-container, figure {
            text-align: center;
            margin: 20px auto;
            page-break-inside: avoid;
        }

        img {
            max-width: 80%;
            height: auto;
            display: block;
            margin: 0 auto 10px auto;
            border-radius: 4px;
        }

        .caption, figcaption {
            font-size: 9.5pt;
            font-style: italic;
            color: #475569;
            margin-top: 5px;
        }

        /* Annotations d'édition */
        .djoliba-annotation {
            background-color: #fef3c7;
            border-bottom: 1px solid #d97706;
        }

        /* Bibliographie */
        .bibliography-section {
            page-break-before: always;
            margin-top: 2cm;
            border-top: 1px solid #cbd5e1;
            padding-top: 20px;
        }

        .bibliography-section h2 {
            font-size: 16pt;
            margin-bottom: 20px;
        }

        .bibliography-section ul {
            list-style-type: none;
            padding-left: 0;
        }

        .bibliography-section li {
            margin-bottom: 12px;
            padding-left: 30px;
            text-indent: -30px; /* Alignement négatif standard APA */
            text-align: justify;
            font-size: 10.5pt;
            line-height: 1.5;
        }

        /* Liens DOI */
        .doi-link {
            font-family: monospace;
            font-size: 9pt;
            color: #0284c7;
        }
    </style>
</head>
<body>
    {# En-tête invisible pour WeasyPrint, géré par le CSS @top-center #}

    <div class="title-block">
        <div class="title">{{ project.name }}</div>
        <div class="metadata">
            Auteur : {{ project.user.firstName|default(project.user.email) }} <br>
            Date de génération : {{ "now"|date("d/m/Y") }}
        </div>
    </div>

    {# La TOC sera injectée de manière interactive ici si le document est long #}
    <!-- TOC_PLACEHOLDER -->

    <div class="content">
        {{ contentHtml|sanitize_html|raw }}
    </div>
</body>
</html>
