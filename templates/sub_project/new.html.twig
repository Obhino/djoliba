{% extends 'base.html.twig' %}

{% block title %}Nouveau sous-projet - Djoliba{% endblock %}

{% block content %}
<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm space-y-8">
        
        <!-- En-tête -->
        <div class="text-center">
            <span class="text-4xl">📁</span>
            <h1 class="text-2xl font-display font-bold text-djoliba mt-4">Créer une nouvelle activité</h1>
            <p class="text-sm text-slate-400 mt-1">Initialisez un sous-projet pour organiser vos travaux.</p>
        </div>

        <form action="{{ path('app_subproject_create_post') }}" method="POST" class="space-y-6">
            <!-- Nom de l'activité -->
            <div>
                <label for="sp-name" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nom de l'activité</label>
                <input id="sp-name" name="name" type="text" required placeholder="Ex: Étude comparative des modèles de climat" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300">
            </div>

            <!-- Type d'activité -->
            <div>
                <label for="sp-type" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Type d'activité</label>
                <select id="sp-type" name="type" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold">
                    <option value="reading" {{ type == 'reading' ? 'selected' : '' }}>📖 Projet de lecture (Analyse de documents)</option>
                    <option value="literature" {{ type == 'literature' ? 'selected' : '' }}>📚 Projet de synthèse (État de l'art)</option>
                    <option value="writing" {{ type == 'writing' ? 'selected' : '' }}>✍️ Projet d'écriture (Rédaction d'article)</option>
                    <option value="thesis" {{ type == 'thesis' ? 'selected' : '' }}>🎓 Thèse / Mémoire (Projet long)</option>
                </select>
            </div>

            <!-- Rattachement Projet de Recherche -->
            <div>
                <label for="research-project-select" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Projet de recherche parent</label>
                <select id="research-project-select" name="research_project_id" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold">
                    <option value="">Aucun (Créer en tant que projet orphelin)</option>
                    {% for rp in research_projects %}
                        {% set is_selected = active_rp and active_rp.id == rp.id %}
                        <option value="{{ rp.id }}" {{ is_selected ? 'selected' : '' }}>📁 {{ rp.name }}</option>
                    {% endfor %}
                </select>
                <p class="text-[10px] text-slate-400 mt-2">Vous pourrez changer le rattachement de ce projet ultérieurement depuis le tableau de bord.</p>
            </div>

            <!-- Boutons d'action -->
            <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                <a href="{{ path('app_hub') }}" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all text-center">
                    Annuler
                </a>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                    Créer l'activité
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
