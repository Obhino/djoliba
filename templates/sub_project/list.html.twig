{% extends 'base.html.twig' %}

{% block title %}{{ title }} - Djoliba{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8" data-controller="research-project-page">
    
    <!-- Messages Flash -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="p-4 rounded-xl border {{ label == 'success' ? 'bg-emerald-50 border-emerald-200 text-emerald-800' : 'bg-rose-50 border-rose-200 text-rose-800' }} flex items-center justify-between">
                <span class="text-sm font-semibold">{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- En-tête -->
    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div class="space-y-2 max-w-2xl">
            <div class="flex items-center gap-3">
                <span class="text-3xl">
                    {% if type == 'reading' %}📖
                    {% elseif type == 'literature' %}📚
                    {% elseif type == 'writing' %}✍️
                    {% elseif type == 'thesis' %}🎓
                    {% endif %}
                </span>
                <h1 class="text-3xl font-display font-bold text-djoliba">{{ title }}</h1>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed">{{ subtitle }}</p>
            {% if research_project %}
                <div class="text-xs text-slate-400 font-medium">
                    Projet de recherche associé : <span class="text-djoliba font-semibold">{{ research_project.title }}</span>
                </div>
            {% else %}
                <div class="text-xs text-slate-400 font-medium">
                    Sous-projets orphelins (sans projet de recherche parent)
                </div>
            {% endif %}
        </div>

        <button type="button" data-action="click->research-project-page#openCreateModal" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/95 text-white font-bold text-xs shadow-lg shadow-djoliba/25 transition-all flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
            Nouveau sous-projet
        </button>
    </div>

    <!-- Drag & Drop Zone (uniquement pour le type lecture) -->
    {% if type == 'reading' %}
        <div data-controller="reading-list-drag-drop" class="bg-white border border-slate-200 border-dashed hover:border-djoliba hover:bg-djoliba/5 rounded-3xl p-8 shadow-sm flex flex-col items-center justify-center min-h-[200px] transition-all relative overflow-hidden group cursor-pointer"
             data-reading-list-drag-drop-target="dropzone"
             data-action="dragover->reading-list-drag-drop#onDragOver dragleave->reading-list-drag-drop#onDragLeave drop->reading-list-drag-drop#onDrop click->reading-list-drag-drop#triggerSelect">
            
            <input type="file" 
                   data-reading-list-drag-drop-target="fileInput"
                   data-action="change->reading-list-drag-drop#onFileSelect" 
                   class="hidden" 
                   accept="application/pdf">

            <div class="flex flex-col items-center justify-center text-center space-y-3 w-full h-full">
                <div class="w-14 h-14 rounded-full bg-djoliba/5 text-djoliba flex items-center justify-center text-2xl shadow-sm border border-djoliba/10 group-hover:scale-110 transition-transform">
                    📖
                </div>
                
                <div class="space-y-1">
                    <h3 class="text-base font-bold text-djoliba">Déposez votre article PDF ici</h3>
                    <p class="text-xs text-slate-400">ou <span class="text-djoliba underline font-semibold">parcourez vos fichiers</span> pour l'importer</p>
                </div>
                
                <span class="px-2.5 py-0.5 bg-djoliba/5 text-djoliba rounded-full text-[9px] font-bold border border-djoliba/10">Format PDF uniquement</span>
            </div>

            <!-- Indicateur de progression -->
            <div data-reading-list-drag-drop-target="progressContainer" class="absolute inset-0 bg-white/95 backdrop-blur-sm hidden flex flex-col items-center justify-center p-8 z-20">
                <div class="w-full max-w-xs space-y-3">
                    <div class="flex justify-between items-center text-xs font-bold text-djoliba">
                        <span data-reading-list-drag-drop-target="statusText">Importation de l'article...</span>
                    </div>
                    <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                        <div data-reading-list-drag-drop-target="progressBar" class="h-full bg-djoliba transition-all duration-150" style="width: 0%;"></div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    <!-- Liste des sous-projets -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for sp in sub_projects %}
            <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm hover:border-djoliba hover:shadow-md transition-all flex flex-col justify-between group">
                <div>
                    <div class="flex items-center justify-between gap-4 mb-4">
                        <span class="text-xs text-slate-400 font-semibold">{{ sp.createdAt|date('d/m/Y') }}</span>
                        <span class="subproject-status px-2.5 py-0.5 rounded-full text-[10px] font-bold {{ sp.status == 'active' ? 'bg-emerald-500/10 text-emerald-700' : 'bg-slate-100 text-slate-600' }}">
                            {{ sp.status == 'active' ? 'Actif' : 'Archivé' }}
                        </span>
                    </div>

                    <a href="{{ path('app_subproject_show', {id: sp.id}) }}" class="block group-hover:text-djoliba transition-colors mb-2">
                        <h3 class="font-bold text-djoliba text-base truncate">{{ sp.name }}</h3>
                    </a>
                </div>

                <div class="border-t border-slate-100 pt-4 mt-6 flex items-center justify-between">
                    <a href="{{ path('app_subproject_show', {id: sp.id}) }}" class="text-xs font-bold text-emerald_ia hover:underline flex items-center gap-1">
                        Ouvrir l'activité
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>

                    <div class="flex items-center gap-1">
                        <form action="{{ path('app_subproject_toggle_status', {id: sp.id}) }}" method="POST" title="Changer le statut">
                            <button type="submit" class="p-1.5 text-slate-400 hover:text-djoliba hover:bg-slate-100 rounded-lg transition-colors text-sm">
                                🔄
                            </button>
                        </form>
                        
                        <button type="button" data-action="click->research-project-page#openEditModal" data-sp-id="{{ sp.id }}" data-sp-name="{{ sp.name }}" class="p-1.5 text-slate-400 hover:text-djoliba hover:bg-slate-100 rounded-lg transition-colors text-sm" title="Renommer">
                            ✏️
                        </button>

                        <form action="{{ path('app_subproject_delete', {id: sp.id}) }}" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce sous-projet définitivement ?');" title="Supprimer">
                            <button type="submit" class="p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors text-sm">
                                🗑️
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-span-full py-20 text-center bg-white rounded-3xl border border-slate-200 shadow-sm">
                <span class="text-5xl">📁</span>
                <h2 class="text-xl font-bold text-djoliba mt-4 mb-2">Aucun sous-projet trouvé</h2>
                <p class="text-slate-400 mb-6 max-w-sm mx-auto">Créez votre première activité pour commencer vos travaux de recherche.</p>
                <button type="button" data-action="click->research-project-page#openCreateModal" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/95 text-white font-bold text-xs shadow-lg shadow-djoliba/25 transition-all">
                    Créer un sous-projet
                </button>
            </div>
        {% endfor %}
    </div>

    <!-- Modale de Création (Adaptée) -->
    <div data-research-project-page-target="createModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
        <div data-action="click->research-project-page#closeCreateModal" class="absolute inset-0 cursor-default"></div>
        <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-md z-10 transform scale-95 opacity-0 transition-all duration-300">
            <button type="button" data-action="click->research-project-page#closeCreateModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            <div class="mb-6">
                <h3 class="text-2xl font-display font-bold text-djoliba">Ajouter un sous-projet</h3>
                <p class="text-sm text-slate-400 mt-1">Créez une nouvelle activité de type {{ title|lower }}.</p>
            </div>
            <form action="{{ research_project ? path('app_research_project_subproject_create', {id: research_project.id}) : '/sub-project/create' }}" method="POST" class="space-y-6">
                <div>
                    <label for="sp-name" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nom du sous-projet</label>
                    <input id="sp-name" name="name" type="text" required placeholder="Ex: Analyse préliminaire des données" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300">
                </div>
                <input type="hidden" name="type" value="{{ type }}">
                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->research-project-page#closeCreateModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Créer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modale d'Édition -->
    <div data-research-project-page-target="editModal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4 bg-slate-950/20 backdrop-blur-md">
        <div data-action="click->research-project-page#closeEditModal" class="absolute inset-0 cursor-default"></div>
        <div class="relative bg-white rounded-3xl p-8 border border-slate-100 shadow-2xl w-full max-w-md z-10 transform scale-95 opacity-0 transition-all duration-300">
            <button type="button" data-action="click->research-project-page#closeEditModal" class="absolute top-6 right-6 text-slate-400 hover:text-djoliba transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            <div class="mb-6">
                <h3 class="text-2xl font-display font-bold text-djoliba">Renommer l'activité</h3>
                <p class="text-sm text-slate-400 mt-1">Donnez un nouveau nom à votre sous-projet.</p>
            </div>
            <form id="edit-sp-form" action="" method="POST" class="space-y-6">
                <div>
                    <label for="edit-sp-name" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nom du sous-projet</label>
                    <input id="edit-sp-name" name="name" type="text" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:border-djoliba focus:ring-4 focus:ring-djoliba/10 transition-all text-sm text-djoliba font-semibold placeholder:text-slate-300">
                </div>
                <div class="flex justify-end gap-3 pt-4 border-t border-slate-50">
                    <button type="button" data-action="click->research-project-page#closeEditModal" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-500 font-bold text-xs hover:bg-slate-50 hover:text-djoliba transition-all">
                        Annuler
                    </button>
                    <button type="submit" class="px-5 py-2.5 rounded-xl bg-djoliba hover:bg-djoliba/90 text-white font-bold text-xs shadow-lg shadow-djoliba/20 transition-all">
                        Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
