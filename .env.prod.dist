# Template de configuration de production pour Djoliba
# Copiez ce fichier sous le nom .env.prod et renseignez les vraies valeurs.

APP_ENV=prod
APP_SECRET=place_your_app_secret_here

# Secrets et clés API critiques (Requis pour le boot de l'application en production)
DEEPSEEK_API_KEY=place_your_deepseek_api_key_here
OPENSERP_API_KEY=place_your_openserp_api_key_here
DB_PASSWORD=place_your_db_password_here

# Clé de chiffrement symétrique pour sécuriser les données sensibles (ex: Zotero API keys)
# Doit être une clé de 64 caractères hexadécimaux (32 octets).
# Génération : openssl rand -hex 32
ENCRYPTION_KEY=place_your_encryption_key_here

# Base de données (les conteneurs utilisent l'hôte interne "database" dans compose.prod.yaml)
DATABASE_URL="postgresql://djoliba:${DB_PASSWORD}@database:5432/djolibadb?serverVersion=16&charset=utf8"

# Redis Cache & Sessions (les conteneurs utilisent l'hôte interne "redis" dans compose.prod.yaml)
REDIS_PASSWORD=place_your_redis_password_here
REDIS_URL="redis://:${REDIS_PASSWORD}@redis:6379"

# Emails (SMTP)
# Remplacez par les vrais identifiants de votre serveur SMTP (SendGrid, Mailgun, OVH, Gmail, etc.)
# Format: smtp://user:pass@smtp.example.com:port
MAILER_DSN=smtp://user:pass@smtp.example.com:587

# Configuration des envois d'e-mails (SMTP de production)
# Exemple pour Brevo/Sendgrid/Mailjet :
# MAILER_DSN="smtp://username:password@smtp.sendgrid.net:587?encryption=tls"
MAILER_DSN="null://null"

# Configuration des proxys de confiance (Trusted Proxies / Headers si derrière un Load Balancer / CDN)
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
# TRUSTED_HEADERS=x-forwarded-for,x-forwarded-host,x-forwarded-proto,x-forwarded-port
